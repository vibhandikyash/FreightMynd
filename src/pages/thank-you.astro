---
import Page from '../layouts/Page.astro';
---

<Page
  title="Thank You | CargoIQ.ai"
  description="Thank you for reaching out to CargoIQ.ai. We'll review your details and get back to you within 1 business day."
  noindex={true}
>
  <section class="min-h-[70vh] flex items-center justify-center" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-lg mx-auto text-center py-20">
        <span class="text-5xl mb-6 block" aria-hidden="true">&#10003;</span>
        <h1 class="text-display-md font-bold text-ink">
          Thank You for Reaching Out
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          We'll review your details and get back to you within 1 business day.
        </p>
        <div class="mt-8">
          <a href="/" class="btn btn-brand">
            Back to Homepage
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Page>
