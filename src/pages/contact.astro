---
import Page from '../layouts/Page.astro';
import { site } from '../data/site';
import { Image } from 'astro:assets';
import contactImg from '../assets/images/contact-cta.webp';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Contact" },
  ],
};

const expectations = [
  {
    icon: '📞',
    title: '30-Minute Discovery Call',
    description: 'A focused conversation about your freight operations, current pain points, and what automation could look like.',
  },
  {
    icon: '🗺️',
    title: 'Operations Workflow Mapping',
    description: 'We map your current document flows, quoting processes, and TMS interactions to identify the highest-impact automation targets.',
  },
  {
    icon: '📊',
    title: 'Custom Automation Roadmap',
    description: 'A detailed proposal with timeline, expected results, and ROI projections — specific to your operation.',
  },
];
---

<Page
  title="Book a Free Freight Operations Audit | CargoIQ.ai"
  description="Book a free 30-minute discovery call. We'll map your freight operations workflow, identify automation opportunities, and deliver a custom roadmap with ROI projections."
  schema={breadcrumbSchema}
>
  <!-- Breadcrumb -->
  <div class="pt-28 bg-surface">
    <div class="container pt-4 pb-0">
      <nav aria-label="Breadcrumb" class="text-xs text-ink-4 font-mono">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <span class="mx-1.5">/</span>
        <span class="text-ink-3">Contact</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Get Started
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          Book a Free Freight Operations Audit
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          We'll map your current freight operations workflow, identify the highest-impact logistics automation opportunities, and show you exactly what we'd build — with a timeline and expected results.
        </p>
      </div>
    </div>
  </section>

  <!-- Visual -->
  <section class="pb-0 pt-0 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-reveal>
        <Image
          src={contactImg}
          alt="Freight operations workflow being automated with CargoIQ AI systems"
          widths={[640, 960, 1180]}
          sizes="(max-width: 1220px) calc(100vw - 40px), 960px"
          quality={80}
          class="w-full rounded-2xl border border-line/70 shadow-lg"
        />
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="max-w-2xl mb-10" data-reveal>
        <h2 class="section-heading">What to Expect</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {expectations.map((item, i) => (
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="text-2xl mb-4 block" aria-hidden="true">{item.icon}</span>
            <h3 class="text-lg font-bold text-ink mb-2">{item.title}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Investment Model -->
  <section class="section" style="background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Investment Model
        </p>
        <h2 class="section-heading">How Much Does This Cost?</h2>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Every CargoIQ engagement is scoped to your operations. We don't sell seats or subscriptions. You invest in a system built for your environment — and you own it.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-7 rounded-2xl border border-line/70 bg-white hover:shadow-md hover:-translate-y-1 transition-all duration-300" data-reveal data-reveal-delay="1">
          <span class="tag tag-brand mb-4">Free</span>
          <h3 class="text-lg font-bold text-ink mb-3">Discovery & Audit</h3>
          <p class="text-sm text-ink-3 leading-relaxed">Free. No commitment. We map your workflows and deliver a custom automation roadmap with ROI projections.</p>
        </div>
        <div class="p-7 rounded-2xl border border-line/70 bg-white hover:shadow-md hover:-translate-y-1 transition-all duration-300" data-reveal data-reveal-delay="2">
          <span class="tag tag-brand mb-4">Project Fee</span>
          <h3 class="text-lg font-bold text-ink mb-3">Build & Deploy</h3>
          <p class="text-sm text-ink-3 leading-relaxed">Project-based investment scoped to your operations complexity, document volumes, and TMS integration requirements. Typical engagements range from initial single-pipeline builds to full multi-system deployments.</p>
        </div>
        <div class="p-7 rounded-2xl border border-line/70 bg-white hover:shadow-md hover:-translate-y-1 transition-all duration-300" data-reveal data-reveal-delay="3">
          <span class="tag tag-brand mb-4">Monthly Retainer</span>
          <h3 class="text-lg font-bold text-ink mb-3">Ongoing Support</h3>
          <p class="text-sm text-ink-3 leading-relaxed">Optional support and optimization retainer. Includes system monitoring, model updates, new supplier onboarding, and TMS API maintenance.</p>
        </div>
      </div>

      <div class="mt-10 max-w-3xl" data-reveal data-reveal-delay="4">
        <p class="text-sm text-ink-3 leading-relaxed">
          <strong class="text-ink">Most clients see positive ROI within 3–6 months of deployment.</strong> We include ROI projections in every audit.
        </p>
        <p class="mt-4 text-sm text-ink-4 leading-relaxed border-l-2 border-brand/30 pl-4">
          Want a ballpark before the call? Tell us your document volume and TMS in the form below — we'll include a budget range in our response.
        </p>
      </div>
    </div>
  </section>

  <!-- Form + Contact Info -->
  <section class="section bg-surface">
    <div class="container">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="lg:col-span-2" data-reveal>
          <form id="contact-form" action="https://formspree.io/f/placeholder" method="POST" class="bg-white p-8 md:p-10 rounded-2xl border border-line/70 shadow-card">
            <h2 class="text-xl font-bold text-ink mb-6">Tell Us About Your Operations</h2>

            <!-- Honeypot -->
            <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
            <!-- Redirect after submit -->
            <input type="hidden" name="_next" value="/thank-you" />
            <!-- Email subject -->
            <input type="hidden" name="_subject" value="New CargoIQ Audit Request" />

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-ink mb-1.5">Name <span class="text-red-500">*</span></label>
                <input type="text" id="name" name="name" required
                       class="w-full px-4 py-3 rounded-xl border border-line bg-surface/50 text-ink text-sm placeholder:text-ink-4 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition-colors"
                       placeholder="Your full name" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email <span class="text-red-500">*</span></label>
                <input type="email" id="email" name="email" required
                       class="w-full px-4 py-3 rounded-xl border border-line bg-surface/50 text-ink text-sm placeholder:text-ink-4 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition-colors"
                       placeholder="you@company.com" />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-ink mb-1.5">Company <span class="text-red-500">*</span></label>
                <input type="text" id="company" name="company" required
                       class="w-full px-4 py-3 rounded-xl border border-line bg-surface/50 text-ink text-sm placeholder:text-ink-4 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition-colors"
                       placeholder="Company name" />
              </div>
              <div>
                <label for="role" class="block text-sm font-medium text-ink mb-1.5">Role / Title</label>
                <input type="text" id="role" name="role"
                       class="w-full px-4 py-3 rounded-xl border border-line bg-surface/50 text-ink text-sm placeholder:text-ink-4 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition-colors"
                       placeholder="e.g. Head of Operations" />
              </div>
            </div>

            <div class="mt-5">
              <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message</label>
              <textarea id="message" name="message" rows="5"
                        class="w-full px-4 py-3 rounded-xl border border-line bg-surface/50 text-ink text-sm placeholder:text-ink-4 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition-colors resize-y"
                        placeholder="Tell us about your current freight operations, volume, TMS, and what you're looking to automate..."></textarea>
            </div>

            <div class="mt-6">
              <button id="submit-btn" type="submit" class="btn btn-brand w-full sm:w-auto justify-center">
                <span id="submit-text">Book Your Free Audit</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </button>
            </div>

            <p class="mt-4 text-xs text-ink-4">
              No commitment. We'll respond within 1 business day.
            </p>
            <p class="mt-2 text-xs text-ink-4">
              Prefer email? Reach us at <a href={`mailto:${site.contact.email}`} class="text-brand hover:text-brand-dark transition-colors font-medium">{site.contact.email}</a>
            </p>
          </form>

          <!-- Not sure where to start -->
          <div class="mt-8 bg-white p-8 rounded-2xl border border-line/70 shadow-card" data-reveal>
            <h3 class="text-lg font-bold text-ink mb-2">Not sure where to start?</h3>
            <p class="text-sm text-ink-3 mb-5">Explore what we build and see real results:</p>
            <ul class="space-y-3">
              <li>
                <a href="/solutions/4pl-control-tower-automation" class="text-sm text-brand hover:text-brand-dark transition-colors font-medium inline-flex items-center gap-1.5">
                  <span aria-hidden="true">&rarr;</span> 4PL Control Tower Automation
                </a>
              </li>
              <li>
                <a href="/solutions/document-intelligence" class="text-sm text-brand hover:text-brand-dark transition-colors font-medium inline-flex items-center gap-1.5">
                  <span aria-hidden="true">&rarr;</span> Document Intelligence
                </a>
              </li>
              <li>
                <a href="/solutions/autonomous-quote-management" class="text-sm text-brand hover:text-brand-dark transition-colors font-medium inline-flex items-center gap-1.5">
                  <span aria-hidden="true">&rarr;</span> Autonomous Quote Management
                </a>
              </li>
              <li>
                <a href="/case-studies/hellmann-4pl-control-tower" class="text-sm text-brand hover:text-brand-dark transition-colors font-medium inline-flex items-center gap-1.5">
                  <span aria-hidden="true">&rarr;</span> Hellmann Case Study — 60% processing time reduction
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-1" data-reveal data-reveal-delay="1">
          <div class="bg-white p-8 rounded-2xl border border-line/70 shadow-card">
            <h3 class="text-lg font-bold text-ink mb-5">Get in Touch</h3>

            <div class="space-y-5">
              <div>
                <p class="text-xs font-mono text-ink-4 uppercase tracking-wider mb-1">Email</p>
                <a href={`mailto:${site.contact.email}`} class="text-sm text-brand hover:text-brand-dark transition-colors font-medium">
                  {site.contact.email}
                </a>
              </div>

              <div>
                <p class="text-xs font-mono text-ink-4 uppercase tracking-wider mb-1">LinkedIn</p>
                <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer"
                   class="text-sm text-brand hover:text-brand-dark transition-colors font-medium inline-flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  CargoIQ on LinkedIn
                </a>
              </div>

              <div>
                <p class="text-xs font-mono text-ink-4 uppercase tracking-wider mb-1">Offices</p>
                <address class="not-italic text-sm text-ink-3">
                  <strong>United States</strong><br/>
                  Clifton, NJ
                </address>
                <address class="not-italic text-sm text-ink-3 mt-1">
                  <strong>India</strong><br/>
                  Gujarat
                </address>
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-line/50">
              <p class="text-xs text-ink-4 leading-relaxed">
                Built by <a href={site.builtBy.url} target="_blank" rel="noopener noreferrer" class="text-ink-3 hover:text-ink transition-colors">{site.builtBy.name}</a> — specialist AI engineering for freight and logistics.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Form enhancement scripts -->
  <script>
    // Disable-on-submit
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text') as HTMLSpanElement;
    form?.addEventListener('submit', () => {
      submitBtn.disabled = true;
      submitText.textContent = 'Sending...';
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
    });

    // Pre-fill message from URL ?interest= parameter
    const params = new URLSearchParams(window.location.search);
    const interest = params.get('interest');
    if (interest) {
      const textarea = document.getElementById('message') as HTMLTextAreaElement;
      if (textarea) {
        textarea.value = `I'm interested in ${interest.replace(/-/g, ' ')}. `;
        textarea.focus();
      }
    }
  </script>
</Page>
