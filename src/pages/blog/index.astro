---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Blog" },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AI for Freight Operations Blog",
  "numberOfItems": posts.length,
  "itemListElement": posts.map((post, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": post.data.title,
    "url": `${site.url}/blog/${post.id}`
  }))
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Page
  title="Blog — Insights on AI for Freight Operations"
  description="Expert insights on AI for freight forwarding — 4PL control towers, document intelligence, pricing AI, and CargoWise integration guides."
  schema={[breadcrumbSchema, itemListSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Blog' }]} bg="bg-white" />

  <!-- Hero -->
  <section class="bg-white border-b border-line">
    <div class="container py-16 md:py-20">
      <div class="eyebrow mb-4" data-reveal>
        <span class="eyebrow-dot bg-brand"></span>
        Blog
      </div>
      <h1 class="text-display-lg font-bold text-ink max-w-2xl" data-reveal data-reveal-delay="1">
        Insights on AI for Freight Operations
      </h1>
      <p class="mt-4 hero-description text-ink-3 max-w-xl" data-reveal data-reveal-delay="2">
        Guides, technical deep-dives, and real deployment stories from the team building AI systems for freight forwarders.
      </p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p class="text-ink-3 text-center py-12">No posts yet. Check back soon.</p>
      ) : (
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="card group block overflow-hidden">
              <div class="p-6 md:p-8">
                <div class="flex items-center gap-3 mb-4">
                  <span class="tag tag-brand">{post.data.category}</span>
                  <span class="text-xs text-ink-4 font-mono">{post.data.readingTime}</span>
                </div>
                <h2 class="text-lg font-bold text-ink group-hover:text-brand transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <p class="mt-3 text-sm text-ink-3 leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
                <div class="mt-5 flex items-center gap-3 text-xs text-ink-4">
                  <span class="font-medium text-ink-3">{post.data.author}</span>
                  <span aria-hidden="true" class="w-1 h-1 rounded-full bg-ink-4"></span>
                  <time datetime={post.data.publishDate.toISOString()}>
                    {formatDate(post.data.publishDate)}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-[-20%] left-[-10%] w-[300px] h-[300px] rounded-full bg-white/5 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-lg font-bold text-white max-w-3xl mx-auto" style="padding-left:0; border-left:none;">
        Ready to Automate Your Freight Operations?
      </h2>
      <p class="mt-5 text-lg text-white/80 max-w-xl mx-auto leading-relaxed">
        Book a free audit. We'll map your workflows and show you exactly what we'd build.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact/" class="btn btn-cta-single">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions/" class="btn bg-brand border border-brand text-white hover:bg-white hover:border-white hover:text-ink">
          Explore Solutions
        </a>
      </div>
    </div>
  </section>
</Page>
