---
import Page from '../layouts/Page.astro';
import Hero from '../components/sections/Hero.astro';
import StatsBar from '../components/sections/StatsBar.astro';
import SectorCards from '../components/sections/SectorCards.astro';
import ProblemSection from '../components/sections/ProblemSection.astro';
import ProofSection from '../components/sections/ProofSection.astro';
import DiffSection from '../components/sections/DiffSection.astro';
import SuiteSection from '../components/sections/SuiteSection.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import HowWeEngage from '../components/sections/HowWeEngage.astro';
import HomeFaq from '../components/sections/HomeFaq.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import { site } from '../data/site';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "FreightMynd",
  "url": "https://freightmynd.com",
  "logo": "https://freightmynd.com/FM-logo.svg",
  "description": "AI-powered operations intelligence for sea, air & freight forwarders. Custom-built systems that replace manual freight operations.",
  "foundingDate": "2019",
  "address": [
    { "@type": "PostalAddress", "addressCountry": "US", "addressLocality": "Clifton" },
    { "@type": "PostalAddress", "addressCountry": "IN", "addressLocality": "Gujarat" }
  ],
  "sameAs": ["https://www.linkedin.com/company/freightmynd"],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": site.contact.email,
    "telephone": site.contact.phone,
    "contactType": "sales",
    "url": `${site.url}/contact`
  },
  "knowsAbout": [
    "AI for Freight Forwarding",
    "Freight Forwarding Software",
    "Freight Automation Software",
    "TMS Software",
    "TMS Transportation Software",
    "Freight Management System",
    "Shipping Automation",
    "Digital Freight Forwarding",
    "AI Logistics Automation",
    "AI Document Processing for Logistics",
    "AI for CargoWise",
    "CargoWise Automation",
    "Freight Forwarding Automation",
    "4PL Control Tower Automation",
    "Autonomous Quote Management",
    "AI in Logistics",
    "Supply Chain Artificial Intelligence",
    "Freight Forwarding Service Automation",
    "Shipping AI",
    "Customs Declaration Automation",
    "Freight Document OCR",
    "Freight Invoice Matching",
    "RFQ Automation Logistics",
    "Freight Rate Benchmarking",
    "Demurrage Prevention AI"
  ],
  "parentOrganization": {
    "@type": "Organization",
    "name": "Bitontree",
    "url": "https://bitontree.com"
  },
  "makesOffer": [
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "4PL Control Tower Automation", "url": "https://freightmynd.com/solutions/4pl-control-tower-automation" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Autonomous Quote Management", "url": "https://freightmynd.com/solutions/autonomous-quote-management" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Document Intelligence", "url": "https://freightmynd.com/solutions/document-intelligence" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Freight Pricing AI", "url": "https://freightmynd.com/solutions/freight-pricing-ai" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sea Freight Automation", "url": "https://freightmynd.com/solutions/sea-freight-automation" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Air Freight Automation", "url": "https://freightmynd.com/solutions/air-freight-automation" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "3PL & 4PL Operations Automation", "url": "https://freightmynd.com/solutions/3pl-4pl-operations" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Smart Invoice Processing", "url": "https://freightmynd.com/solutions/smart-invoice-processing" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Freight Revenue Recovery", "url": "https://freightmynd.com/solutions/freight-revenue-recovery" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Freight Spend Analytics", "url": "https://freightmynd.com/solutions/freight-spend-analytics" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Customs Automation", "url": "https://freightmynd.com/solutions/customs-automation" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Freight Document Automation", "url": "https://freightmynd.com/solutions/freight-document-automation" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "TMS Automation", "url": "https://freightmynd.com/solutions/tms-automation" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Email Intelligence & Auto-Triage", "url": "https://freightmynd.com/solutions/email-intelligence" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Shipment Visibility & Customer Portal", "url": "https://freightmynd.com/solutions/shipment-visibility-portal" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Carrier Performance Analytics", "url": "https://freightmynd.com/solutions/carrier-performance-analytics" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Freight Booking Automation", "url": "https://freightmynd.com/solutions/booking-automation" } },
