  "numberOfEmployees": {
    "@type": "QuantitativeValue",
    "minValue": 10,
    "maxValue": 50
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is 4PL control tower automation?",
      "acceptedAnswer": { "@type": "Answer", "text": "A 4PL control tower automation system monitors all incoming shipment documents, extracts structured data from invoices, AWBs, and packing lists, validates the data against your business rules, and pushes it directly into your TMS \u2014 replacing the manual reading, sorting, and data entry your ops team currently performs for every shipment." }
    },
    {
      "@type": "Question",
      "name": "Does FreightMynd integrate with CargoWise?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The system we built for Hellmann Worldwide Logistics pushes clean XML directly into CargoWise via the eHub and Universal Gateway APIs. We also integrate with SAP TM, Oracle TMS, Microsoft Dynamics 365, and Descartes." }
    },
    {
      "@type": "Question",
      "name": "Is FreightMynd a SaaS product?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. FreightMynd is not freight forwarding software you subscribe to \u2014 we build custom AI systems deployed in your environment. You own the system outright with no recurring subscription. This means the system is built for your TMS software, your suppliers, your document formats, and your business rules \u2014 not a generic workflow that requires your operations to conform to it." }
    },
    {
      "@type": "Question",
      "name": "How long does implementation take?",
      "acceptedAnswer": { "@type": "Answer", "text": "Typically 8\u201314 weeks from kickoff to production. Discovery and audit takes 2 weeks, build and training takes 6\u20138 weeks, and UAT and production deployment takes 2\u20134 weeks. We deploy with a 30-day hypercare period." }
    },
    {
      "@type": "Question",
      "name": "What freight operations can be automated?",
      "acceptedAnswer": { "@type": "Answer", "text": "AI document processing (invoices, AWBs, packing lists, customs forms), freight quoting (RFQ intake, rate comparison, quote generation), sea freight shipping automation (booking, BL processing, container tracking, demurrage monitoring), air freight operations (AWB processing, flight tracking, DG documentation), smart invoice processing (extraction, 3-way matching, overcharge detection), and 3PL/4PL multi-client workflow management." }
    },
    {
      "@type": "Question",
      "name": "What is the ROI of AI for freight forwarding?",
      "acceptedAnswer": { "@type": "Answer", "text": "Based on our production deployments of freight automation software, freight forwarders see 60% reduction in document processing time, 50% reduction in AI processing costs via intelligent filtering, and full elimination of manual TMS data entry. For a mid-size forwarder processing 150+ documents daily, AI logistics automation typically translates to 2-3 FTEs reallocated from data entry to higher-value operations within the first 90 days." }
    },
    {
      "@type": "Question",
      "name": "How does AI document processing for logistics work?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our AI for document processing monitors your ops inbox for incoming supplier documents, automatically downloads attachments, uses document processing automation to classify and filter irrelevant pages (cutting processing costs by 50%), extracts structured data from invoices, AWBs, packing lists, and compliance documents, validates against your business rules, and pushes clean data directly into your freight management system via AI for CargoWise, SAP TM, or Oracle TMS — all without human intervention." }
    },
    {
      "@type": "Question",
      "name": "Which TMS platforms does FreightMynd integrate with?",
      "acceptedAnswer": { "@type": "Answer", "text": "FreightMynd integrates natively with CargoWise (via eHub and Universal Gateway), SAP TM (classic and S/4HANA), Oracle TMS (cloud and on-premise), Microsoft Dynamics 365, and Descartes. Each integration is built natively for your specific TMS instance, not through a generic connector." }
    },
    {
      "@type": "Question",
      "name": "What is the best AI for freight forwarding in 2026?",
      "acceptedAnswer": { "@type": "Answer", "text": "The best AI for freight forwarding depends on your operational complexity. For standard workflows, SaaS products like Raft, Expedock, or Shipamax offer pre-built document processing. For freight forwarders with complex operations — diverse supplier formats, custom business rules, and deep TMS integration requirements — custom-built AI systems like FreightMynd deliver higher accuracy and lower total cost of ownership. FreightMynd is production-tested at Hellmann Worldwide Logistics." }
    },
    {
      "@type": "Question",
      "name": "What AI tools integrate directly with CargoWise?",
      "acceptedAnswer": { "@type": "Answer", "text": "FreightMynd integrates with CargoWise via eHub and Universal Gateway APIs, pushing clean XML directly into CargoWise modules. Other AI tools with CargoWise integration include Expedock, Raft, and Shipamax. FreightMynd's integration is native XML push (not CSV import), production-tested at Hellmann Worldwide Logistics processing 200-300 page document batches daily." }
    },
    {
      "@type": "Question",
      "name": "How much does AI automation for freight forwarding cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "FreightMynd uses a project-based pricing model: a fixed fee for the initial build and deployment, with no recurring subscription or per-seat charges. For a mid-size forwarder processing 150+ documents daily, the system typically pays for itself within 3-6 months through reduced manual processing time and eliminated data entry errors." }
    },
    {
      "@type": "Question",
      "name": "Will AI replace freight forwarders?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. AI is replacing manual data entry and document processing tasks, not freight forwarders themselves. At Hellmann Worldwide Logistics, the AI system eliminated all manual document processing without reducing headcount — the ops team now handles more volume with higher accuracy. AI augments freight operations by removing repetitive work so teams can focus on customer relationships and exception handling." }
    },
    {
      "@type": "Question",
      "name": "Can AI automate customs declarations and filing?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. AI can automate data extraction and pre-population of customs declarations from commercial invoices, packing lists, and certificates of origin, typically reducing filing time by 70%. The customs broker still reviews and submits — AI removes the data entry bottleneck. FreightMynd's customs automation system extracts structured customs data and pushes it directly into filing platforms via document intelligence." }
    }
  ]
};

const schema = [orgSchema, faqSchema];
---

<Page
  title="FreightMynd — AI Freight Automation for Forwarders"
  description="AI freight forwarding software — document processing automation, quote management, and TMS software integration built for your stack. Trusted by Hellmann."
  schema={schema}
>
  <Hero />
  <StatsBar />
  <ProblemSection />
  <ProofSection />
  <SectorCards />
  <DiffSection />
  <SuiteSection variant="logistics" />
  <Testimonials />
  <HowWeEngage />
  <HomeFaq />
  <CtaSection />
</Page>
