---
import Page from '../layouts/Page.astro';
import Hero from '../components/sections/Hero.astro';
import StatsBar from '../components/sections/StatsBar.astro';
import SectorCards from '../components/sections/SectorCards.astro';
import ProblemSection from '../components/sections/ProblemSection.astro';
import ProofSection from '../components/sections/ProofSection.astro';
import DiffSection from '../components/sections/DiffSection.astro';
import SuiteSection from '../components/sections/SuiteSection.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import HowWeEngage from '../components/sections/HowWeEngage.astro';
import HomeFaq from '../components/sections/HomeFaq.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import { site } from '../data/site';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "FreightMynd",
  "url": site.url,
  "logo": `${site.url}/FM-logo.svg`,
  "description": "AI in logistics and freight forwarding — custom-built systems that replace manual freight operations for sea, air & freight forwarders.",
  "foundingDate": "2019",
  "address": [
    { "@type": "PostalAddress", "addressCountry": "US", "addressLocality": "Clifton" },
    { "@type": "PostalAddress", "addressCountry": "IN", "addressLocality": "Gujarat" }
  ],
  "sameAs": [site.social.linkedin],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": site.contact.email,
    "contactType": "sales",
    "url": `${site.url}/contact`
  },
  "knowsAbout": [
    "AI for Freight Forwarding",
    "Freight Automation Software",
    "AI Logistics Automation",
    "AI Document Processing for Logistics",
    "AI for CargoWise",
    "Freight Forwarding Automation",
    "4PL Control Tower Automation",
    "Autonomous Quote Management",
    "AI in Logistics",
    "Supply Chain Artificial Intelligence",
    "Freight Forwarding Service Automation",
    "Shipping AI"
  ],
  "areaServed": "Global",
  "numberOfEmployees": {
    "@type": "QuantitativeValue",
    "minValue": 10,
    "maxValue": 50
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is 4PL control tower automation?",
      "acceptedAnswer": { "@type": "Answer", "text": "A 4PL control tower automation system monitors all incoming shipment documents, extracts structured data from invoices, AWBs, and packing lists, validates the data against your business rules, and pushes it directly into your TMS \u2014 replacing the manual reading, sorting, and data entry your ops team currently performs for every shipment." }
    },
    {
      "@type": "Question",
      "name": "Does FreightMynd integrate with CargoWise?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The system we built for Hellmann Worldwide Logistics pushes clean XML directly into CargoWise via the eHub and Universal Gateway APIs. We also integrate with SAP TM, Oracle TMS, Microsoft Dynamics 365, and Descartes." }
    },
    {
      "@type": "Question",
      "name": "Is FreightMynd a SaaS product?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. We build custom AI systems deployed in your environment \u2014 not a SaaS seat. You own the system outright with no recurring subscription. This means the system is built for your TMS, your suppliers, your document formats, and your business rules \u2014 not a generic workflow that requires your operations to conform to it." }
    },
    {
      "@type": "Question",
      "name": "How long does implementation take?",
      "acceptedAnswer": { "@type": "Answer", "text": "Typically 8\u201314 weeks from kickoff to production. Discovery and audit takes 2 weeks, build and training takes 6\u20138 weeks, and UAT and production deployment takes 2\u20134 weeks. We deploy with a 30-day hypercare period." }
    },
    {
      "@type": "Question",
      "name": "What freight operations can be automated?",
      "acceptedAnswer": { "@type": "Answer", "text": "Document processing (invoices, AWBs, packing lists, customs forms), freight quoting (RFQ intake, rate comparison, quote generation), sea freight operations (booking, BL processing, container tracking, demurrage monitoring), air freight operations (AWB processing, flight tracking, DG documentation), invoice processing (extraction, 3-way matching, overcharge detection), and 3PL/4PL multi-client workflow management." }
    },
    {
      "@type": "Question",
      "name": "What is the ROI of AI for freight forwarding?",
      "acceptedAnswer": { "@type": "Answer", "text": "Based on our production deployments of freight automation software, freight forwarders see 60% reduction in document processing time, 50% reduction in AI processing costs via intelligent filtering, and full elimination of manual TMS data entry. For a mid-size forwarder processing 150+ documents daily, AI logistics automation typically translates to 2-3 FTEs reallocated from data entry to higher-value operations within the first 90 days." }
    },
    {
      "@type": "Question",
      "name": "How does AI document processing for logistics work?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our AI document processing for logistics monitors your ops inbox for incoming supplier documents, automatically downloads attachments, uses AI to classify and filter irrelevant pages (cutting processing costs by 50%), extracts structured data from invoices, AWBs, packing lists, and compliance documents, validates against your business rules, and pushes clean data directly into your TMS via AI for CargoWise, SAP TM, or Oracle TMS — all without human intervention." }
    },
    {
      "@type": "Question",
      "name": "Which TMS platforms does FreightMynd integrate with?",
      "acceptedAnswer": { "@type": "Answer", "text": "FreightMynd integrates natively with CargoWise (via eHub and Universal Gateway), SAP TM (classic and S/4HANA), Oracle TMS (cloud and on-premise), Microsoft Dynamics 365, and Descartes. Each integration is built natively for your specific TMS instance, not through a generic connector." }
    }
  ]
};

const schema = [orgSchema, faqSchema];
---

<Page
  title="FreightMynd — AI for Freight Forwarding | Freight Automation Software"
  description="AI in logistics and freight forwarding — document processing, quote automation, and TMS integration built for your stack. Trusted by Hellmann."
  schema={schema}
>
  <Hero />
  <StatsBar />
  <ProblemSection />
  <ProofSection />
  <SectorCards />
  <DiffSection />
  <SuiteSection variant="logistics" />
  <Testimonials />
  <HowWeEngage />
  <HomeFaq />
  <CtaSection />
</Page>
