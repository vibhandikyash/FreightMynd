---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Compare" },
    { "@type": "ListItem", "position": 3, "name": "Freightos vs FreightMynd" },
  ],
};

const faqItems = [
  {
    q: 'What is the difference between Freightos and FreightMynd?',
    a: 'Freightos is a freight rate marketplace and booking platform — it aggregates carrier rates and provides a platform for comparing and booking freight. FreightMynd builds custom AI operations systems for freight forwarders — document intelligence, quoting automation, and deep TMS integration. Freightos focuses on rate discovery and booking; FreightMynd focuses on automating the operational workflows that happen after booking — document processing, data entry, compliance, and TMS updates.',
  },
  {
    q: 'Is FreightMynd a Freightos alternative?',
    a: 'Not directly. Freightos and FreightMynd solve different problems. Freightos is a rate marketplace for finding and comparing carrier rates. FreightMynd automates freight operations — document processing, quoting, and TMS integration. They overlap in pricing intelligence, but FreightMynd combines market data with your historical pricing data and custom business rules for more accurate, context-aware quotes. Many freight forwarders could use both.',
  },
  {
    q: 'Can I use Freightos and FreightMynd together?',
    a: 'Yes. Freightos provides rate marketplace data, while FreightMynd handles the operational automation — document processing, data extraction, validation, and TMS integration. FreightMynd can ingest rate data from Freightos (or any source) and combine it with your historical pricing, margin rules, and carrier preferences to generate more accurate quotes. The two systems are complementary rather than competing.',
  },
  {
    q: 'Does FreightMynd offer freight rate data like Freightos?',
    a: 'FreightMynd does not operate a rate marketplace. Instead, FreightMynd\'s freight pricing AI combines multiple data sources — market rate data (which can include Freightos data), your historical pricing, carrier contracts, and real-time market conditions — to generate intelligent, context-aware pricing recommendations. This approach provides more accurate quotes tailored to your specific operation rather than generic marketplace rates.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const comparisonRows = [
  { category: 'Focus', freightos: 'Freight rate marketplace and booking platform', cargoiq: 'Custom AI operations automation for freight forwarders' },
  { category: 'Pricing Intelligence', freightos: 'Market rate data from the Freightos marketplace', cargoiq: 'Dynamic pricing + market data + your historical data combined' },
  { category: 'Document Processing', freightos: 'Not a core focus', cargoiq: 'Core capability — invoices, AWBs, packing lists, compliance docs' },
  { category: 'TMS Integration', freightos: 'Limited — primarily their own platform', cargoiq: 'Deep native integration with CargoWise, SAP TM, Oracle TMS, and more' },
  { category: 'Quoting', freightos: 'Through the Freightos platform', cargoiq: 'Your existing workflow, automated with AI' },
  { category: 'Ownership', freightos: 'Platform dependency — your data lives in their ecosystem', cargoiq: 'You own the system — deployed in your environment' },
  { category: 'Rate Sheet Processing', freightos: 'Marketplace rate aggregation from carriers', cargoiq: 'AI ingests your carrier rate sheets in any format, normalises, and powers your quoting engine' },
  { category: 'Email Automation', freightos: 'Not offered', cargoiq: 'AI email triage, RFQ detection, auto-response, attachment routing' },
  { category: 'Booking Automation', freightos: 'eBooking through marketplace', cargoiq: 'Quote-to-booking in your TMS, carrier confirmation parsing, amendment handling' },
  { category: 'Customer Portal', freightos: 'Marketplace-based shipper portal', cargoiq: 'White-label portal — your brand, your data, full visibility and analytics' },
  { category: 'Carrier Analytics', freightos: 'Freightos Baltic Index (market benchmarks)', cargoiq: 'AI scorecards from your own shipment data — lane-level, real-time' },
  { category: 'ETA & Exceptions', freightos: 'Basic tracking through platform', cargoiq: 'Predictive ETA AI, proactive delay alerting, intelligent exception management' },
  { category: 'Order-to-Cash', freightos: 'Not offered', cargoiq: 'Full billing automation — accruals, invoicing, revenue recognition, reconciliation' },
  { category: 'Solution Breadth', freightos: 'Rate comparison, booking, benchmarking', cargoiq: '21 solutions covering the complete freight operations lifecycle' },
];
---

<Page
  title="Freightos vs FreightMynd — AI Comparison"
  description="Freightos vs FreightMynd — rate marketplace vs custom AI freight operations. Compare pricing intelligence, document processing, and TMS integration."
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Compare' }, { label: 'Freightos vs FreightMynd' }]} bg="breadcrumb-bg-warm" />

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20" style="background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F1 50%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Compare
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          Freightos vs FreightMynd — Marketplace Rate Data vs Custom Cargo Data Intelligence
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Looking for a Freightos alternative for operations automation? Freightos is a freight marketplace and rate platform. FreightMynd builds custom AI operations systems for freight forwarders. They solve different problems but overlap in pricing intelligence. Here's how they compare.
        </p>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-reveal>
        <h2 class="section-heading mb-8">Side-by-Side Comparison</h2>

        <!-- Desktop Table -->
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b-2 border-line">
                <th scope="col" class="py-4 pr-6 text-sm font-semibold text-ink-3 w-1/4">Feature</th>
                <th scope="col" class="py-4 px-6 text-sm font-semibold text-ink-4 w-[37.5%]">Freightos</th>
                <th scope="col" class="py-4 px-6 text-sm font-semibold text-brand w-[37.5%]">FreightMynd</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row, i) => (
                <tr class={`border-b border-line/50 ${i % 2 === 1 ? 'bg-surface/50' : ''}`}>
                  <th scope="row" class="py-4 pr-6 text-sm font-semibold text-ink text-left">{row.category}</th>
                  <td class="py-4 px-6 text-sm text-ink-3">{row.freightos}</td>
                  <td class="py-4 px-6 text-sm text-ink font-medium bg-brand-light/30">{row.cargoiq}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile Cards -->
        <div class="md:hidden space-y-4">
          {comparisonRows.map((row, i) => (
            <div class="p-5 rounded-xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <p class="text-sm font-bold text-ink mb-3">{row.category}</p>
              <div class="space-y-2">
                <div>
                  <span class="text-[10px] font-mono text-ink-4 uppercase tracking-wider">Freightos</span>
                  <p class="text-sm text-ink-3">{row.freightos}</p>
                </div>
                <div class="p-2.5 rounded-lg bg-brand-light/40">
                  <span class="text-[10px] font-mono text-brand uppercase tracking-wider">FreightMynd</span>
                  <p class="text-sm text-ink font-medium">{row.cargoiq}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- When Freightos / When FreightMynd -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Freightos -->
        <div class="p-8 rounded-2xl border border-line/70 bg-white" data-reveal>
          <h3 class="text-xl font-bold text-ink mb-4">When Freightos Makes Sense</h3>
          <ul class="space-y-3">
            {[
              'You need access to a broad freight rate marketplace',
              'Your primary challenge is finding and comparing carrier rates',
              'You want a booking platform with built-in rate management',
              'Your operations are rate-driven rather than document-driven',
              'You prefer a marketplace model over custom-built systems',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink-3 leading-relaxed">
                <span class="text-ink-4 mt-0.5 flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- FreightMynd -->
        <div class="p-8 rounded-2xl border border-brand/20 bg-brand-light/20" data-reveal data-reveal-delay="1">
          <h3 class="text-xl font-bold text-ink mb-4">When FreightMynd Makes Sense</h3>
          <ul class="space-y-3">
            {[
              'Your bottleneck is document processing, not rate discovery',
              'You need deep TMS integration (CargoWise, SAP TM, Oracle)',
              'You want AI that combines market data with your historical pricing',
              'You need end-to-end operations automation beyond just quoting',
              'You want to own your automation infrastructure',
              'Your operation has complex supplier document formats and edge cases',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink leading-relaxed">
                <span class="text-brand mt-0.5 flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Key Distinction -->
      <div class="max-w-3xl mx-auto mt-12 p-6 rounded-2xl border border-brand/20 bg-brand-light/20 text-center" data-reveal>
        <p class="text-sm text-ink leading-relaxed">
          <strong>Key distinction:</strong> Freightos and FreightMynd are not direct competitors. Freightos is a rate marketplace. FreightMynd builds custom AI systems for freight operations. Many freight forwarders could use Freightos for rate data while using FreightMynd for document processing, quoting automation, and TMS integration.
        </p>
      </div>
    </div>
  </section>

  <!-- See Our Work -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow mb-4 justify-center">
          <span class="eyebrow-dot bg-brand"></span>
          See Our Work
        </p>
        <h2 class="text-display-sm font-bold text-ink mb-4" style="padding-left:0; border-left:none;">
          Real Systems. Real Results.
        </h2>
        <p class="text-ink-3 leading-relaxed mb-10">
          Don't just take our word for it. See how we've built custom AI systems for freight forwarders like Hellmann Worldwide Logistics.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-4xl mx-auto">
        <a href="/case-studies/hellmann-4pl-control-tower"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="1">
          <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Hellmann Case Study</h3>
          <p class="text-xs text-ink-3 leading-relaxed">60% processing time reduction for 4PL control tower ops.</p>
        </a>
        <a href="/solutions/4pl-control-tower-automation"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="2">
          <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">4PL Control Tower</h3>
          <p class="text-xs text-ink-3 leading-relaxed">Full document intelligence pipeline — email to TMS push.</p>
        </a>
        <a href="/solutions/document-intelligence"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="3">
          <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Document Intelligence</h3>
          <p class="text-xs text-ink-3 leading-relaxed">AI reads and extracts data from 300-page batches.</p>
        </a>
        <a href="/integrations"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="4">
          <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Integrations</h3>
          <p class="text-xs text-ink-3 leading-relaxed">CargoWise, SAP TM, Oracle TMS, and more.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10" data-reveal>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <div class="grid gap-4">
          {faqItems.map((item, i) => (
            <details class="group rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
                {item.q}
                <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        See What AI-Driven Cargo Data Intelligence Looks Like
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll show you where AI automation has the highest impact on your specific freight operations.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions" class="btn bg-brand border border-brand text-white hover:bg-white hover:border-white hover:text-ink">
          Explore Solutions
        </a>
      </div>
    </div>
  </section>
</Page>
