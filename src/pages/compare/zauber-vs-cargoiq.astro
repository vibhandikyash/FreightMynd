---
import Page from '../../layouts/Page.astro';
import { site } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Compare" },
    { "@type": "ListItem", "position": 3, "name": "Zauber vs CargoIQ" },
  ],
};

const comparisonRows = [
  { category: 'Deployment', zauber: 'SaaS — vendor-hosted platform', cargoiq: 'Custom-built in your environment' },
  { category: 'Ownership', zauber: 'Subscription — ongoing license fees', cargoiq: 'You own it — project fee + operational fee' },
  { category: 'TMS Integration', zauber: 'Pre-built connectors for supported TMS', cargoiq: 'Native integration with your specific TMS instance' },
  { category: 'Customization', zauber: 'Configure within product limits', cargoiq: 'Built for your edge cases from day one' },
  { category: 'Document Formats', zauber: 'Supported formats only', cargoiq: 'Any format — AI learns your suppliers automatically' },
  { category: 'Pricing', zauber: 'Per-seat subscription', cargoiq: 'Project fee + operational fee — no per-seat cost' },
  { category: 'Data Control', zauber: 'Vendor-hosted — data on their servers', cargoiq: 'Your environment — your data stays with you' },
];
---

<Page
  title="Zauber vs CargoIQ — Custom AI vs SaaS Freight Automation | CargoIQ.ai"
  description="Compare Zauber and CargoIQ for freight automation. See how custom-built AI systems compare to SaaS freight automation on deployment, ownership, TMS integration, and customization."
  schema={breadcrumbSchema}
>
  <!-- Breadcrumb -->
  <div class="pt-20 bg-surface">
    <div class="container pt-4 pb-0">
      <nav aria-label="Breadcrumb" class="text-xs text-ink-4 font-mono">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <span class="mx-1.5">/</span>
        <span class="text-ink-4">Compare</span>
        <span class="mx-1.5">/</span>
        <span class="text-ink-3">Zauber vs CargoIQ</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Compare
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          Zauber vs CargoIQ — How Custom AI Compares to SaaS Freight Automation
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Zauber offers a SaaS freight automation product. CargoIQ builds custom AI systems deployed in your environment. Both aim to reduce manual freight operations — but the approach, ownership model, and depth of customization are fundamentally different.
        </p>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-reveal>
        <h2 class="section-heading mb-8">Side-by-Side Comparison</h2>

        <!-- Desktop Table -->
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b-2 border-line">
                <th scope="col" class="py-4 pr-6 text-sm font-semibold text-ink-3 w-1/4">Feature</th>
                <th scope="col" class="py-4 px-6 text-sm font-semibold text-ink-4 w-[37.5%]">Zauber</th>
                <th scope="col" class="py-4 px-6 text-sm font-semibold text-brand w-[37.5%]">CargoIQ</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row, i) => (
                <tr class={`border-b border-line/50 ${i % 2 === 1 ? 'bg-surface/50' : ''}`}>
                  <th scope="row" class="py-4 pr-6 text-sm font-semibold text-ink text-left">{row.category}</th>
                  <td class="py-4 px-6 text-sm text-ink-3">{row.zauber}</td>
                  <td class="py-4 px-6 text-sm text-ink font-medium bg-brand-light/30">{row.cargoiq}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile Cards -->
        <div class="md:hidden space-y-4">
          {comparisonRows.map((row, i) => (
            <div class="p-5 rounded-xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <p class="text-sm font-bold text-ink mb-3">{row.category}</p>
              <div class="space-y-2">
                <div>
                  <span class="text-[10px] font-mono text-ink-4 uppercase tracking-wider">Zauber</span>
                  <p class="text-sm text-ink-3">{row.zauber}</p>
                </div>
                <div class="p-2.5 rounded-lg bg-brand-light/40">
                  <span class="text-[10px] font-mono text-brand uppercase tracking-wider">CargoIQ</span>
                  <p class="text-sm text-ink font-medium">{row.cargoiq}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- When Zauber / When CargoIQ -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Zauber -->
        <div class="p-8 rounded-2xl border border-line/70 bg-white" data-reveal>
          <h3 class="text-xl font-bold text-ink mb-4">When Zauber Makes Sense</h3>
          <ul class="space-y-3">
            {[
              'Small to mid-size operations wanting quick deployment',
              'Standard workflows that fit within a product\'s configuration options',
              'Teams that prefer a managed SaaS experience over custom development',
              'Operations with limited TMS customization requirements',
              'Budgets that favour predictable monthly subscription costs',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink-3 leading-relaxed">
                <span class="text-ink-4 mt-0.5 flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- CargoIQ -->
        <div class="p-8 rounded-2xl border border-brand/20 bg-brand-light/20" data-reveal data-reveal-delay="1">
          <h3 class="text-xl font-bold text-ink mb-4">When CargoIQ Makes Sense</h3>
          <ul class="space-y-3">
            {[
              'Complex, high-volume operations needing deep TMS integration',
              'Custom document formats from diverse supplier networks',
              'Operations that need systems built for their specific edge cases',
              'Companies that want to own their automation infrastructure',
              'Multi-system environments (CargoWise + SAP + custom portals)',
              'Organisations where data sovereignty and control matter',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink leading-relaxed">
                <span class="text-brand mt-0.5 flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- See Our Work -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow mb-4 justify-center">
          <span class="eyebrow-dot bg-brand"></span>
          See Our Work
        </p>
        <h2 class="text-display-sm font-bold text-ink mb-4" style="padding-left:0; border-left:none;">
          Real Systems. Real Results.
        </h2>
        <p class="text-ink-3 leading-relaxed mb-10">
          Don't just take our word for it. See how we've built custom AI systems for freight forwarders like Hellmann Worldwide Logistics.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-4xl mx-auto">
        <a href="/case-studies/hellmann-4pl-control-tower"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="1">
          <span class="text-2xl mb-3 block" aria-hidden="true">📊</span>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Hellmann Case Study</h3>
          <p class="text-xs text-ink-3 leading-relaxed">60% processing time reduction for 4PL control tower ops.</p>
        </a>
        <a href="/solutions/4pl-control-tower-automation"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="2">
          <span class="text-2xl mb-3 block" aria-hidden="true">🏗️</span>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">4PL Control Tower</h3>
          <p class="text-xs text-ink-3 leading-relaxed">Full document intelligence pipeline — email to TMS push.</p>
        </a>
        <a href="/solutions/document-intelligence"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="3">
          <span class="text-2xl mb-3 block" aria-hidden="true">📄</span>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Document Intelligence</h3>
          <p class="text-xs text-ink-3 leading-relaxed">AI reads and extracts data from 300-page batches.</p>
        </a>
        <a href="/integrations"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="4">
          <span class="text-2xl mb-3 block" aria-hidden="true">🔗</span>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Integrations</h3>
          <p class="text-xs text-ink-3 leading-relaxed">CargoWise, SAP TM, Oracle TMS, and more.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Want to See What Custom AI Looks Like for Your Operations?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your workflows and show you what we'd build — with a timeline and expected results.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/case-studies/hellmann-4pl-control-tower" class="btn border border-white/30 text-white hover:bg-white/10">
          Read the Hellmann Case Study
        </a>
      </div>
    </div>
  </section>
</Page>
