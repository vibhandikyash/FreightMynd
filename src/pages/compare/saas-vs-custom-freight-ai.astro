---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Compare" },
    { "@type": "ListItem", "position": 3, "name": "SaaS vs Custom AI for Freight Forwarding" },
  ],
};

const faqItems = [
  {
    q: 'Is SaaS or custom AI better for freight forwarding?',
    a: 'It depends on your operational complexity. SaaS platforms work well for freight forwarders with standard workflows, common document formats, and limited TMS customization needs. Custom AI is better for complex, high-volume operations with diverse supplier formats, deep TMS integration requirements (CargoWise XML push, SAP TM BAPIs), and edge cases that are a competitive advantage rather than a nuisance.',
  },
  {
    q: 'How long does custom freight AI take to deploy?',
    a: 'Typically 4-8 weeks from kickoff to production. This includes a discovery and audit phase, system build and testing in your environment, and deployment with full handoff and documentation. SaaS platforms can be live in days to weeks, but with less depth of integration and customization.',
  },
  {
    q: 'Is custom AI more expensive than SaaS?',
    a: 'The upfront cost of custom AI is higher than a SaaS subscription. However, custom AI has no recurring per-seat fees, no price hikes when you scale, and no vendor lock-in. Over a 2-3 year horizon, custom AI often costs less than a SaaS subscription — and you own the system outright.',
  },
  {
    q: 'Can I migrate from SaaS to custom AI later?',
    a: 'Yes. FreightMynd builds custom AI systems from scratch for your specific environment — your TMS, your suppliers, your workflows. If you\'ve outgrown a SaaS platform or hit its configuration limits, we can build a purpose-built replacement that handles your edge cases and integrates natively with your existing systems.',
  },
  {
    q: 'What TMS integrations does custom AI support?',
    a: 'FreightMynd builds native integrations with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes — not generic connectors, but per-instance integrations tailored to your specific TMS configuration. This means direct XML push, BAPI calls, and API integration rather than flat-file imports or middleware workarounds.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const comparisonRows = [
  { category: 'Deployment', saas: 'Vendor-hosted cloud platform', custom: 'Deployed in your environment' },
  { category: 'Time to Deploy', saas: 'Days to weeks', custom: '4-8 weeks' },
  { category: 'Cost Structure', saas: 'Monthly/annual subscription per seat', custom: 'One-time project fee, no recurring' },
  { category: 'Integration Depth', saas: 'Pre-built connectors, limited customization', custom: 'Native per-TMS instance integration' },
  { category: 'Customization', saas: 'Configure within platform limits', custom: 'Built for your specific workflows' },
  { category: 'Data Ownership', saas: 'Vendor-hosted, vendor-controlled', custom: 'You own everything' },
  { category: 'Vendor Lock-in', saas: 'Switching costs increase over time', custom: 'No lock-in, system is yours' },
  { category: 'Edge Cases', saas: 'Workarounds or feature requests', custom: 'Built in from day one' },
];
---

<Page
  title="SaaS vs Custom AI for Freight Forwarding"
  description="Should your freight operation use SaaS AI or build a custom system? Compare deployment, cost, integration depth, and long-term ROI."
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Compare' }, { label: 'SaaS vs Custom AI for Freight Forwarding' }]} bg="breadcrumb-bg-warm" />

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20" style="background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F1 50%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Compare
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          SaaS AI vs Custom-Built AI: Which Model Wins for Freight Operations?
        </h1>
        <p class="mt-5 hero-description text-ink-3">
          Two fundamentally different approaches to freight automation. SaaS platforms offer speed and breadth. Custom-built systems offer depth and ownership. Here's how to decide.
        </p>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-reveal>
        <h2 class="section-heading mb-8">Side-by-Side Comparison</h2>

        <!-- Desktop Table -->
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b-2 border-line">
                <th scope="col" class="py-4 pr-6 text-sm font-semibold text-ink-3 w-1/4">Dimension</th>
                <th scope="col" class="py-4 px-6 text-sm font-semibold text-ink-4 w-[37.5%]">SaaS AI (Raft, Zauber, Expedock)</th>
                <th scope="col" class="py-4 px-6 text-sm font-semibold text-brand w-[37.5%]">Custom-Built AI (FreightMynd)</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row, i) => (
                <tr class={`border-b border-line/50 ${i % 2 === 1 ? 'bg-surface/50' : ''}`}>
                  <th scope="row" class="py-4 pr-6 text-sm font-semibold text-ink text-left">{row.category}</th>
                  <td class="py-4 px-6 text-sm text-ink-3">{row.saas}</td>
                  <td class="py-4 px-6 text-sm text-ink font-medium bg-brand-light/30">{row.custom}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile Cards -->
        <div class="md:hidden space-y-4">
          {comparisonRows.map((row, i) => (
            <div class="p-5 rounded-xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <p class="text-sm font-bold text-ink mb-3">{row.category}</p>
              <div class="space-y-2">
                <div>
                  <span class="text-[10px] font-mono text-ink-4 uppercase tracking-wider">SaaS AI</span>
                  <p class="text-sm text-ink-3">{row.saas}</p>
                </div>
                <div class="p-2.5 rounded-lg bg-brand-light/40">
                  <span class="text-[10px] font-mono text-brand uppercase tracking-wider">FreightMynd</span>
                  <p class="text-sm text-ink font-medium">{row.custom}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- When SaaS / When Custom -->
  <section class="section bg-surface">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- SaaS -->
        <div class="p-8 rounded-2xl border border-line/70 bg-white" data-reveal>
          <h3 class="text-xl font-bold text-ink mb-4">When SaaS Makes Sense</h3>
          <ul class="space-y-3">
            {[
              'You need to be live in days, not weeks',
              'Your workflows are standard and don\'t require deep customization',
              'You prefer vendor-managed infrastructure and updates',
              'You\'re comfortable with recurring subscription costs',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink-3 leading-relaxed">
                <span class="text-ink-4 mt-0.5 flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Custom -->
        <div class="p-8 rounded-2xl border border-brand/20 bg-brand-light/20" data-reveal data-reveal-delay="1">
          <h3 class="text-xl font-bold text-ink mb-4">When Custom Makes Sense</h3>
          <ul class="space-y-3">
            {[
              'You have diverse supplier formats that don\'t fit templates',
              'You need deep TMS integration (CargoWise XML push, SAP TM BAPIs)',
              'You want to own your system and data with no vendor lock-in',
              'Your edge cases are a competitive advantage, not a nuisance',
              'the global freight forwarder chose custom because their 4PL control tower needed per-supplier document intelligence that no SaaS platform could handle',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink leading-relaxed">
                <span class="text-brand mt-0.5 flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Key Distinction -->
      <div class="max-w-3xl mx-auto mt-12 p-6 rounded-2xl border border-brand/20 bg-brand-light/20 text-center" data-reveal>
        <p class="text-sm text-ink leading-relaxed">
          <strong>Key distinction:</strong> This isn't about which approach is "better" — it's about which one fits your operational reality. If your documents, suppliers, and TMS workflows are unique, a custom system will outperform any SaaS platform. If they're standard, SaaS gets you there faster.
        </p>
      </div>
    </div>
  </section>

  <!-- See Our Work -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow mb-4 justify-center">
          <span class="eyebrow-dot bg-brand"></span>
          See Our Work
        </p>
        <h2 class="text-display-sm font-bold text-ink mb-4" style="padding-left:0; border-left:none;">
          Real Systems. Real Results.
        </h2>
        <p class="text-ink-3 leading-relaxed mb-10">
          Don't just take our word for it. See how we've built custom AI systems for freight forwarders like a global freight forwarder.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-3xl mx-auto">
        <a href="/case-studies/4pl-control-tower-automation/"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="1">
          <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Global Freight Forwarder Case Study</h3>
          <p class="text-xs text-ink-3 leading-relaxed">60% processing time reduction for 4PL control tower ops.</p>
        </a>
        <a href="/solutions/4pl-control-tower-automation/"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="2">
          <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">4PL Control Tower</h3>
          <p class="text-xs text-ink-3 leading-relaxed">Full document intelligence pipeline — email to TMS push.</p>
        </a>
        <a href="/solutions/document-intelligence/"
           class="group p-6 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay="3">
          <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-ink mb-1 group-hover:text-brand transition-colors">Document Intelligence</h3>
          <p class="text-xs text-ink-3 leading-relaxed">AI reads and extracts data from 300-page batches.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10" data-reveal>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <div class="grid gap-4">
          {faqItems.map((item, i) => (
            <details class="group rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
                {item.q}
                <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Not Sure Which Approach Fits Your Operation?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your workflows and tell you honestly whether SaaS or custom AI is the right fit — with a timeline and expected results.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
          <a href="/contact/" class="btn btn-cta-single">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/case-studies/4pl-control-tower-automation/" class="btn bg-brand border border-brand text-white hover:bg-white hover:border-white hover:text-ink">
          Read the Global Freight Forwarder Case Study
        </a>
      </div>
    </div>
  </section>
</Page>
