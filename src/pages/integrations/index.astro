---
import Page from '../../layouts/Page.astro';
import { site } from '../../data/site';
import { integrations } from '../../data/integrations';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Integrations" },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "TMS & Freight System AI Integrations",
  "numberOfItems": integrations.length,
  "itemListElement": integrations.map((intg, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": intg.shortTitle,
    "url": `${site.url}/integrations/${intg.slug}`
  }))
};
---

<Page
  title="TMS & Freight System AI Integrations | CargoIQ.ai"
  description="Direct AI integrations with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes. No middleware — our systems connect to the TMS you already run."
  schema={[breadcrumbSchema, itemListSchema]}
>
  <!-- Hero -->
  <section class="pt-28 pb-16 md:pt-36 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Integrations
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          Connects to the Systems You Already Run
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          CargoIQ integrates directly with your TMS — no middleware, no CSV exports, no manual data entry.
          We build on top of the freight systems your team already uses every day.
        </p>
        <p class="mt-4 text-base text-ink-3 leading-relaxed">
          CargoIQ integrates directly with the TMS your operations team already runs — no middleware layer, no CSV exports, no manual data re-entry. We build native connections using each system's official APIs and data formats: CargoWise eHub and Universal Gateway, SAP BAPIs and RFC calls, Oracle REST APIs, Microsoft Dynamics Dataverse, and Descartes GLN. Every integration is built and tested in your specific environment. Don't see your TMS? We build custom integrations for any freight management system with an API.
        </p>
      </div>
    </div>
  </section>

  <!-- Integrations grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {integrations.map((intg, i) => (
          <a href={`/integrations/${intg.slug}`}
             class="group p-7 rounded-2xl border border-line/70 bg-surface/30 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <h2 class="text-xl font-bold text-ink mb-2 group-hover:text-brand transition-colors">{intg.shortTitle}</h2>
            <p class="text-sm text-ink-3 leading-relaxed mb-5 flex-grow">{intg.description}</p>

            <!-- Capabilities preview -->
            <div class="pt-5 border-t border-line/50 mb-5">
              <ul class="space-y-2">
                {intg.capabilities.slice(0, 3).map(cap => (
                  <li class="flex items-start gap-2 text-sm text-ink-3">
                    <svg class="w-4 h-4 mt-0.5 text-health flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{cap.title}</span>
                  </li>
                ))}
              </ul>
            </div>

            <span class="text-sm font-semibold text-brand group-hover:text-brand-dark transition-colors inline-flex items-center gap-1.5">
              Learn more
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Don't See Your TMS?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        We build custom integrations for any freight management system. Book a free audit and we'll scope the connection.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
