---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';
import { integrations } from '../../data/integrations';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Integrations" },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "TMS & Freight System AI Integrations",
  "numberOfItems": integrations.length,
  "itemListElement": integrations.map((intg, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": intg.shortTitle,
    "url": `${site.url}/integrations/${intg.slug}`
  }))
};

const faqItems = [
  {
    q: 'Which TMS systems do you integrate with?',
    a: 'We build native AI integrations with CargoWise (via eHub and Universal Gateway), SAP TM (classic and S/4HANA embedded), Oracle TMS (cloud and on-premise), Microsoft Dynamics 365, and Descartes. Each integration is built and tested against your specific TMS instance — not a generic connector.',
  },
  {
    q: 'How long does AI integration take?',
    a: 'Most TMS integrations go live within 8–14 weeks. The timeline depends on the complexity of your TMS environment, the number of data flows, and whether we are integrating with a cloud or on-premise instance. We handle discovery, build, UAT, and production deployment end to end.',
  },
  {
    q: 'Do I need middleware for TMS integration?',
    a: 'No. FreightMynd connects directly to your TMS using native APIs and data formats — CargoWise XML via eHub, SAP BAPIs, Oracle REST APIs, and so on. There is no middleware layer, no iPaaS subscription, and no CSV export step. This reduces latency, failure points, and ongoing maintenance.',
  },
  {
    q: 'Can you integrate with custom or legacy TMS?',
    a: 'Yes. If your TMS has an API, a database connection, or even a file-based interface, we can build an integration. We have connected with proprietary in-house systems, older on-premise installations, and niche regional platforms. Book a free audit and we will scope the connection.',
  },
  {
    q: 'What data can the AI push into my TMS?',
    a: 'The AI can push structured shipment data including consignment details, commercial invoice line items, AWB fields, packing list quantities, customs declarations, carrier rate data, and booking confirmations. Every field is validated against your business rules before it enters the TMS — so your ops team only sees clean, verified records.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};
---

<Page
  title="TMS AI Integration for Freight Systems | FreightMynd"
  description="Direct AI integration with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes. No middleware — native connection to your TMS."
  schema={[breadcrumbSchema, itemListSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Integrations' }]} bg="breadcrumb-bg-warm" />

  <!-- Hero -->
  <section class="pt-28 pb-16 md:pt-36 md:pb-20" style="background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F1 50%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Integrations
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          AI Integration for Freight Systems You Already Run
        </h1>
        <p class="mt-5 hero-description text-ink-3">
          FreightMynd provides direct AI integration with your TMS — no middleware, no CSV exports, no manual data entry.
          We build on top of the freight management system your team already uses every day.
        </p>
        <p class="mt-4 hero-description text-ink-3">
          FreightMynd integrates directly with the TMS your operations team already runs — no middleware layer, no CSV exports, no manual data re-entry. We build native connections using each system's official APIs and data formats: CargoWise eHub and Universal Gateway, SAP BAPIs and RFC calls, Oracle REST APIs, Microsoft Dynamics Dataverse, and Descartes GLN. Every integration is built and tested in your specific environment. Don't see your TMS? We build custom integrations for any freight management system with an API.
        </p>
      </div>
    </div>
  </section>

  <!-- Integrations grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {integrations.map((intg, i) => (
          <a href={`/integrations/${intg.slug}`}
             class="group p-7 rounded-2xl border border-line/70 bg-surface/30 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <h2 class="text-xl font-bold text-ink mb-2 group-hover:text-brand transition-colors">{intg.shortTitle}</h2>
            <p class="text-sm text-ink-3 leading-relaxed mb-5 flex-grow">{intg.description}</p>

            <!-- Capabilities preview -->
            <div class="pt-5 border-t border-line/50 mb-5">
              <ul class="space-y-2">
                {intg.capabilities.slice(0, 3).map(cap => (
                  <li class="flex items-start gap-2 text-sm text-ink-3">
                    <svg class="w-4 h-4 mt-0.5 text-health flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{cap.title}</span>
                  </li>
                ))}
              </ul>
            </div>

            <span class="text-sm font-semibold text-brand group-hover:text-brand-dark transition-colors inline-flex items-center gap-1.5">
              Learn more
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          FAQ
        </p>
        <h2 class="section-heading">TMS AI Integration — Frequently Asked Questions</h2>
      </div>
      <div class="max-w-3xl grid gap-4">
        {faqItems.map((item, i) => (
          <details class="group rounded-2xl border border-line/70 bg-surface/50 hover:bg-white transition-colors" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
              {item.q}
              <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div>
              <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Don't See Your TMS?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        We build custom integrations for any freight management system. Book a free audit and we'll scope the connection.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-cta-single">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
