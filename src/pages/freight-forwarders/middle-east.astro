---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Freight Forwarders", "item": `${site.url}/freight-forwarders` },
    { "@type": "ListItem", "position": 3, "name": "Middle East" },
  ],
};

const faqItems = [
  {
    q: 'Does FreightMynd support Arabic-language freight documents?',
    a: 'Yes. Our document intelligence engine processes Arabic, English, and bilingual documents — the standard across Middle Eastern trade operations. The AI extraction layer identifies language automatically and maps fields correctly regardless of script direction, handling both RTL Arabic and LTR English within the same document.',
  },
  {
    q: 'Can FreightMynd automate free zone documentation in the UAE?',
    a: 'Yes. We build automation for JAFZA, DAFZA, SAIF Zone, and other UAE free zone documentation workflows — including certificates of origin, re-export declarations, and free zone customs entries. The system handles the specific document formats and regulatory requirements of each free zone.',
  },
  {
    q: 'Does FreightMynd integrate with TMS platforms used in the Middle East?',
    a: 'Yes. We build native integrations with CargoWise, SAP TM, Oracle TMS, and Microsoft Dynamics — the TMS platforms most widely deployed by Middle Eastern freight forwarders and logistics providers. Data flows directly via API with no middleware or manual re-entry.',
  },
  {
    q: 'How does FreightMynd handle multi-modal freight operations common in the Gulf?',
    a: 'Our automation covers sea freight (dominant for Gulf port operations), air freight (critical for Dubai and Doha hubs), and road freight across GCC corridors. The system processes documents for all modes and handles the transshipment documentation common in hub-and-spoke Gulf logistics.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};

const capabilities = [
  {
    icon: 'port',
    title: 'High-Volume Port Operations',
    description: 'Process thousands of documents daily across Jebel Ali, Khalifa Port, Hamad Port, and King Abdullah Port. Built for the throughput that Gulf hub operations demand.',
    href: '/solutions/document-intelligence',
  },
  {
    icon: 'globe',
    title: 'Arabic & Bilingual Document Processing',
    description: 'AI extraction that handles Arabic, English, and bilingual freight documents — invoices, customs declarations, certificates of origin, and bills of lading. No per-language setup.',
    href: '/solutions/document-intelligence',
  },
  {
    icon: 'shield',
    title: 'Free Zone & Customs Automation',
    description: 'Automated processing for UAE free zone documentation, GCC customs declarations, and re-export paperwork across JAFZA, DAFZA, SAIF Zone, and Saudi free zones.',
    href: '/solutions/4pl-control-tower-automation',
  },
  {
    icon: 'integration',
    title: 'CargoWise & SAP TM Integration',
    description: 'Native integration with the TMS platforms dominant in Middle Eastern freight — CargoWise, SAP TM, Oracle TMS, and Microsoft Dynamics. Direct API push, no middleware.',
    href: '/integrations',
  },
];

const challenges = [
  'Massive transshipment volumes through Dubai, Abu Dhabi, and Doha hubs — manual processing can\'t keep pace',
  'Bilingual Arabic-English documentation across invoices, customs forms, and certificates of origin',
  'Complex free zone regulations varying by emirate and zone — JAFZA, DAFZA, SAIF, and Saudi free zones each with unique requirements',
  'Multi-modal operations spanning sea freight (Gulf ports), air freight (Dubai/Doha hubs), and road freight across GCC corridors',
];
---

<Page
  title="AI for Freight Forwarders in the Middle East | FreightMynd"
  description="AI automation for Middle Eastern freight forwarders — Arabic document processing, free zone automation, and TMS integration for Gulf logistics."
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Freight Forwarders', href: '/freight-forwarders' }, { label: 'Middle East' }]} bg="breadcrumb-bg-warm" />

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pb-20" style="background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F1 50%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow justify-center mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Middle East
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          AI Automation for Middle Eastern Freight Forwarders
        </h1>
        <p class="mt-5 hero-description text-ink-3">
          Custom AI systems built for the scale and complexity of Gulf freight operations — high-volume port processing, Arabic-English document intelligence, free zone automation, and multi-modal operations across the UAE, Saudi Arabia, Qatar, and the wider GCC.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/solutions" class="btn btn-ghost">Explore All Solutions</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Middle East Freight Challenges -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-red-500"></span>
            Middle East Freight Challenges
          </p>
          <h2 class="section-heading">Gulf Hub Volumes Demand Purpose-Built Automation</h2>
          <p class="mt-5 text-ink-3 leading-relaxed">
            The Middle East is a global transshipment hub — Jebel Ali alone handles over 14 million TEUs annually, and Dubai's air cargo hub moves more international freight than any other airport. The combination of massive volumes, bilingual documentation, free zone complexity, and multi-modal operations creates operational demands that generic AI tools can't meet.
          </p>
        </div>
        <div class="space-y-3" data-reveal data-reveal-delay="1">
          {challenges.map((point) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-line/50 bg-surface/50">
              <span class="text-red-400 mt-0.5 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
                </svg>
              </span>
              <p class="text-sm text-ink-3 leading-relaxed">{point}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How FreightMynd Helps Middle Eastern Forwarders -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Solutions
        </p>
        <h2 class="section-heading">How FreightMynd Helps Middle Eastern Forwarders</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {capabilities.map((card, i) => (
          <a href={card.href}
             class="group p-7 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 4))}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                {card.icon === 'port' && <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />}
                {card.icon === 'globe' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />}
                {card.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />}
                {card.icon === 'integration' && <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />}
              </svg>
            </div>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{card.title}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{card.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Trade Corridors -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow justify-center mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Trade Corridors
        </p>
        <h2 class="text-display-sm font-bold text-ink" style="padding-left:0; border-left:none;">
          Built for Gulf and Middle Eastern Trade Lanes
        </h2>
        <p class="mt-4 text-ink-3 leading-relaxed max-w-xl mx-auto">
          Our AI systems handle the document formats, regulatory requirements, and operational workflows specific to the Middle East's busiest trade corridors and logistics hubs.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          {['UAE', 'Saudi Arabia', 'Qatar', 'Bahrain', 'Oman', 'Kuwait'].map((region) => (
            <span class="px-5 py-2.5 rounded-xl border border-line/70 bg-surface/50 text-sm font-medium text-ink-3">
              {region}
            </span>
          ))}
        </div>
      </div>
      <div class="grid sm:grid-cols-3 gap-6 mt-12">
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="1">
          <h3 class="text-base font-bold text-ink mb-2">Sea Freight — Gulf Ports</h3>
          <p class="text-sm text-ink-3 leading-relaxed">Jebel Ali, Khalifa Port, Hamad Port, King Abdullah Port — automated booking, BL processing, and container tracking for the world's busiest transshipment hubs.</p>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="2">
          <h3 class="text-base font-bold text-ink mb-2">Air Freight — Dubai & Doha Hubs</h3>
          <p class="text-sm text-ink-3 leading-relaxed">DXB, DWC, and DOH are among the world's top air cargo airports. Automated AWB processing, flight tracking, and customs documentation for high-volume air operations.</p>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="3">
          <h3 class="text-base font-bold text-ink mb-2">GCC Road Freight</h3>
          <p class="text-sm text-ink-3 leading-relaxed">Cross-border road freight between UAE, Saudi Arabia, Qatar, Bahrain, and Oman — with automated customs documentation and GCC single-entry transit processing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10" data-reveal>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <div class="space-y-4">
          {faqItems.map((faq, i) => (
            <details class="group p-5 rounded-xl border border-line/70 bg-white" data-reveal data-reveal-delay={String(i + 1)}>
              <summary class="flex items-center justify-between cursor-pointer text-ink font-semibold text-sm leading-relaxed list-none">
                {faq.q}
                <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-sm text-ink-3 leading-relaxed">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Automate Your Middle East Freight Operations?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your workflows, assess your free zone and customs requirements, and deliver a custom automation proposal within 48 hours.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-cta-single">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions" class="btn btn-white">
          Explore Solutions
        </a>
      </div>
      <p class="mt-8 text-sm text-white/60 font-mono" data-reveal data-reveal-delay="3">
        No commitment · 30-minute call · Custom proposal within 48 hours
      </p>
    </div>
  </section>
</Page>
