---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Freight Forwarders", "item": `${site.url}/freight-forwarders/` },
    { "@type": "ListItem", "position": 3, "name": "Canada" },
  ],
};

const faqItems = [
  {
    q: 'Does FreightMynd work with Canadian freight forwarders?',
    a: 'Yes, we serve forwarders operating out of Vancouver, Toronto, and Montreal with AI automation for document processing, quoting, and TMS integration.',
  },
  {
    q: 'Do you support Canada-US cross-border freight automation?',
    a: 'Yes, our systems automate cross-border documentation, customs pre-population for CBSA filing, and carrier rate management across Canadian and US trade lanes.',
  },
  {
    q: 'How does AI help with CBSA customs compliance?',
    a: 'Our customs automation extracts data from commercial invoices and certificates of origin to pre-populate CBSA customs declarations, reducing filing time and compliance errors for Canadian importers and exporters.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};

const useCases = [
  {
    icon: 'document',
    title: 'Document Processing',
    description: 'AI-powered extraction from invoices, AWBs, packing lists, and customs forms — handling US, Canadian, and Mexican document formats automatically.',
    href: '/solutions/document-intelligence/',
  },
  {
    icon: 'quote',
    title: 'Quote Automation',
    description: 'Autonomous RFQ processing and rate comparison across carriers, ports, and trade lanes throughout North America.',
    href: '/solutions/autonomous-quote-management/',
  },
  {
    icon: 'integration',
    title: 'TMS Integration',
    description: 'Native CargoWise integration — the dominant TMS across North American freight forwarders. Also supports SAP TM, Oracle TMS, and Microsoft Dynamics.',
    href: '/integrations/cargowise/',
  },
  {
    icon: 'invoice',
    title: 'Invoice Matching',
    description: 'Automated invoice capture, three-way matching against POs and shipment records, validation, and TMS posting with exception routing.',
    href: '/solutions/smart-invoice-processing/',
  },
];
---

<Page
  title="AI Freight Automation for Canada | FreightMynd"
  description="AI automation for freight forwarders in Canada — document processing, CargoWise integration, and quote automation for Canadian cross-border and international operations."
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Freight Forwarders', href: '/freight-forwarders/' }, { label: 'Canada' }]} />

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Canada
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          AI Freight Forwarding Automation for Canadian Freight Operators
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Custom-built AI systems for freight forwarders across Canada. From Vancouver's Pacific gateway to Toronto's central hub and Montreal's Atlantic trade routes, we build AI automation that replaces manual freight operations — document processing, quote management, and TMS integration — for forwarders running Canadian and Canada-US cross-border trade lanes.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/solutions/" class="btn btn-ghost">Explore All Solutions</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Canadian Forwarders Choose FreightMynd -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-health"></span>
          Why Canadian Forwarders Choose Us
        </p>
        <h2 class="section-heading">Built for Canadian Freight. Proven at Enterprise Scale.</h2>
        <p class="mt-5 text-ink-3 leading-relaxed">
          Canadian freight forwarders operate at the intersection of Pacific, Atlantic, and cross-border trade — handling complex documentation across CBSA customs requirements, CUSMA/USMCA compliance, and multi-modal shipments through some of North America's busiest ports. We build AI automation tailored to these realities, proven at enterprise scale for Hellmann Worldwide Logistics.
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6 mt-12">
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="1">
          <h3 class="text-base font-bold text-ink mb-2">Canada-US Cross-Border Expertise</h3>
          <p class="text-sm text-ink-3 leading-relaxed">Automated CUSMA/USMCA compliance documentation, Canada-US trade lane optimization, and cross-border documentation automation — reducing manual effort on the highest-volume North American corridor.</p>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="2">
          <h3 class="text-base font-bold text-ink mb-2">CBSA Customs Compliance</h3>
          <p class="text-sm text-ink-3 leading-relaxed">AI-powered extraction and pre-population of Canada Border Services Agency customs declarations, trade compliance documents, and certificates of origin — reducing filing errors and clearance delays.</p>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="3">
          <h3 class="text-base font-bold text-ink mb-2">Coast-to-Coast Coverage</h3>
          <p class="text-sm text-ink-3 leading-relaxed">Supporting forwarders at Vancouver (Pacific gateway to Asia), Toronto (Canada's central logistics hub), and Montreal (Atlantic and European trade) — with systems built for Canadian freight workflows.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Common Automation Use Cases -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Use Cases
        </p>
        <h2 class="section-heading">Common Automation Use Cases for Canadian Forwarders</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {useCases.map((card, i) => (
          <a href={card.href}
             class="group p-7 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 4))}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                {card.icon === 'document' && <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />}
                {card.icon === 'quote' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />}
                {card.icon === 'integration' && <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />}
                {card.icon === 'invoice' && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />}
              </svg>
            </div>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{card.title}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{card.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Serving Canadian Forwarders -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow justify-center mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Serving Canadian Forwarders
        </p>
        <h2 class="text-display-sm font-bold text-ink" style="padding-left:0; border-left:none;">
          Vancouver · Toronto · Montreal — and Every Trade Lane Between
        </h2>
        <p class="mt-4 text-ink-3 leading-relaxed max-w-xl mx-auto">
          We serve freight forwarders across Canada's major logistics hubs — from Pacific imports through Vancouver, central distribution via Toronto, and Atlantic/European trade through Montreal. Our systems also support Canada-US cross-border freight operations, the largest bilateral trade corridor in the world.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          {['Vancouver', 'Toronto', 'Montreal', 'Canada-US Cross-Border'].map((region) => (
            <span class="px-5 py-2.5 rounded-xl border border-line/70 bg-surface/50 text-sm font-medium text-ink-3">
              {region}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10" data-reveal>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <div class="space-y-4">
          {faqItems.map((faq, i) => (
            <details class="group p-5 rounded-xl border border-line/70 bg-white" data-reveal data-reveal-delay={String(i + 1)}>
              <summary class="flex items-center justify-between cursor-pointer text-ink font-semibold text-sm leading-relaxed list-none">
                {faq.q}
                <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-sm text-ink-3 leading-relaxed">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Automate Your Canadian Freight Operations?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit with our team. We'll map your workflows, identify the highest-impact automation, and deliver a custom proposal within 48 hours.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact/" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions/" class="btn border border-white/30 text-white hover:bg-white/10">
          Explore Solutions
        </a>
      </div>
      <p class="mt-8 text-sm text-white/60 font-mono" data-reveal data-reveal-delay="3">
        No commitment · 30-minute call · Custom proposal within 48 hours
      </p>
    </div>
  </section>
</Page>
