---
import Page from '../../layouts/Page.astro';
import { site } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Freight Forwarders", "item": `${site.url}/freight-forwarders` },
    { "@type": "ListItem", "position": 3, "name": "Europe" },
  ],
};

const faqItems = [
  {
    q: 'How does CargoIQ handle multi-language documents from European suppliers?',
    a: 'Our document intelligence engine processes documents in all major European languages — English, German, French, Dutch, Spanish, Italian, and more. The AI extraction layer identifies language automatically and maps fields correctly regardless of language or format, handling the document diversity that European trade lanes produce.',
  },
  {
    q: 'Is CargoIQ compliant with GDPR for European freight operations?',
    a: 'Yes. Our systems can be deployed in your own cloud environment within EU data centres, ensuring full GDPR compliance. All document data stays within your infrastructure — no data is sent to third-party servers outside your control. We build with privacy-by-design principles from day one.',
  },
  {
    q: 'Does CargoIQ integrate with European TMS platforms like SAP TM and Descartes?',
    a: 'Yes. We build native integrations with SAP TM, Descartes, CargoWise, Oracle TMS, and Microsoft Dynamics — the TMS platforms most widely used by European freight forwarders. Data flows directly via API with no middleware or manual re-entry.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};

const capabilities = [
  {
    icon: '🌍',
    title: 'Multi-Language Document Processing',
    description: 'AI extraction that handles invoices, AWBs, and customs documents in German, French, Dutch, Spanish, Italian, and 20+ other languages — no per-language configuration required.',
    href: '/solutions/document-intelligence',
  },
  {
    icon: '📜',
    title: 'Customs Compliance Automation',
    description: 'Automated processing of EU and non-EU customs declarations, T1/T2 transit documents, EUR.1 certificates, and country-specific regulatory forms across European trade corridors.',
    href: '/solutions/4pl-control-tower-automation',
  },
  {
    icon: '🔗',
    title: 'Descartes & SAP TM Integration',
    description: 'Native integration with the TMS platforms dominant in European freight — SAP TM, Descartes, CargoWise, and Microsoft Dynamics. Direct API push, no middleware.',
    href: '/integrations',
  },
  {
    icon: '🔒',
    title: 'GDPR-Compliant Deployment',
    description: 'Systems deployed in your own EU cloud infrastructure. No data leaves your environment. Privacy-by-design architecture that satisfies GDPR and national data protection requirements.',
    href: '/contact',
  },
];

const challenges = [
  'Customs complexity across EU and non-EU borders — different forms, different rules, different languages',
  'Multi-language supplier documents requiring manual translation and field mapping',
  'Regulatory compliance varying by country — GDPR, AEO, ICS2, and national customs requirements',
  'Fragmented TMS landscape with SAP TM, Descartes, and CargoWise all widely deployed',
];
---

<Page
  title="AI for Freight Forwarders in Europe | CargoIQ.ai"
  description="AI automation for European freight forwarders — customs compliance, document intelligence, and TMS integration. Trusted by Hellmann Worldwide Logistics."
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <div class="pt-24 md:pt-28 bg-surface">
    <div class="container">
      <nav class="flex items-center gap-2 text-xs font-mono text-ink-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/freight-forwarders" class="hover:text-brand transition-colors">Freight Forwarders</a>
        <span aria-hidden="true">/</span>
        <span class="text-ink-3">Europe</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Europe
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          AI Automation for European Freight Forwarders
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Custom AI systems built for the complexity of European freight — multi-language documents, cross-border customs, and fragmented regulatory landscapes. Trusted by Hellmann Worldwide Logistics, headquartered in Osnabruck, Germany, with operations across every European corridor.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/case-studies/hellmann-4pl-control-tower" class="btn btn-ghost">Hellmann Case Study</a>
        </div>
      </div>
    </div>
  </section>

  <!-- European Freight Challenges -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-red-500"></span>
            European Freight Challenges
          </p>
          <h2 class="section-heading">Complexity That Generic AI Tools Can't Handle</h2>
          <p class="mt-5 text-ink-3 leading-relaxed">
            European freight forwarders face unique operational challenges that off-the-shelf AI tools weren't designed for. Cross-border customs between EU and non-EU states, multi-language supplier documentation, and country-specific regulatory requirements create layers of manual work that demand purpose-built automation.
          </p>
        </div>
        <div class="space-y-3" data-reveal data-reveal-delay="1">
          {challenges.map((point) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-line/50 bg-surface/50">
              <span class="text-red-400 mt-0.5 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
                </svg>
              </span>
              <p class="text-sm text-ink-3 leading-relaxed">{point}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How CargoIQ Helps European Forwarders -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Solutions
        </p>
        <h2 class="section-heading">How CargoIQ Helps European Forwarders</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {capabilities.map((card, i) => (
          <a href={card.href}
             class="group p-7 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 4))}>
            <span class="text-2xl mb-4" aria-hidden="true">{card.icon}</span>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{card.title}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{card.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Trusted by Hellmann -->
  <section class="relative py-24 md:py-32 overflow-hidden" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
    <div class="absolute top-[-20%] left-[20%] w-[600px] h-[600px] rounded-full bg-brand/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow justify-center mb-4 text-white/50">
          <span class="eyebrow-dot bg-health"></span>
          Trusted by a European Leader
        </p>
        <h2 class="text-display-md font-bold text-white" style="padding-left:0; border-left:none;">
          Live at Hellmann Worldwide Logistics
        </h2>
        <p class="mt-5 text-white/60 leading-relaxed">
          Hellmann — headquartered in Germany with operations across every European market — relies on our 4PL control tower automation to process complex document batches at scale. The same engineering that powers their operations is available to European freight forwarders of every size.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-12">
        {[
          { value: '60%', label: 'Processing time reduction' },
          { value: '50%', label: 'AI cost reduction' },
          { value: '300pg', label: 'Batch processing, near-zero failure' },
          { value: '0', label: 'Manual TMS data entry' },
        ].map((stat, i) => (
          <div class="p-6 rounded-2xl border border-white/10 bg-white/[0.04] text-center"
               data-reveal data-reveal-delay={String(i + 1)}>
            <p class="text-3xl font-bold text-white">{stat.value}</p>
            <p class="text-sm text-white/50 mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10" data-reveal data-reveal-delay="3">
        <a href="/case-studies/hellmann-4pl-control-tower" class="btn btn-white">
          Read the Full Case Study
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10" data-reveal>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <div class="space-y-4">
          {faqItems.map((faq, i) => (
            <details class="group p-5 rounded-xl border border-line/70 bg-white" data-reveal data-reveal-delay={String(i + 1)}>
              <summary class="flex items-center justify-between cursor-pointer text-ink font-semibold text-sm leading-relaxed list-none">
                {faq.q}
                <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-sm text-ink-3 leading-relaxed">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Automate Your European Freight Operations?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your workflows, assess your customs and compliance requirements, and deliver a custom automation proposal within 48 hours.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions" class="btn border border-white/30 text-white hover:bg-white/10">
          Explore Solutions
        </a>
      </div>
      <p class="mt-8 text-sm text-white/60 font-mono" data-reveal data-reveal-delay="3">
        No commitment · 30-minute call · Custom proposal within 48 hours
      </p>
    </div>
  </section>
</Page>
