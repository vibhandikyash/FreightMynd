---
import Page from '../../layouts/Page.astro';
import { site } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Freight Forwarders", "item": `${site.url}/freight-forwarders` },
    { "@type": "ListItem", "position": 3, "name": "Asia-Pacific" },
  ],
};

const faqItems = [
  {
    q: 'How does CargoIQ handle the high document volumes typical in APAC freight operations?',
    a: 'Our document intelligence engine is built for high-volume batch processing — handling 200-300 page document batches at near-zero failure rate. For APAC forwarders managing thousands of shipments across diverse trade lanes, the system scales horizontally and processes documents in parallel without degrading accuracy.',
  },
  {
    q: 'Can CargoIQ process documents in Asian languages and non-Latin scripts?',
    a: 'Yes. Our AI extraction pipeline handles documents in Chinese, Japanese, Korean, Thai, Vietnamese, Bahasa, Hindi, and other Asian languages. The system identifies language and script automatically and maps fields correctly — no per-language configuration or separate modules required.',
  },
  {
    q: 'Does CargoIQ have a presence in the Asia-Pacific region?',
    a: 'Yes. Our engineering hub is in Gujarat, India, providing APAC timezone coverage for development and support. Combined with our US office in Clifton, NJ, we deliver continuous development cycles that align with APAC business hours for project management and deployment support.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};

const capabilities = [
  {
    icon: '📦',
    title: 'High-Volume Batch Processing',
    description: 'Process thousands of documents daily across busy APAC trade corridors. Our pipeline handles 200-300 page batches at near-zero failure — built for the volume that APAC freight operations demand.',
    href: '/solutions/document-intelligence',
  },
  {
    icon: '🔄',
    title: 'Multi-Format Supplier Onboarding',
    description: 'Self-learning AI that maps new supplier document formats automatically. Critical for APAC operations where supplier diversity spans dozens of countries, languages, and document standards.',
    href: '/solutions/4pl-control-tower-automation',
  },
  {
    icon: '🚢',
    title: 'Sea Freight Automation',
    description: 'Automate booking confirmations, sailing schedules, container tracking, and ocean freight documentation across major APAC corridors — China-US, Intra-Asia, and Asia-Europe.',
    href: '/solutions/sea-freight-automation',
  },
  {
    icon: '🔗',
    title: 'CargoWise Integration',
    description: 'Native CargoWise integration — the dominant TMS across APAC freight forwarders in Australia, Singapore, Hong Kong, and the broader region. Direct XML push, zero manual entry.',
    href: '/integrations/cargowise',
  },
];

const challenges = [
  'Extremely high shipment and document volumes across dense APAC trade lanes',
  'Diverse document formats across dozens of countries — China, Japan, Korea, Southeast Asia, India, and Oceania',
  'Multiple languages and non-Latin scripts requiring specialized OCR and extraction',
  'Complex multi-leg trade lanes with transshipment hubs in Singapore, Hong Kong, and Shanghai',
];
---

<Page
  title="AI for Freight Forwarders in Asia-Pacific | CargoIQ.ai"
  description="AI automation for APAC freight forwarders — high-volume document processing, carrier integration, and multi-format supplier onboarding. India engineering hub."
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <div class="pt-24 md:pt-28 bg-surface">
    <div class="container">
      <nav class="flex items-center gap-2 text-xs font-mono text-ink-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/freight-forwarders" class="hover:text-brand transition-colors">Freight Forwarders</a>
        <span aria-hidden="true">/</span>
        <span class="text-ink-3">Asia-Pacific</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Asia-Pacific
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          AI Automation for Asia-Pacific Freight Forwarders
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Purpose-built AI systems for APAC freight forwarders managing high-volume trade lanes, diverse supplier formats, and multi-language documentation. Our engineering hub in Gujarat, India provides APAC timezone coverage — building the same automation trusted by Hellmann Worldwide Logistics.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/solutions" class="btn btn-ghost">Explore All Solutions</a>
        </div>
      </div>
    </div>
  </section>

  <!-- APAC Freight Challenges -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-red-500"></span>
            APAC Freight Challenges
          </p>
          <h2 class="section-heading">Volume and Complexity at a Scale That Breaks Manual Processes</h2>
          <p class="mt-5 text-ink-3 leading-relaxed">
            Asia-Pacific freight forwarders operate on some of the world's busiest trade lanes. The combination of extreme document volumes, diverse supplier formats across dozens of countries, and multiple languages and scripts creates operational bottlenecks that no amount of manual effort can solve.
          </p>
        </div>
        <div class="space-y-3" data-reveal data-reveal-delay="1">
          {challenges.map((point) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-line/50 bg-surface/50">
              <span class="text-red-400 mt-0.5 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
                </svg>
              </span>
              <p class="text-sm text-ink-3 leading-relaxed">{point}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How CargoIQ Helps APAC Forwarders -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Solutions
        </p>
        <h2 class="section-heading">How CargoIQ Helps APAC Forwarders</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {capabilities.map((card, i) => (
          <a href={card.href}
             class="group p-7 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 4))}>
            <span class="text-2xl mb-4" aria-hidden="true">{card.icon}</span>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{card.title}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{card.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Engineering Hub in India -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow justify-center mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          APAC Presence
        </p>
        <h2 class="text-display-sm font-bold text-ink" style="padding-left:0; border-left:none;">
          Engineering Hub in Gujarat, India
        </h2>
        <p class="mt-4 text-ink-3 leading-relaxed max-w-xl mx-auto">
          Our Gujarat engineering hub provides APAC timezone coverage for development, deployment, and support. Combined with our US office in Clifton, NJ, we deliver continuous development cycles that keep pace with the demands of APAC freight operations.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          {['Australia', 'Singapore', 'Hong Kong', 'India', 'China', 'Japan', 'Southeast Asia'].map((region) => (
            <span class="px-5 py-2.5 rounded-xl border border-line/70 bg-surface/50 text-sm font-medium text-ink-3">
              {region}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10" data-reveal>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <div class="space-y-4">
          {faqItems.map((faq, i) => (
            <details class="group p-5 rounded-xl border border-line/70 bg-white" data-reveal data-reveal-delay={String(i + 1)}>
              <summary class="flex items-center justify-between cursor-pointer text-ink font-semibold text-sm leading-relaxed list-none">
                {faq.q}
                <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-sm text-ink-3 leading-relaxed">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Automate Your APAC Freight Operations?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll assess your document volumes, trade lanes, and TMS setup — then deliver a custom automation proposal within 48 hours.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions" class="btn border border-white/30 text-white hover:bg-white/10">
          Explore Solutions
        </a>
      </div>
      <p class="mt-8 text-sm text-white/60 font-mono" data-reveal data-reveal-delay="3">
        No commitment · 30-minute call · Custom proposal within 48 hours
      </p>
    </div>
  </section>
</Page>
