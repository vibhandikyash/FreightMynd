---
import Page from '../../layouts/Page.astro';
import { site } from '../../data/site';
import { solutions } from '../../data/solutions';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Solutions" },
  ],
};
---

<Page
  title="AI Solutions for Freight Forwarding & Logistics | CargoIQ.ai"
  description="Custom-built AI systems for freight forwarders — 4PL control tower automation, document intelligence, autonomous quoting, freight pricing AI, and more. Every system built for your stack."
  schema={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="pt-28 pb-16 md:pt-36 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Solutions
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          Every AI System Your Freight Operations Need
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Each module is custom-built for your environment — your TMS, your suppliers, your workflows.
          Deploy one or connect them all into a unified operations intelligence layer.
        </p>
        <p class="mt-6 text-base text-ink-3 leading-relaxed">
          CargoIQ builds custom AI systems for freight forwarding and logistics operations — each one purpose-built for your TMS, your suppliers, and your workflows. Every module below is production-deployed, not a proof of concept. Start with the highest-impact automation for your operation and connect additional modules as your operations mature. Each system integrates directly with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes. No middleware, no CSV exports, no manual data re-entry. Trusted by Hellmann Worldwide Logistics. Built and deployed in 8–14 weeks.
        </p>
      </div>
    </div>
  </section>

  <!-- Solutions grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {solutions.map((sol, i) => (
          <a href={`/solutions/${sol.slug}`}
             class="group p-7 rounded-2xl border border-line/70 bg-surface/30 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <span class="text-2xl mb-4" aria-hidden="true">{sol.icon}</span>
            <h2 class="text-xl font-bold text-ink mb-2 group-hover:text-brand transition-colors">{sol.title}</h2>
            <p class="text-sm text-ink-3 leading-relaxed mb-5 flex-grow">{sol.description}</p>

            <!-- Results preview -->
            <div class="grid grid-cols-2 gap-3 mb-5 pt-5 border-t border-line/50">
              {sol.results.slice(0, 2).map(r => (
                <div>
                  <p class="text-lg font-bold text-brand">{r.value}</p>
                  <p class="text-[11px] text-ink-4">{r.label}</p>
                </div>
              ))}
            </div>

            <!-- Stack pills -->
            <div class="flex flex-wrap gap-1.5">
              {sol.stack.slice(0, 4).map(tech => (
                <span class="tag tag-brand">{tech}</span>
              ))}
              {sol.stack.length > 4 && (
                <span class="tag tag-brand">+{sol.stack.length - 4}</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Not Sure Which Solution Fits?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your workflows and recommend the highest-impact starting point.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
