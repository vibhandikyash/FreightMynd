---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';
import { caseStudies } from '../../data/case-studies';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Case Studies" },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AI Case Studies for Freight Forwarding",
  "numberOfItems": caseStudies.length,
  "itemListElement": caseStudies.map((study, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": study.title,
    "url": `${site.url}/case-studies/${study.slug}`
  }))
};
---

<Page
  title="AI Case Studies for Freight Forwarding & Logistics | CargoIQ.ai"
  description="Real AI case studies for freight forwarders — 4PL control towers, RFQ automation, document processing. See measurable ROI from production deployments."
  schema={[breadcrumbSchema, itemListSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Case Studies' }]} />

  <!-- Hero -->
  <section class="pt-28 pb-16 md:pt-36 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Case Studies
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          Real Systems. Real Results.
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Every system we build is deployed, measured, and proven in live freight operations.
          These are not concepts — they are AI systems running in production today.
        </p>
      </div>
    </div>
  </section>

  <!-- Case Studies Grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid sm:grid-cols-2 gap-6">
        {caseStudies.map((study, i) => (
          <a href={`/case-studies/${study.slug}`}
             class="group p-7 rounded-2xl border border-line/70 bg-surface/30 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <span class="text-xs text-ink-4 font-mono mb-2">{study.client}</span>
            <h2 class="text-xl font-bold text-ink mb-2 group-hover:text-brand transition-colors">{study.title}</h2>
            <p class="text-sm text-ink-3 leading-relaxed mb-5 flex-grow">{study.description}</p>

            <!-- Hero Metric -->
            <div class="pt-5 border-t border-line/50">
              <div class="inline-flex items-baseline gap-2">
                <span class="text-lg font-bold text-brand">{study.heroMetric.value}</span>
                <span class="text-xs text-ink-4">{study.heroMetric.label}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Want Results Like These?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your operations and show you what's possible.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
