---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import SolutionIcon from '../../components/ui/SolutionIcon.astro';
import { site } from '../../data/site';
import { glossaryTerms } from '../../data/glossary';
import { solutions } from '../../data/solutions';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return glossaryTerms.map((term) => ({
    params: { slug: term.slug },
    props: { term },
  }));
};

const { term } = Astro.props as { term: import('../../data/glossary').GlossaryTerm };

const relatedSolutionData = solutions.filter((s) =>
  term.relatedSolutions.includes(s.slug)
);

const relatedTermData = glossaryTerms.filter((t) =>
  term.relatedTerms.includes(t.slug)
);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Glossary", "item": `${site.url}/glossary/` },
    { "@type": "ListItem", "position": 3, "name": term.term },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is ${term.term}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": term.definition,
      },
    },
  ],
};

const definedTermSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": term.term,
  "description": term.definition,
  "url": `${site.url}/glossary/${term.slug}`,
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": "Freight Forwarding & Logistics Glossary",
    "url": `${site.url}/glossary/`,
  },
};
---

<Page
  title={`${term.term} — Freight Glossary | FreightMynd`}
  description={term.definition}
  schema={[breadcrumbSchema, faqSchema, definedTermSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Glossary', href: '/glossary/' }, { label: term.term }]} bg="breadcrumb-bg-glossary" />

  <!-- Term content -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20" style="background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F1 50%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Glossary
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          {term.term}
        </h1>

        <!-- Short definition -->
        <div class="mt-6 p-5 rounded-xl bg-brand-light border border-brand-mid">
          <p class="text-base text-ink-2 leading-relaxed font-medium">
            {term.definition}
          </p>
        </div>

        <!-- Long description -->
        <div class="mt-10 prose prose-lg max-w-none text-ink-3 leading-relaxed">
          {term.longDescription.split('\n\n').map((paragraph) => (
            <p class="mb-6 text-base leading-relaxed text-ink-3" set:html={paragraph.trim()} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Related Solutions -->
  {relatedSolutionData.length > 0 && (
    <section class="section-sm bg-surface border-t border-line">
      <div class="container">
        <h2 class="text-display-sm font-bold text-ink mb-8" style="padding-left:0; border-left:none;">
          Related Solutions
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedSolutionData.map((sol) => (
            <a href={`/solutions/${sol.slug}/`}
               class="group p-6 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col">
              <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
                <SolutionIcon slug={sol.slug} fallbackEmoji={sol.icon} class="w-5 h-5 text-brand" />
              </div>
              <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">
                {sol.title}
              </h3>
              <p class="text-sm text-ink-3 leading-relaxed flex-grow">
                {sol.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Terms -->
  {relatedTermData.length > 0 && (
    <section class="section-sm bg-white border-t border-line">
      <div class="container">
        <h2 class="text-display-sm font-bold text-ink mb-8" style="padding-left:0; border-left:none;">
          Related Terms
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {relatedTermData.map((related) => (
            <a href={`/glossary/${related.slug}/`}
               class="group flex items-start gap-3 p-4 rounded-xl border border-line/70 bg-surface/30 hover:bg-white hover:shadow-card hover:-translate-y-0.5 transition-all duration-200">
              <div>
                <h3 class="text-base font-semibold text-ink group-hover:text-brand transition-colors">
                  {related.term}
                </h3>
                <p class="text-sm text-ink-4 mt-1 line-clamp-2">
                  {related.definition}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Want to Automate This?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll show you how AI can transform your freight operations.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact/" class="btn btn-cta-single">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
