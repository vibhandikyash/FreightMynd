---
import Page from '../../layouts/Page.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';
import { glossaryTerms } from '../../data/glossary';

const sortedTerms = [...glossaryTerms].sort((a, b) =>
  a.term.localeCompare(b.term)
);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Glossary" },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Freight Forwarding & Logistics Glossary",
  "numberOfItems": glossaryTerms.length,
  "itemListElement": sortedTerms.map((term, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": term.term,
    "url": `${site.url}/glossary/${term.slug}`
  }))
};
---

<Page
  title="Freight Forwarding & Logistics Glossary | FreightMynd"
  description="Key freight forwarding and logistics terms explained — from airway bills to TMS platforms. Learn how AI automation applies to each."
  schema={[breadcrumbSchema, itemListSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Glossary' }]} bg="breadcrumb-bg-glossary" />

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20" style="background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F1 50%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Glossary
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          Freight Forwarding &amp; Logistics Glossary
        </h1>
        <p class="mt-5 hero-description text-ink-3">
          Key freight forwarding and logistics terms explained — from airway bills to TMS platforms. Each entry covers what the term means, why it matters for freight forwarders, and how AI automation applies.
        </p>
      </div>
    </div>
  </section>

  <!-- Terms grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedTerms.map((term, i) => (
          <a href={`/glossary/${term.slug}/`}
             class="group p-7 rounded-2xl border border-line/70 bg-surface/30 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <h2 class="text-xl font-bold text-ink mb-3 group-hover:text-brand transition-colors">
              {term.term}
            </h2>
            <p class="text-sm text-ink-3 leading-relaxed mb-5 flex-grow">
              {term.definition}
            </p>
            <div class="flex flex-wrap gap-1.5 pt-4 border-t border-line/50">
              {term.relatedSolutions.slice(0, 3).map(sol => (
                <span class="tag tag-brand">{sol}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Automate Your Freight Operations?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your workflows and recommend the highest-impact starting point.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact/" class="btn btn-cta-single">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
