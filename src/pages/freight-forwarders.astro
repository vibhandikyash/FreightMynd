---
import Page from '../layouts/Page.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { site } from '../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Freight Forwarders" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What AI automation systems are available for freight forwarders?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "FreightMynd builds custom AI systems for freight forwarders including 4PL control tower automation, autonomous quote management, document intelligence, sea and air freight automation, freight pricing AI, and smart invoice processing. Each system is purpose-built for your TMS and workflows."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to implement AI automation for freight forwarding?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Typical implementation takes 4–8 weeks from kickoff to production. We start with a discovery and audit phase, design the architecture, build in iterative sprints with your ops team, and deploy with full documentation and support."
      }
    },
    {
      "@type": "Question",
      "name": "Does FreightMynd integrate with CargoWise and other TMS platforms?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We build native integrations with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes. The systems push data directly into your TMS via API — no middleware, no CSV exports, no manual re-entry."
      }
    },
    {
      "@type": "Question",
      "name": "How is FreightMynd different from SaaS freight automation tools?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Unlike SaaS tools, FreightMynd builds custom systems deployed in your environment. You own the system — no subscription, no vendor lock-in. We build for your specific TMS, suppliers, document formats, and edge cases rather than offering a one-size-fits-all product."
      }
    },
    {
      "@type": "Question",
      "name": "What results can freight forwarders expect from AI automation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our Hellmann Worldwide Logistics deployment achieved 60% processing time reduction, 50% AI cost reduction via intelligent pre-filtering, near-zero failure on 300-page document batches, and zero manual TMS data entry. Results vary by operation but typically include significant time savings and error reduction."
      }
    },
  ],
};

const solutionCards = [
  {
    icon: '4pl-control-tower',
    title: '4PL Control Tower Automation',
    description: 'Full document intelligence pipeline — email monitoring to CargoWise XML with zero manual entry.',
    href: '/solutions/4pl-control-tower-automation/',
    metric: '60% time reduction',
  },
  {
    icon: 'quote-management',
    title: 'Autonomous Quote Management',
    description: 'AI-powered RFQ processing, rate comparison, and quote generation across sea and air freight.',
    href: '/solutions/autonomous-quote-management/',
    metric: 'Minutes, not hours',
  },
  {
    icon: 'document-intelligence',
    title: 'Document Intelligence',
    description: 'Extract structured data from invoices, AWBs, packing lists, and compliance documents at scale.',
    href: '/solutions/document-intelligence/',
    metric: 'Near-zero failure rate',
  },
  {
    icon: 'sea-freight',
    title: 'Sea Freight Automation',
    description: 'Automate booking confirmations, sailing schedules, container tracking, and ocean freight documentation.',
    href: '/solutions/sea-freight-automation/',
    metric: 'End-to-end automation',
  },
  {
    icon: 'air-freight',
    title: 'Air Freight Automation',
    description: 'AWB processing, flight tracking, capacity management, and air freight document handling.',
    href: '/solutions/air-freight-automation/',
    metric: 'Real-time processing',
  },
  {
    icon: 'invoice-processing',
    title: 'Smart Invoice Processing',
    description: 'Automated invoice capture, validation, matching, and TMS posting with exception routing.',
    href: '/solutions/smart-invoice-processing/',
    metric: 'Zero manual entry',
  },
];

const painPoints = [
  'Ops teams manually downloading, splitting, and re-keying documents from supplier emails',
  'Quotes taking hours because rate data lives in spreadsheets and carrier portals',
  'New suppliers requiring engineering effort to map their document formats',
  'Error-prone manual data entry into CargoWise, SAP TM, or other TMS platforms',
  'Growing shipment volumes with no scalable way to handle the operational load',
  'Compliance documents and audit trails assembled manually from scattered sources',
];

const faqItems = [
  {
    q: 'What AI automation systems are available for freight forwarders?',
    a: 'FreightMynd builds custom AI systems for freight forwarders including 4PL control tower automation, autonomous quote management, document intelligence, sea and air freight automation, freight pricing AI, and smart invoice processing. Each system is purpose-built for your TMS and workflows.',
  },
  {
    q: 'How long does it take to implement AI automation for freight forwarding?',
    a: 'Typical implementation takes 4–8 weeks from kickoff to production. We start with a discovery and audit phase, design the architecture, build in iterative sprints with your ops team, and deploy with full documentation and support.',
  },
  {
    q: 'Does FreightMynd integrate with CargoWise and other TMS platforms?',
    a: 'Yes. We build native integrations with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes. The systems push data directly into your TMS via API — no middleware, no CSV exports, no manual re-entry.',
  },
  {
    q: 'How is FreightMynd different from SaaS freight automation tools?',
    a: 'Unlike SaaS tools, FreightMynd builds custom systems deployed in your environment. You own the system — no subscription, no vendor lock-in. We build for your specific TMS, suppliers, document formats, and edge cases rather than offering a one-size-fits-all product.',
  },
  {
    q: 'What results can freight forwarders expect from AI automation?',
    a: 'Our Hellmann Worldwide Logistics deployment achieved 60% processing time reduction, 50% AI cost reduction via intelligent pre-filtering, near-zero failure on 300-page document batches, and zero manual TMS data entry. Results vary by operation but typically include significant time savings and error reduction.',
  },
];

const integrations = ['CargoWise', 'SAP TM', 'Oracle TMS', 'Microsoft Dynamics', 'Descartes'];
---

<Page
  title="AI Systems Built for Freight Forwarders | FreightMynd"
  description="AI-powered freight forwarding service automation — document processing, quoting, booking, and TMS integration with CargoWise, SAP TM. Trusted by Hellmann."
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Freight Forwarders' }]} bg="breadcrumb-bg-warm" />

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20 bg-surface">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow justify-center mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          For Freight Forwarders
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          AI-Powered Freight Forwarding Automation Built for Forwarders
        </h1>
        <p class="mt-5 hero-description text-ink-3">
          Whether you run 50 shipments a week or 5,000 — our freight forwarding automation software eliminates manual operations across document processing, quoting, booking, tracking, and invoicing.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact/" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/solutions/" class="btn btn-ghost">Explore All Solutions</a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-red-500"></span>
            The Problem
          </p>
          <h2 class="section-heading">Manual Processes Don't Scale With Growing Volume</h2>
          <p class="mt-5 text-ink-3 leading-relaxed">
            Freight forwarders are stuck between growing volume demands and manual processes that don't scale. Your ops teams spend hours on tasks that should be automated — downloading documents, re-keying data, chasing rates, and assembling compliance paperwork.
          </p>
        </div>
        <div class="space-y-3" data-reveal data-reveal-delay="1">
          {painPoints.map((point) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-line/50 bg-surface/50">
              <span class="text-red-400 mt-0.5 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
                </svg>
              </span>
              <p class="text-sm text-ink-3 leading-relaxed">{point}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Solutions
        </p>
        <h2 class="section-heading">AI for Logistics Operations — Every Part of Your Freight Workflow</h2>
        <p class="mt-4 text-lg text-ink-3 leading-relaxed">
          Every system is built around your ops environment. Sea freight automation, air freight automation, document intelligence, quoting. Start with the highest-impact module and expand as your freight forwarder automation matures.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {solutionCards.map((card, i) => (
          <a href={card.href}
             class="group p-7 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-4">
              {card.icon === '4pl-control-tower' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
                </svg>
              )}
              {card.icon === 'quote-management' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                </svg>
              )}
              {card.icon === 'document-intelligence' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              )}
              {card.icon === 'sea-freight' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 0a8.961 8.961 0 016.462 2.736l1.54-1.54M12 5.25a8.961 8.961 0 00-6.462 2.736l-1.54-1.54M12 5.25V3m0 18v-2.25m0 0a8.96 8.96 0 01-6.462-2.736l-1.54 1.54M12 18.75a8.96 8.96 0 006.462-2.736l1.54 1.54M12 18.75V21M3.75 12H6m12 0h2.25M5.636 5.636l1.59 1.59m9.548 9.548l1.59 1.59M5.636 18.364l1.59-1.59m9.548-9.548l1.59-1.59" />
                </svg>
              )}
              {card.icon === 'air-freight' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                </svg>
              )}
              {card.icon === 'invoice-processing' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
                </svg>
              )}
            </div>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{card.title}</h3>
            <p class="text-sm text-ink-3 leading-relaxed mb-5 flex-grow">{card.description}</p>
            <div class="pt-4 border-t border-line/50">
              <span class="text-sm font-semibold text-brand">{card.metric}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Hellmann Proof -->
  <section class="relative py-24 md:py-32 overflow-hidden" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
    <div class="absolute top-[-20%] left-[20%] w-[600px] h-[600px] rounded-full bg-brand/10 blur-3xl" aria-hidden="true"></div>

    <div class="container relative z-10">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow justify-center mb-4 text-white/50">
          <span class="eyebrow-dot bg-health"></span>
          Proven in Production
        </p>
        <h2 class="text-display-md font-bold text-white" style="padding-left:0; border-left:none;">
          Live at Hellmann Worldwide Logistics
        </h2>
        <p class="mt-5 text-white/60 leading-relaxed">
          Our flagship deployment: a full 4PL control tower automation system for one of the world's largest freight forwarders — 500+ offices, 13,000+ employees.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-12">
        {[
          { value: '60%', label: 'Processing time reduction' },
          { value: '50%', label: 'AI cost reduction' },
          { value: '300pg', label: 'Batch processing, near-zero failure' },
          { value: '0', label: 'Manual TMS data entry' },
        ].map((stat, i) => (
          <div class="p-6 rounded-2xl border border-white/10 bg-white/[0.04] text-center"
               data-reveal data-reveal-delay={String(i + 1)}>
            <p class="text-3xl font-bold text-brand">{stat.value}</p>
            <p class="text-sm text-white/50 mt-1">{stat.label}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-10" data-reveal data-reveal-delay="3">
        <a href="/case-studies/hellmann-4pl-control-tower/" class="btn btn-white">
          Read the Full Case Study
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Integration Callout -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow justify-center mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Integrations
        </p>
        <h2 class="text-display-sm font-bold text-ink" style="padding-left:0; border-left:none;">
          Works With Your Existing TMS
        </h2>
        <p class="mt-4 text-ink-3 leading-relaxed">
          Every system we build integrates natively with your freight management platform. No middleware. No CSV exports. Direct API integration.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          {integrations.map((name) => (
            <a href={`/integrations/${name.toLowerCase().replace(/\s+/g, '-')}/`}
               class="px-5 py-2.5 rounded-xl border border-line/70 bg-surface/50 text-sm font-medium text-ink-3 hover:text-brand hover:border-brand/30 hover:bg-brand-light transition-all duration-200">
              {name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ROI Example -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12" data-reveal>
          <p class="eyebrow justify-center mb-4">
            <span class="eyebrow-dot bg-health"></span>
            ROI Example
          </p>
          <h2 class="text-display-sm font-bold text-ink" style="padding-left:0; border-left:none;">
            What This Means for Your Bottom Line
          </h2>
        </div>

        <div class="bg-white rounded-2xl border border-line/70 shadow-md overflow-hidden" data-reveal data-reveal-delay="1">
          <!-- Scenario header -->
          <div class="px-7 py-5 border-b border-line/70 bg-surface/50">
            <p class="text-sm font-semibold text-ink">
              Scenario: A mid-size freight forwarder processing 150 documents/day with 3 FTEs on data entry
            </p>
          </div>

          <div class="grid md:grid-cols-2">
            <!-- Before -->
            <div class="p-7 md:border-r border-b md:border-b-0 border-line/70">
              <span class="tag text-red-700 bg-red-50 border border-red-200 mb-4">Before</span>
              <p class="text-sm text-ink-3 leading-relaxed">
                3 FTEs x 4 hours/day on document processing = <strong class="text-ink">60 hours/week</strong> of manual data entry
              </p>
            </div>

            <!-- After -->
            <div class="p-7">
              <span class="tag text-health-dark bg-health-light border border-health-mid mb-4">After</span>
              <p class="text-sm text-ink-3 leading-relaxed">
                AI processes 90%+ automatically. Exception review takes 1 FTE x 1 hour/day. <strong class="text-ink">2 FTEs redeployed</strong> to exception management and client service.
              </p>
            </div>
          </div>

          <!-- Outcome -->
          <div class="px-7 py-5 border-t border-line/70 bg-brand-light/50">
            <div class="flex items-start gap-3">
              <span class="text-brand mt-0.5 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </span>
              <p class="text-sm text-ink leading-relaxed">
                <strong>~55 hours/week reclaimed.</strong> Faster quote turnaround. Fewer data entry errors. Scalable without adding headcount.
              </p>
            </div>
          </div>
        </div>

        <p class="mt-6 text-xs text-ink-4 text-center leading-relaxed" data-reveal data-reveal-delay="2">
          Actual results vary by operation. We include detailed ROI projections in every <a href="/contact/" class="text-brand hover:text-brand-dark transition-colors font-medium">free audit</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- When FreightMynd Isn't the Right Fit -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10" data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-ink-4"></span>
            Honest Assessment
          </p>
          <h2 class="section-heading">When FreightMynd Isn't the Right Fit</h2>
          <p class="mt-4 text-ink-3 leading-relaxed">
            We're not for everyone. Here's when a different approach makes more sense:
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="1">
            <h3 class="text-base font-bold text-ink mb-2">You need a solution this week</h3>
            <p class="text-sm text-ink-3 leading-relaxed">Our minimum engagement is 4 weeks. If you need automation deployed tomorrow, a pre-built SaaS tool may be a better starting point.</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="2">
            <h3 class="text-base font-bold text-ink mb-2">Your document volume is under 20/day</h3>
            <p class="text-sm text-ink-3 leading-relaxed">Custom AI automation has a cost floor. If you're processing fewer than 20 documents daily, the ROI timeline extends beyond 12 months. A lighter-weight tool may serve you better.</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="3">
            <h3 class="text-base font-bold text-ink mb-2">You want a managed service, not a system</h3>
            <p class="text-sm text-ink-3 leading-relaxed">We build and hand over. If you'd prefer someone else to run your ops permanently, a BPO or managed service provider is a better fit.</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="4">
            <h3 class="text-base font-bold text-ink mb-2">Your TMS isn't on our integration list</h3>
            <p class="text-sm text-ink-3 leading-relaxed">We integrate with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes. If you're running a different TMS, we may not be the right partner yet.</p>
          </div>
        </div>
