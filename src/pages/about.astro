---
import Page from '../layouts/Page.astro';
import { site } from '../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "About" },
  ],
};

const differentiators = [
  {
    icon: '🔒',
    title: 'You Own It',
    description: 'No subscription. No vendor lock-in. No price hike when you scale. The system we build is yours — deployed in your environment, maintained on your terms.',
  },
  {
    icon: '🔧',
    title: 'Your Stack',
    description: 'We integrate with your TMS — CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, Descartes — not ours. Your carrier portals. Your data formats.',
  },
  {
    icon: '🎯',
    title: 'Your Edge Cases',
    description: 'Every freight forwarder has lanes, suppliers, and document formats that don\'t fit a template. We build those in from day one — not as an afterthought.',
  },
];

const steps = [
  {
    num: '01',
    title: 'Audit',
    description: 'We map your current workflows, identify automation opportunities, and quantify the time and cost impact. Free, no-commitment.',
    duration: 'Week 1–2',
  },
  {
    num: '02',
    title: 'Design',
    description: 'System architecture — integrations, data flows, validation rules, and exception handling — designed for your specific environment.',
    duration: 'Week 2–4',
  },
  {
    num: '03',
    title: 'Build',
    description: 'Iterative sprints with your ops team reviewing outputs at every stage. No black-box handoff. You see it working before it ships.',
    duration: 'Week 4–10',
  },
  {
    num: '04',
    title: 'Deploy',
    description: 'Production deployment with full documentation, monitoring, and a support period. You own the system — no recurring SaaS fees.',
    duration: 'Week 10–14',
  },
];
---

<Page
  title="About CargoIQ.ai — AI Systems for Freight Forwarding"
  description="CargoIQ.ai is the freight automation division of Bitontree. We build custom AI systems for freight forwarders, 3PLs, and logistics providers. Founded 2019, offices in US and India."
  schema={breadcrumbSchema}
>
  <!-- Breadcrumb -->
  <div class="pt-28 bg-surface">
    <div class="container pt-4 pb-0">
      <nav aria-label="Breadcrumb" class="text-xs text-ink-4 font-mono">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <span class="mx-1.5">/</span>
        <span class="text-ink-3">About</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="pt-8 pb-16 md:pt-12 md:pb-20" style="background: linear-gradient(135deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          About
        </p>
        <h1 class="text-display-lg font-bold text-ink">
          AI Systems for Freight — Built by People Who Understand Operations
        </h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          CargoIQ is powered by <a href={site.builtBy.url} target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark transition-colors font-medium">Bitontree</a> — a specialist AI engineering firm with 6+ years of production AI deployments. We build custom AI systems for freight forwarders, 3PLs, and logistics providers. Not SaaS. Not templates. Purpose-built systems deployed in your environment.
        </p>
      </div>
      <div class="mt-12 max-w-4xl">
        <img
          src="/images/about-hero.webp"
          alt="CargoIQ team building AI systems for freight forwarding operations"
          width="960"
          height="540"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="w-full rounded-2xl border border-line/70 shadow-lg"
        />
      </div>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-brand"></span>
            Who We Are
          </p>
          <h2 class="section-heading">A Team of AI Engineers and Logistics Domain Experts</h2>
          <p class="mt-5 text-ink-3 leading-relaxed">
            Founded in 2019, we operate from offices in the United States (Clifton, NJ) and India (Gujarat). Our team combines deep AI engineering expertise with hands-on knowledge of freight forwarding operations. See what we build on our <a href="/solutions" class="text-brand hover:text-brand-dark font-medium transition-colors">solutions page</a>.
          </p>
          <p class="mt-4 text-ink-3 leading-relaxed">
            We don't sell a product. We build systems that become part of your operations infrastructure — integrated with your TMS, trained on your documents, and deployed in your environment. Our work with <a href="/case-studies/hellmann-4pl-control-tower" class="text-brand hover:text-brand-dark font-medium transition-colors">Hellmann Worldwide Logistics</a> is a flagship example.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4" data-reveal data-reveal-delay="1">
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30">
            <p class="text-3xl font-bold text-brand">2019</p>
            <p class="text-sm text-ink-4 mt-1">Founded</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30">
            <p class="text-3xl font-bold text-brand">6yr</p>
            <p class="text-sm text-ink-4 mt-1">Domain AI depth</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30">
            <p class="text-3xl font-bold text-brand">US</p>
            <p class="text-sm text-ink-4 mt-1">Clifton, NJ</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/30">
            <p class="text-3xl font-bold text-brand">IN</p>
            <p class="text-sm text-ink-4 mt-1">Gujarat, India</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Team -->
  <section class="section bg-surface">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-brand"></span>
            The Team
          </p>
          <h2 class="section-heading">AI Engineers With Freight Operations DNA</h2>
          <p class="mt-5 text-ink-3 leading-relaxed">
            We are not a generic AI consultancy that discovered logistics last year. Our engineers have spent years embedded in freight forwarding operations — understanding TMS systems like CargoWise and SAP TM from the inside, building carrier integrations that handle real-world edge cases, and designing document workflows that survive the chaos of multi-supplier, multi-format, multi-language freight documentation.
          </p>
          <p class="mt-4 text-ink-3 leading-relaxed">
            CargoIQ.ai is built by <a href="https://bitontree.com" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark font-medium transition-colors">Bitontree</a>, a specialist AI engineering firm focused on building production-grade AI systems for complex operational domains. We bring the engineering rigour of a top-tier AI team with the domain knowledge of people who have lived inside freight operations.
          </p>
        </div>
        <div data-reveal data-reveal-delay="1">
          <div class="grid grid-cols-2 gap-4">
            <div class="p-6 rounded-2xl border border-line/70 bg-white">
              <p class="text-3xl font-bold text-brand">6+</p>
              <p class="text-sm text-ink-4 mt-1">Years building AI for freight</p>
            </div>
            <div class="p-6 rounded-2xl border border-line/70 bg-white">
              <p class="text-3xl font-bold text-brand">15+</p>
              <p class="text-sm text-ink-4 mt-1">TMS integrations completed</p>
            </div>
            <div class="p-6 rounded-2xl border border-line/70 bg-white">
              <p class="text-3xl font-bold text-brand">50K+</p>
              <p class="text-sm text-ink-4 mt-1">Documents processed monthly</p>
            </div>
            <div class="p-6 rounded-2xl border border-line/70 bg-white">
              <p class="text-3xl font-bold text-brand">5</p>
              <p class="text-sm text-ink-4 mt-1">Production systems deployed</p>
            </div>
          </div>
          <!-- Built by Bitontree callout -->
          <div class="mt-4 p-5 rounded-2xl border border-brand-mid/40 bg-brand-light/50">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center flex-shrink-0">
                <span class="text-brand font-bold text-sm font-mono">B</span>
              </div>
              <div>
                <p class="text-sm font-semibold text-ink">Powered by Bitontree</p>
                <p class="text-xs text-ink-3 mt-1 leading-relaxed">CargoIQ is powered by <a href="https://bitontree.com" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark transition-colors font-medium">Bitontree</a> — a specialist AI engineering firm with 6+ years of production AI deployments. When you sign with CargoIQ, you contract with Bitontree's dedicated freight automation team.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Who You'll Work With -->
      <div class="mt-16" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Who You'll Work With
        </p>
        <h3 class="text-display-sm font-bold text-ink pl-4 border-l-4 border-brand">Your Dedicated Team</h3>
        <p class="mt-4 text-ink-3 leading-relaxed max-w-2xl">
          Every engagement is staffed with a small, senior team — not a rotating cast of junior consultants. Here's who you'll work with directly:
        </p>
        <div class="grid sm:grid-cols-2 gap-5 mt-8">
          <div class="p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-300" data-reveal data-reveal-delay="1">
            <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h4 class="text-base font-bold text-ink mb-2">Project Lead</h4>
            <p class="text-sm text-ink-3 leading-relaxed">A senior AI engineer who's built freight automation systems before. Your single point of contact from discovery through deployment.</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-300" data-reveal data-reveal-delay="2">
            <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h4 class="text-base font-bold text-ink mb-2">Domain Specialist</h4>
            <p class="text-sm text-ink-3 leading-relaxed">Someone who understands freight ops, TMS workflows, and document formats. Translates your operations into system requirements.</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-300" data-reveal data-reveal-delay="3">
            <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h4 class="text-base font-bold text-ink mb-2">Integration Engineer</h4>
            <p class="text-sm text-ink-3 leading-relaxed">Specializes in TMS APIs — CargoWise eHub, SAP TM connectors, Oracle OTM. Handles the connection between AI and your systems.</p>
          </div>
          <div class="p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-300" data-reveal data-reveal-delay="4">
            <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h4 class="text-base font-bold text-ink mb-2">AI/ML Engineer</h4>
            <p class="text-sm text-ink-3 leading-relaxed">Builds the extraction models, validation logic, and self-learning pipelines. Tunes accuracy to your specific document formats.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="relative py-24 md:py-32 overflow-hidden" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
    <div class="absolute top-[-20%] left-[20%] w-[600px] h-[600px] rounded-full bg-brand/10 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-[-20%] right-[10%] w-[400px] h-[400px] rounded-full bg-brand/5 blur-3xl" aria-hidden="true"></div>

    <div class="container relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
        <p class="eyebrow justify-center mb-4 text-white/50">
          <span class="eyebrow-dot bg-brand"></span>
          What Makes Us Different
        </p>
        <h2 class="text-display-md font-bold text-white" style="padding-left:0; border-left:none;">
          A SaaS Seat Fits Their Workflow.<br class="hidden md:inline" />
          <span class="text-brand-mid">We Build Around Yours.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {differentiators.map((diff, i) => (
          <div class="p-8 rounded-2xl border border-white/10 bg-white/[0.04] backdrop-blur-sm hover:bg-white/[0.08] transition-all duration-300"
               data-reveal data-reveal-delay={String(i + 1)}>
            <span class="text-3xl mb-5 block" aria-hidden="true">{diff.icon}</span>
            <h3 class="text-xl font-bold text-white mb-3">{diff.title}</h3>
            <p class="text-white/60 leading-relaxed">{diff.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="section" style="background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);">
    <div class="container">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Our Approach
        </p>
        <h2 class="section-heading">From Audit to Production in 8–14 Weeks</h2>
        <p class="mt-4 text-lg text-ink-3 leading-relaxed">
          No 6-month enterprise sales cycle. No multi-year contract. A focused engagement that delivers a working system. It starts with a free <a href="/contact" class="text-brand hover:text-brand-dark font-medium transition-colors">audit</a>.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {steps.map((step, i) => (
          <div class="relative p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md hover:-translate-y-1 transition-all duration-300"
               data-reveal data-reveal-delay={String(i + 1)}>
            <span class="font-mono text-4xl font-bold text-brand/10 absolute top-4 right-5">{step.num}</span>
            <span class="tag tag-brand mb-4">{step.duration}</span>
            <h3 class="text-lg font-bold text-ink mb-2">{step.title}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust / Hellmann -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <p class="eyebrow justify-center mb-4">
          <span class="eyebrow-dot bg-health"></span>
          Trusted By
        </p>
        <h2 class="text-display-sm font-bold text-ink" style="padding-left:0; border-left:none;">
          Trusted by Hellmann Worldwide Logistics
        </h2>
        <p class="mt-5 text-ink-3 leading-relaxed">
          Our flagship deployment: a full 4PL control tower automation system processing 200–300 page document batches with near-zero failure rate. 60% processing time reduction. Zero manual TMS data entry.
        </p>
        <div class="mt-8">
          <a href="/case-studies/hellmann-4pl-control-tower" class="btn btn-brand">
            Read the Case Study
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Security & Data Handling -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-health"></span>
          Security & Compliance
        </p>
        <h2 class="section-heading">Enterprise-Grade Data Handling</h2>
      </div>
      <dl class="grid sm:grid-cols-2 gap-5">
        <div class="p-6 rounded-2xl border border-line/70 bg-white" data-reveal data-reveal-delay="1">
          <dt class="text-base font-bold text-ink mb-2">Your Environment</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">Systems deployed in your Azure tenant or dedicated cloud environment. No shared infrastructure, no multi-tenant data mixing.</dd>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-white" data-reveal data-reveal-delay="2">
          <dt class="text-base font-bold text-ink mb-2">Encryption</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">AES-256 encryption at rest. TLS 1.3 for all data in transit. Keys managed in your environment.</dd>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-white" data-reveal data-reveal-delay="3">
          <dt class="text-base font-bold text-ink mb-2">Access Control</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">Role-based access with SSO integration. Every action logged with full audit trail.</dd>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-white" data-reveal data-reveal-delay="4">
          <dt class="text-base font-bold text-ink mb-2">Compliance Ready</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">Architecture designed to meet ISO 27001, SOC 2, and GDPR requirements. We work with your compliance team during implementation.</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- What Happens After Deployment -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-health"></span>
          Post-Deployment
        </p>
        <h2 class="section-heading">What Happens After Deployment</h2>
      </div>
      <dl class="grid sm:grid-cols-2 gap-5">
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="1">
          <dt class="text-base font-bold text-ink mb-2">30-Day Hypercare</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">Every deployment includes a 30-day hypercare period. We monitor system performance, tune extraction accuracy, and resolve any edge cases in real-time alongside your ops team.</dd>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="2">
          <dt class="text-base font-bold text-ink mb-2">Ongoing Monitoring</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">Production dashboards track document volumes, extraction accuracy, validation pass rates, and TMS push success. You see everything — no black boxes.</dd>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="3">
          <dt class="text-base font-bold text-ink mb-2">System Maintenance</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">TMS API updates, new supplier format handling, model retraining, and performance optimization. Available as a monthly retainer or on-demand.</dd>
        </div>
        <div class="p-6 rounded-2xl border border-line/70 bg-surface/30" data-reveal data-reveal-delay="4">
          <dt class="text-base font-bold text-ink mb-2">Your Team Owns It</dt>
          <dd class="text-sm text-ink-3 leading-relaxed">Full documentation, runbooks, and knowledge transfer at deployment. If you want to bring maintenance in-house, you can. The system is yours.</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Let's Talk About Your Operations
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your workflows and show you what we'd build.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions" class="btn border border-white/30 text-white hover:bg-white/10">
          Explore Solutions
        </a>
      </div>
    </div>
  </section>
</Page>
