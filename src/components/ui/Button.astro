---
interface Props {
  href?: string;
  variant?: 'brand' | 'ghost' | 'white';
  size?: 'default' | 'sm';
  class?: string;
  [key: string]: unknown;
}

const { href, variant = 'brand', size = 'default', class: className = '', ...rest } = Astro.props;

const variantClass = {
  brand: 'btn-brand',
  ghost: 'btn-ghost',
  white: 'btn-white',
}[variant];

const sizeClass = size === 'sm' ? 'btn-sm' : '';
const classes = `btn ${variantClass} ${sizeClass} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button class={classes} {...rest}>
    <slot />
  </button>
)}
