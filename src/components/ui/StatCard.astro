---
interface Props {
  value: string;
  label: string;
  suffix?: string;
}

const { value, label, suffix = '' } = Astro.props;
---

<div class="text-center" data-reveal>
  <p class="text-display-sm font-bold text-brand">
    {value}<span class="text-brand/60">{suffix}</span>
  </p>
  <p class="mt-1 text-sm text-ink-3">{label}</p>
</div>
