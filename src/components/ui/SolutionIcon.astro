---
/**
 * Renders an SVG icon for a solution based on its slug.
 * All 21 solutions have dedicated SVG icons — no emoji fallbacks.
 */
interface Props {
  slug: string;
  fallbackEmoji?: string;
  class?: string;
}

const { slug, fallbackEmoji, class: className = 'w-5 h-5' } = Astro.props;

