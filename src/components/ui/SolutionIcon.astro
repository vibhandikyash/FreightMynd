---
/**
 * Renders a modern SVG icon for a solution based on its slug.
 * Falls back to the emoji icon if no SVG mapping exists.
 */
interface Props {
  slug: string;
  fallbackEmoji?: string;
  class?: string;
}

const { slug, fallbackEmoji, class: className = 'w-5 h-5' } = Astro.props;

const iconMap: Record<string, string> = {
  '4pl-control-tower-automation': 'tower',
  'autonomous-quote-management': 'quote',
  'document-intelligence': 'document',
  'freight-pricing-ai': 'pricing',
  'sea-freight-automation': 'ship',
  'air-freight-automation': 'plane',
  '3pl-4pl-operations': 'workflow',
  'smart-invoice-processing': 'invoice',
};

const icon = iconMap[slug];
---

{icon === 'tower' && (
  <svg class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
  </svg>
)}
