---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  bg?: string;
}

const { items, bg = 'breadcrumb-bg-cool' } = Astro.props;
---

<nav class={`pt-24 md:pt-28 pb-0 ${bg}`} aria-label="Breadcrumb">
  <div class="container">
    <ol class="flex items-center gap-1.5 text-[13px]" role="list">
      <li>
        <a href="/" class="inline-flex items-center gap-1 text-ink-4 hover:text-brand transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          <span class="sr-only md:not-sr-only">Home</span>
        </a>
      </li>
      {items.map((item, i) => (
        <>
          <li aria-hidden="true">
            <svg class="w-3.5 h-3.5 text-ink-4/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </li>
          <li>
            {item.href ? (
              <a href={item.href} class="text-ink-4 hover:text-brand transition-colors">
                {item.label}
              </a>
            ) : (
              <span class="text-ink-2 font-medium" aria-current="page">
                {item.label}
              </span>
            )}
          </li>
        </>
      ))}
    </ol>
  </div>
</nav>

<style is:global>
  .breadcrumb-bg-cool {
    background: #F8FAFC;
  }

  .breadcrumb-bg-warm {
    background: #FFFCF8;
  }
</style>
