---
import { site } from '../../data/site';

const solutionLinks = [
  { label: '4PL Control Tower', href: '/solutions/4pl-control-tower-automation' },
  { label: 'Quote Management', href: '/solutions/autonomous-quote-management' },
  { label: 'Document Intelligence', href: '/solutions/document-intelligence' },
  { label: 'Freight Pricing AI', href: '/solutions/freight-pricing-ai' },
  { label: 'Sea Freight Automation', href: '/solutions/sea-freight-automation' },
  { label: 'Air Freight Automation', href: '/solutions/air-freight-automation' },
  { label: '3PL/4PL Operations', href: '/solutions/3pl-4pl-operations' },
  { label: 'Smart Invoice Processing', href: '/solutions/smart-invoice-processing' },
  { label: 'Customs Automation', href: '/solutions/customs-automation' },
  { label: 'Document Automation', href: '/solutions/freight-document-automation' },
  { label: 'TMS Automation', href: '/solutions/tms-automation' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Blog', href: '/blog' },
  { label: 'Freight Forwarders', href: '/freight-forwarders' },
  { label: 'Middle East', href: '/freight-forwarders/middle-east' },
  { label: 'North America', href: '/freight-forwarders/north-america' },
  { label: 'Europe', href: '/freight-forwarders/europe' },
  { label: 'Asia Pacific', href: '/freight-forwarders/asia-pacific' },
  { label: 'Glossary', href: '/glossary' },
  { label: 'Contact', href: '/contact' },
];

const compareLinks = [
  { label: 'Raft vs FreightMynd', href: '/compare/raft-vs-freightmynd' },
  { label: 'Zauber vs FreightMynd', href: '/compare/zauber-vs-cargoiq' },
  { label: 'Freightos vs FreightMynd', href: '/compare/freightos-vs-cargoiq' },
  { label: 'SaaS vs Custom AI', href: '/compare/saas-vs-custom-freight-ai' },
];

const integrationLinks = [
  { label: 'CargoWise', href: '/integrations/cargowise' },
  { label: 'SAP TM', href: '/integrations/sap-tm' },
  { label: 'Oracle TMS', href: '/integrations/oracle-tms' },
  { label: 'Microsoft Dynamics', href: '/integrations/microsoft-dynamics' },
  { label: 'Descartes', href: '/integrations/descartes' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-ink-2 text-white/70 pt-20 pb-8" role="contentinfo">
  <div class="container">
    <!-- Top grid -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10 pb-12 border-b border-white/10">
      <!-- Col 1: Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center mb-4">
          <img src="/FM-logo.svg" alt="FreightMynd" class="h-8 w-auto brightness-0 invert" />
        </a>
        <p class="text-sm leading-relaxed mb-6 max-w-[260px]">
          AI-driven cargo data intelligence for sea, air & freight forwarders.
        </p>
        <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 text-xs text-white/60 hover:text-white transition-colors"
           aria-label="FreightMynd on LinkedIn">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>

      <!-- Col 2: Solutions -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Solutions</h3>
        <ul class="space-y-2.5" role="list">
          {solutionLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Integrations -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Integrations</h3>
        <ul class="space-y-2.5" role="list">
          {integrationLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Compare -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Compare</h3>
        <ul class="space-y-2.5" role="list">
          {compareLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 5: Company -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Company</h3>
        <ul class="space-y-2.5" role="list">
          {companyLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <a href="/contact" class="btn btn-brand btn-sm text-xs">
            Book a Free Audit
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 text-xs text-white/60">
      <p>&copy; {currentYear} {site.name}. All rights reserved.</p>
      <p>
        Built by <a href={site.builtBy.url} target="_blank" rel="noopener noreferrer"
                     class="text-white/70 hover:text-white transition-colors">{site.builtBy.name}</a>
      </p>
    </div>
  </div>
</footer>
