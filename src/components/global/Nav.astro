---
import { solutions } from '../../data/solutions';
import { integrations } from '../../data/integrations';

const solutionItems = solutions.map(s => ({
  title: s.shortTitle,
  description: s.description.slice(0, 80) + (s.description.length > 80 ? '...' : ''),
  href: `/solutions/${s.slug}`,
  icon: s.icon,
}));

const integrationItems = integrations.map(i => ({
  title: i.shortTitle,
  description: i.description.slice(0, 80) + (i.description.length > 80 ? '...' : ''),
  href: `/integrations/${i.slug}`,
  icon: '',
}));

const navLinks = [
  { label: 'Solutions', href: '/solutions', dropdown: solutionItems },
  { label: 'Integrations', href: '/integrations', dropdown: integrationItems },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
];
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 btn btn-brand btn-sm">
  Skip to content
</a>

<!-- ═══ DESKTOP NAV ═══ -->
<nav id="desktop-nav" class="hidden lg:block fixed top-0 inset-x-0 z-50" role="navigation" aria-label="Main navigation">
  <div class="navbar-container">
    <div class="navbar-box" id="navbar-box">
      <div class="navbar-inner">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 font-bold text-lg text-ink flex-shrink-0" aria-label="CargoIQ Home">
          <span class="text-brand font-mono tracking-tight">Cargo<span class="text-ink">IQ</span></span>
          <span class="font-mono text-[10px] text-brand-dark bg-brand-light px-1.5 py-0.5 rounded-md">.ai</span>
        </a>

        <!-- Links -->
        <ul class="flex items-center gap-1" role="list">
          {navLinks.map(link => (
            <li class="relative" data-has-dropdown={link.dropdown ? 'true' : undefined}>
              <a href={link.href}
                 class="nav-link text-[13.5px] font-semibold text-ink-3 px-3 py-2 rounded-lg hover:text-ink transition-colors duration-150 flex items-center gap-1 focus-visible:ring-2 focus-visible:ring-brand/40 focus-visible:outline-none">
                {link.label}
                {link.dropdown && (
                  <svg class="nav-arrow w-3.5 h-3.5 text-ink-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <a href="/contact" class="btn-nav-cta flex-shrink-0">
          Book a Free Audit
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Dropdown: Solutions -->
  <div id="dropdown-solutions" class="nav-dropdown" style="display:none;" data-dropdown="Solutions">
    <div class="nav-dropdown-inner">
      <div class="grid grid-cols-2 gap-x-2 gap-y-1">
        {solutionItems.map(item => (
          <a href={item.href} class="nav-dropdown-item">
            <span class="text-lg flex-shrink-0" aria-hidden="true">{item.icon}</span>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-ink">{item.title}</p>
              <p class="text-xs text-ink-4 leading-snug truncate">{item.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-3 pt-3 border-t border-line/50">
        <a href="/solutions" class="text-xs font-semibold text-brand hover:text-brand-dark transition-colors">
          View all solutions &rarr;
        </a>
      </div>
    </div>
  </div>

  <!-- Dropdown: Integrations -->
  <div id="dropdown-integrations" class="nav-dropdown" style="display:none;" data-dropdown="Integrations">
    <div class="nav-dropdown-inner" style="max-width:480px;">
      <div class="grid grid-cols-1 gap-y-1">
        {integrationItems.map(item => (
          <a href={item.href} class="nav-dropdown-item">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-ink">{item.title}</p>
              <p class="text-xs text-ink-4 leading-snug">{item.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-3 pt-3 border-t border-line/50">
        <a href="/integrations" class="text-xs font-semibold text-brand hover:text-brand-dark transition-colors">
          View all integrations &rarr;
        </a>
      </div>
    </div>
  </div>

  <!-- Dropdown backdrop -->
  <div id="dropdown-backdrop" class="fixed inset-0 -z-10" style="display:none;"></div>
</nav>

<!-- ═══ MOBILE NAV ═══ -->
<nav id="mobile-nav" class="lg:hidden fixed top-0 inset-x-0 z-50 bg-white border-b border-line/50" role="navigation" aria-label="Main navigation">
  <div class="flex items-center justify-between h-16 px-5">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-ink" aria-label="CargoIQ Home">
      <span class="text-brand font-mono tracking-tight">Cargo<span class="text-ink">IQ</span></span>
      <span class="font-mono text-[10px] text-brand-dark bg-brand-light px-1.5 py-0.5 rounded-md">.ai</span>
    </a>
    <button id="menu-toggle" class="p-2.5 rounded-lg text-ink-3 hover:text-ink hover:bg-surface"
            aria-expanded="false" aria-label="Toggle menu">
      <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6" style="display:none;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu panel (separate from nav to avoid nesting issues) -->
<div id="mobile-menu" class="lg:hidden fixed inset-0 top-16 z-40 bg-white overflow-y-auto" style="display:none;"
     role="region" aria-label="Mobile navigation">
  <div class="px-5 py-6 flex flex-col gap-1">
    {navLinks.map(link => (
      <div>
        {link.dropdown ? (
          <div>
            <button class="mobile-acc-btn flex items-center justify-between w-full text-left text-base font-semibold text-ink px-3 py-3.5 rounded-lg hover:bg-surface transition-colors"
                    data-accordion-for={link.label} aria-expanded="false">
              {link.label}
              <svg class="acc-arrow w-4 h-4 text-ink-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="acc-panel mt-1 ml-3 pl-3 border-l border-line/50" style="display:none;" data-accordion-panel={link.label}>
              {link.dropdown.map(item => (
                <a href={item.href} class="flex items-start gap-2.5 px-3 py-2.5 rounded-lg hover:bg-surface transition-colors">
                  {item.icon && <span class="text-base mt-0.5 flex-shrink-0" aria-hidden="true">{item.icon}</span>}
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-ink">{item.title}</p>
                    <p class="text-xs text-ink-4 leading-snug">{item.description}</p>
                  </div>
                </a>
              ))}
              <a href={link.href} class="block px-3 py-2 text-xs font-semibold text-brand">
                View all {link.label.toLowerCase()} &rarr;
              </a>
            </div>
          </div>
        ) : (
          <a href={link.href}
             class="block text-base font-semibold text-ink px-3 py-3.5 rounded-lg hover:bg-surface transition-colors">
            {link.label}
          </a>
        )}
      </div>
    ))}
    <div class="mt-4 pt-4 border-t border-line/50">
      <a href="/contact" class="btn btn-brand w-full justify-center">
        Book a Free Audit
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</div>

<style is:global>
  /* ── Floating pill navbar ── */
  .navbar-container {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .navbar-box {
    height: 68px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 40px;
    margin-top: 16px;
    max-width: 1120px;
    width: calc(100% - 40px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
    transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .navbar-box.scrolled {
    margin-top: 0;
    max-width: 100%;
    width: 100%;
    border-radius: 0;
    background: rgba(255, 255, 255, 0.97);
    border-color: rgba(226, 232, 240, 0.4);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
  }

  .navbar-inner {
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-left: 24px;
    padding-right: 12px;
    gap: 8px;
    max-width: 1140px;
    margin: 0 auto;
  }

  /* ── Scroll-driven shrink (progressive enhancement) ── */
  @supports (animation-timeline: scroll()) {
    .navbar-box {
      animation: navbarShrink 1s both;
      animation-timeline: scroll();
      animation-range: 0 180px;
      transition: none;
    }

    @keyframes navbarShrink {
      from {
        margin-top: 16px;
        max-width: 1120px;
        width: calc(100% - 40px);
        border-radius: 40px;
        background: rgba(255, 255, 255, 0.88);
        border-color: rgba(255, 255, 255, 0.5);
      }
      to {
        margin-top: 0px;
        max-width: 100%;
        width: 100%;
        border-radius: 0px;
        background: rgba(255, 255, 255, 0.97);
        border-color: rgba(226, 232, 240, 0.4);
        box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
      }
    }
  }

  /* ── CTA Button ── */
  .btn-nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 32px;
    background: #1A5FA8;
    color: white;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .btn-nav-cta:hover {
    background: #154d8a;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26, 95, 168, 0.3);
  }

  /* ── Dropdown panel ── */
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 8px;
    z-index: 60;
  }

  .nav-dropdown-inner {
    background: white;
    border: 1px solid rgba(226, 232, 240, 0.7);
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    max-width: 680px;
    width: max-content;
    min-width: 400px;
  }

  .nav-dropdown-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    transition: background 0.15s ease;
  }
  .nav-dropdown-item:hover {
    background: #F8F9FB;
  }

  /* ── Arrow rotation ── */
  [data-has-dropdown].dropdown-open .nav-arrow {
    transform: rotate(180deg);
  }

  .mobile-acc-btn[aria-expanded="true"] .acc-arrow {
    transform: rotate(180deg);
  }
</style>

<script>
  // ── Scroll: JS fallback (always use JS for Safari compatibility) ──
  const navBox = document.getElementById('navbar-box');
  if (navBox) {
    const update = () => navBox.classList.toggle('scrolled', window.scrollY > 40);
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  // ── Desktop dropdowns ──
  const dropdownEls: Record<string, HTMLElement | null> = {
    'Solutions': document.getElementById('dropdown-solutions'),
    'Integrations': document.getElementById('dropdown-integrations'),
  };
  const backdrop = document.getElementById('dropdown-backdrop');
  const triggerItems = document.querySelectorAll('[data-has-dropdown]');
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  function showDropdown(label: string) {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    Object.entries(dropdownEls).forEach(([key, el]) => {
      if (el) el.style.display = key === label ? 'block' : 'none';
    });
    if (backdrop) backdrop.style.display = 'block';
    triggerItems.forEach(item => {
      item.classList.toggle('dropdown-open',
        item.querySelector('.nav-link')?.textContent?.trim() === label);
    });
  }

  function hideAllDropdowns() {
    closeTimer = setTimeout(() => {
      Object.values(dropdownEls).forEach(el => { if (el) el.style.display = 'none'; });
      if (backdrop) backdrop.style.display = 'none';
      triggerItems.forEach(item => item.classList.remove('dropdown-open'));
    }, 120);
  }

  function cancelHide() {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
  }

  triggerItems.forEach(item => {
    const label = item.querySelector('.nav-link')?.textContent?.trim() || '';
    if (!dropdownEls[label]) return;
    item.addEventListener('mouseenter', () => showDropdown(label));
    item.addEventListener('mouseleave', hideAllDropdowns);
  });

  Object.values(dropdownEls).forEach(el => {
    if (!el) return;
    el.addEventListener('mouseenter', cancelHide);
    el.addEventListener('mouseleave', hideAllDropdowns);
  });

  backdrop?.addEventListener('click', () => {
    Object.values(dropdownEls).forEach(el => { if (el) el.style.display = 'none'; });
    if (backdrop) backdrop.style.display = 'none';
    triggerItems.forEach(item => item.classList.remove('dropdown-open'));
  });

  // ── Mobile menu toggle ──
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeBtn = document.getElementById('close-icon');

  function openMobileMenu() {
    if (mobileMenu) mobileMenu.style.display = 'block';
    if (hamburger) hamburger.style.display = 'none';
    if (closeBtn) closeBtn.style.display = 'block';
    menuToggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    if (mobileMenu) mobileMenu.style.display = 'none';
    if (hamburger) hamburger.style.display = 'block';
    if (closeBtn) closeBtn.style.display = 'none';
    menuToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.style.display === 'block';
    isOpen ? closeMobileMenu() : openMobileMenu();
  });

  // ── Mobile accordions ──
  document.querySelectorAll('.mobile-acc-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const label = btn.getAttribute('data-accordion-for');
      const panel = document.querySelector(`[data-accordion-panel="${label}"]`) as HTMLElement | null;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll('.mobile-acc-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
      });
      document.querySelectorAll('.acc-panel').forEach(p => {
        (p as HTMLElement).style.display = 'none';
      });

      // Toggle current
      if (!isOpen && panel) {
        btn.setAttribute('aria-expanded', 'true');
        panel.style.display = 'block';
      }
    });
  });
</script>
