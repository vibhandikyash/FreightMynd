---
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/hero-container-shipping-clean.jpg';
---

<section class="relative min-h-[max(560px,_85vh)] overflow-hidden pt-24 pb-12 md:min-h-[max(640px,_82vh)] md:pt-32 md:pb-14">
  <!-- Hero background image -->
  <div class="absolute inset-0" aria-hidden="true">
    <Image src={heroImg} alt="" class="h-full w-full object-cover object-center" widths={[640, 960, 1280, 1600, 1920]} sizes="100vw" loading="eager" fetchpriority="high" quality={72} />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(18,11,7,0.72)_0%,rgba(18,11,7,0.52)_42%,rgba(18,11,7,0.22)_72%,rgba(18,11,7,0.42)_100%)]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0f1f22]/36 via-[#120b07]/8 to-[#120b07]/72"></div>
  </div>

  <div class="container relative z-10 flex min-h-[440px] items-center justify-center md:min-h-[500px]">
    <div class="mx-auto max-w-[880px] text-center">
      <!-- Eyebrow -->
      <p class="eyebrow mb-5 justify-center text-white/76">
        <span class="eyebrow-dot bg-brand-mid animate-pulse-dot"></span>
        AI in Logistics &middot; Freight Forwarding Automation
      </p>

      <!-- Headline -->
      <h1 class="text-[40px] font-bold leading-[1.08] tracking-normal text-white md:text-[56px] lg:text-[66px]">
        AI in Logistics That Runs Your Freight Forwarding Operations.
        <span class="block text-brand-mid">End to End.</span>
      </h1>

      <!-- Subheadline -->
      <p class="mx-auto mt-6 max-w-[760px] hero-description text-white/84">
        A freight automation platform purpose-built for sea freight, air freight & logistics operations.
        AI document processing, freight quote automation, and shipping automation integrated with your TMS software &mdash; built for your workflows, not ours.
      </p>

      <!-- Trust signal -->
      <p class="mx-auto mt-4 max-w-[740px] text-xs text-white/62 font-mono tracking-wide md:text-sm">
        Trusted by Hellmann Worldwide Logistics &middot; Serving freight forwarders across North America, Europe & Asia-Pacific
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/case-studies/hellmann-4pl-control-tower/" class="btn bg-brand border border-brand text-white hover:bg-white hover:border-white hover:text-ink">
          See It in Action
        </a>
      </div>

      <!-- Micro-copy -->
      <p class="mt-3 text-xs text-white/54 font-mono tracking-wide">
        No commitment &middot; 30-minute call &middot; Custom proposal within 48 hours
      </p>
    </div>
  </div>
</section>
