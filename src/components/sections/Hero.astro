---
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/hero-freight-ai.webp';
---

<section class="relative overflow-hidden pt-28 pb-20 md:pt-36 md:pb-28">
  <!-- Hero background image -->
  <div class="absolute inset-0" aria-hidden="true">
    <Image src={heroImg} alt="" class="w-full h-full object-cover" widths={[640, 960, 1280]} sizes="100vw" loading="eager" fetchpriority="high" quality={60} />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0D1117]/70 via-[#0D1117]/50 to-[#0D1117]/80"></div>
  </div>

  <div class="container relative z-10 text-center">
    <!-- Eyebrow -->
    <p class="eyebrow justify-center mb-6 text-white/60">
      <span class="eyebrow-dot bg-brand-mid animate-pulse-dot"></span>
      AI in Logistics · Freight Forwarding Automation
    </p>

    <!-- Headline -->
    <h1 class="text-display-xl font-bold text-white max-w-4xl mx-auto">
      AI in Logistics That Runs Your<br class="hidden md:inline" /> Freight Forwarding Operations.<br />
      <span class="text-brand-mid">End to End.</span>
    </h1>

    <!-- Subheadline -->
    <p class="mt-6 text-lg md:text-xl text-white/70 leading-relaxed max-w-2xl mx-auto">
      Supply chain artificial intelligence purpose-built for sea freight, air freight & logistics operations.
      Document processing, freight quote automation, and AI integration with your TMS — built for your workflows, not ours.
    </p>

    <!-- Trust signal -->
    <p class="mt-4 text-sm text-white/50 font-mono tracking-wide">
      Trusted by Hellmann Worldwide Logistics · Serving freight forwarders across North America, Europe & Asia-Pacific
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/contact" class="btn btn-brand">
        Book a Free Audit
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="/case-studies/hellmann-4pl-control-tower" class="btn border border-white/30 text-white hover:bg-white/10">
        See How Hellmann Did It
      </a>
    </div>

    <!-- Lower-commitment CTA -->
    <p class="mt-5 text-sm text-white/40">
      <a href="/solutions" class="hover:text-white/60 transition-colors">Or explore our solutions &rarr;</a>
    </p>

    <!-- Scroll indicator -->
    <div class="mt-16 flex flex-col items-center gap-2 text-white/30" data-reveal data-reveal-delay="4" aria-hidden="true">
      <span class="text-[10px] font-mono tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-white/20 animate-scroll-line origin-top"></div>
    </div>
  </div>
</section>

