---
const capabilities = [
  {
    icon: '📄',
    title: 'Zero-Touch Document Processing',
    description: 'AI reads, classifies, and extracts data from 200–300 page batches — invoices, AWBs, packing lists — with near-zero failure rate.',
    href: '/solutions/document-intelligence',
  },
  {
    icon: '📋',
    title: 'Quotes in Minutes, Not Hours',
    description: 'RFQ intake, rate comparison, margin optimization, and quote generation — cutting turnaround from hours to minutes.',
    href: '/solutions/autonomous-quote-management',
  },
  {
    icon: '🚢',
    title: 'Automated Booking to Delivery',
    description: 'End-to-end workflow automation — booking, documentation, tracking, and exception management across ocean and air.',
    href: '/solutions/sea-freight-automation',
  },
  {
    icon: '🔗',
    title: 'Direct TMS Push, Zero Re-Entry',
    description: 'Direct integration with CargoWise, SAP TM, Oracle TMS, and Dynamics — zero manual data entry into your systems.',
    href: '/integrations',
  },
];
---

<section class="section bg-white">
  <div class="container">
    <!-- Header -->
    <div class="max-w-2xl mb-12" data-reveal>
      <p class="eyebrow mb-4">
        <span class="eyebrow-dot bg-brand"></span>
        What We Automate
      </p>
      <h2 class="section-heading">AI Automation for Every Freight Forwarding Workflow</h2>
      <p class="mt-4 text-lg text-ink-3 leading-relaxed">
        From document processing to quoting to TMS integration — we build the AI layer that removes human bottlenecks.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {capabilities.map((cap, i) => (
        <a href={cap.href}
           class="group p-7 rounded-2xl border border-line bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300"
           data-reveal data-reveal-delay={String(i + 1)}>
          <span class="text-2xl mb-4 block" aria-hidden="true">{cap.icon}</span>
          <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{cap.title}</h3>
          <p class="text-sm text-ink-3 leading-relaxed">{cap.description}</p>
          <span class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold text-brand group-hover:gap-2.5 transition-all duration-200">
            {cap.title === 'Zero-Touch Document Processing' ? 'Explore document intelligence' : cap.title === 'Quotes in Minutes, Not Hours' ? 'Explore AI quote management' : cap.title === 'Automated Booking to Delivery' ? 'Explore sea freight automation' : 'View TMS integrations'}
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
