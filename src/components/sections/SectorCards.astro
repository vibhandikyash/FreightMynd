---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import docIntelImg from '../../assets/images/ai-document-processing-v2.png';
import quoteImg from '../../assets/images/quotation-generation-minutes-v3.png';
import airFreightImg from '../../assets/images/automated-booking-delivery-logistics-v3.png';
import tmsPushImg from '../../assets/images/tms-integration-card-v2.png';

const imageMap: Record<string, ImageMetadata> = {
  '/images/document-intelligence.webp': docIntelImg,
  '/images/quote-management-1.webp': quoteImg,
  '/images/air-freight.webp': airFreightImg,
  '/images/smart-invoice-processing.webp': tmsPushImg,
};

const capabilities = [
  {
    icon: 'document',
    title: 'Zero-Touch Document Processing',
    description: 'AI document processing for logistics — reads, classifies, and extracts data from 200–300 page batches of invoices, AWBs, and packing lists with near-zero failure rate.',
    href: '/solutions/document-intelligence',
    image: '/images/document-intelligence.webp',
    imageAspect: 'aspect-[3/2]',
    imageWidth: 760,
    imageHeight: 505,
    imageAlt: 'AI document intelligence — extracting structured data from freight documents',
    cta: 'Explore document intelligence',
  },
  {
    icon: 'quote',
    title: 'Quotes in Minutes, Not Hours',
    description: 'RFQ intake, rate comparison, margin optimization, and quote generation — cutting turnaround from hours to minutes.',
    href: '/solutions/autonomous-quote-management',
    image: '/images/quote-management-1.webp',
    imageAspect: 'aspect-[3/2]',
    imageWidth: 760,
    imageHeight: 505,
    imageAlt: 'Autonomous freight quote management — email to rate card comparison',
    cta: 'Explore AI quote management',
  },
  {
    icon: 'ship',
    title: 'Automated Booking to Delivery',
    description: 'End-to-end workflow automation — booking, documentation, tracking, and exception management across ocean and air.',
    href: '/solutions/sea-freight-automation',
    image: '/images/air-freight.webp',
    imageAspect: 'aspect-[3/2]',
    imageWidth: 760,
    imageHeight: 505,
    imageAlt: 'Sea and air freight booking automation — end-to-end shipment workflow',
    cta: 'Explore sea freight automation',
  },
  {
    icon: 'integration',
    title: 'Direct TMS Push, Zero Re-Entry',
    description: 'AI for CargoWise, SAP TM, Oracle TMS, and Dynamics 365 — native integration that pushes validated data directly into your TMS with zero manual entry.',
    href: '/integrations',
    image: '/images/smart-invoice-processing.webp',
    imageAspect: 'aspect-[3/2]',
    imageWidth: 760,
    imageHeight: 505,
    imageAlt: 'Smart invoice processing — AI-powered 3-way matching and data extraction',
    cta: 'View TMS integrations',
  },
];
---

<section class="section bg-white">
  <div class="container">
    <!-- Header -->
    <div class="max-w-2xl mb-12" data-reveal>
      <p class="eyebrow mb-4">
        <span class="eyebrow-dot bg-brand"></span>
        What We Automate
      </p>
      <h2 class="section-heading">AI Automation for Every Freight Forwarding Workflow</h2>
      <p class="mt-4 text-lg text-ink-3 leading-relaxed">
        From AI document processing to quote automation to TMS integration — our freight automation software removes human bottlenecks from every workflow.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {capabilities.map((cap, i) => (
        <a href={cap.href}
           class="group rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300 overflow-hidden flex flex-col"
           data-reveal data-reveal-delay={String(i + 1)}>
          {cap.image && (
            <div class:list={['w-full overflow-hidden bg-white border-b border-line/70 flex items-center justify-center', cap.imageAspect]}>
              <Image
                src={imageMap[cap.image]}
                alt={cap.imageAlt}
                class="w-full h-full object-cover object-center group-hover:scale-[1.02] transition-transform duration-500"
                width={cap.imageWidth}
                height={cap.imageHeight}
                quality={84}
              />
            </div>
          )}
          <div class="p-7 flex flex-col flex-grow">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center flex-shrink-0">
                {cap.icon === 'document' && (
                  <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                )}
                {cap.icon === 'quote' && (
                  <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
                  </svg>
                )}
                {cap.icon === 'ship' && (
                  <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.149-.504 1.149-1.125v-5.648a3.568 3.568 0 00-.927-2.403L16.5 5.25H6l-2.972 4.324a3.568 3.568 0 00-.928 2.403v5.648c0 .621.504 1.125 1.125 1.125H6.75" />
                  </svg>
                )}
                {cap.icon === 'integration' && (
                  <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                  </svg>
                )}
              </div>
              <h3 class="text-lg font-bold text-ink group-hover:text-brand transition-colors">{cap.title}</h3>
            </div>
            <p class="text-sm text-ink-3 leading-relaxed">{cap.description}</p>
            <span class="inline-flex items-center gap-1.5 mt-5 text-sm font-semibold text-brand group-hover:gap-2.5 transition-[gap] duration-200">
              {cap.cta}
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
