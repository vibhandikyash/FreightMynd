---
import { Image } from 'astro:assets';
import manualOpsImg from '../../assets/images/section-manual-ops.webp';

const painPoints = [
  {
    icon: 'document',
    title: '300-page PDFs processed by hand',
    description: 'Ops teams spend hours every morning splitting, reading, and re-keying data from supplier document bundles into spreadsheets before it touches the TMS.',
  },
  {
    icon: 'clock',
    title: 'Quotes that take hours, not minutes',
    description: 'Rate lookups, margin calculations, and quote formatting are manual and repetitive. Every slow response is a deal lost to a faster competitor.',
  },
  {
    icon: 'disconnect',
    title: 'Systems that don\'t talk to each other',
    description: 'Data sits in CargoWise, carrier portals, email inboxes, and spreadsheets. Without document processing automation across your TMS transportation software and other systems, moving data between them is a full-time job for multiple people.',
  },
  {
    icon: 'supplier',
    title: 'New suppliers = engineering effort',
    description: 'Every new supplier means new document formats, new mappings, new edge cases. Onboarding a supplier shouldn\'t require a developer.',
  },
];
---

<section class="section bg-white">
  <div class="container">
    <!-- Visual: Manual ops chaos image -->
    <div class="mb-12 rounded-2xl overflow-hidden border border-line/70 shadow-lg" data-reveal>
      <Image src={manualOpsImg} alt="Manual freight document processing — invoices, airway bills, and packing lists scattered across a desk" class="w-full h-auto" widths={[480, 768, 1024]} sizes="(max-width: 1220px) calc(100vw - 40px), 1024px" quality={55} />
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left: Header -->
      <div data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-accent"></span>
          The Problem
        </p>
        <h2 class="section-heading">
          Why Freight Forwarding Operations Still Run on Manual Work
        </h2>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">
          Freight forwarding runs on documents, data entry, and manual coordination.
          Most "automation" in logistics is just a dashboard on top of the same broken process.
          The real problem isn't visibility — it's that humans are still the glue between your TMS software, carrier portals, and supplier documents. A proper <strong>freight management system</strong> with AI logistics automation eliminates these manual handoffs entirely — whether you're running CargoWise, SAP TM, or Oracle TMS.
        </p>
        <a href="/solutions" class="inline-flex items-center gap-2 mt-8 text-sm font-semibold text-brand hover:gap-3 transition-[gap] duration-200">
          See how we solve this
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: Pain point cards -->
      <div class="grid gap-4">
        {painPoints.map((point, i) => (
          <div class="flex gap-4 p-5 rounded-2xl border border-line/70 bg-surface/50 hover:bg-white hover:shadow-md transition-[background-color,box-shadow] duration-200"
               data-reveal data-reveal-delay={String(i + 1)}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center flex-shrink-0 mt-0.5">
              {point.icon === 'document' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              )}
              {point.icon === 'clock' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
              {point.icon === 'disconnect' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.181 8.68a4.503 4.503 0 011.903 6.405m-9.768-2.782L3.56 14.06a4.5 4.5 0 006.364 6.365l3.129-3.129m5.614-5.615l1.757-1.757a4.5 4.5 0 00-6.364-6.365l-3.129 3.129" />
                </svg>
              )}
              {point.icon === 'supplier' && (
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-semibold text-ink mb-1">{point.title}</h3>
              <p class="text-sm text-ink-3 leading-relaxed">{point.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
