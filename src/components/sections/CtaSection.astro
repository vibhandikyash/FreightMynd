---
---

<section class="relative py-12 md:py-[60px] overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
  <!-- Soft orbs -->
  <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-[-20%] left-[-10%] w-[300px] h-[300px] rounded-full bg-white/5 blur-3xl" aria-hidden="true"></div>

  <div class="container relative z-10 text-center">
    <h2 class="text-display-lg font-bold text-white max-w-3xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
      Ready to Replace Manual Freight Ops with AI?
    </h2>
    <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto leading-relaxed" data-reveal data-reveal-delay="1">
      Book a free audit. We'll map your freight operations, identify where AI document processing and logistics automation will have the highest impact, and show you exactly what we'd build.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="2">
      <a href="/contact/" class="btn btn-cta-single">
        Book a Free Audit
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="/solutions/" class="btn btn-white">
        Explore Freight AI Solutions
      </a>
    </div>
    <p class="mt-6 text-sm text-white/60 font-mono" data-reveal data-reveal-delay="3">
      No commitment · 30-minute call · Custom proposal within 48 hours
    </p>
    <p class="mt-4 text-sm text-white/50" data-reveal data-reveal-delay="4">
      Prefer email? Reach us at <a href="mailto:hello@freightmynd.com" class="underline hover:text-white/70 transition-colors">hello@freightmynd.com</a>
    </p>
  </div>
</section>
