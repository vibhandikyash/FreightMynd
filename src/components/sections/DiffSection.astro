---
const differentiators = [
  {
    title: 'You Own It — Forever',
    description: 'No subscription. No vendor lock-in. No price hike when you scale. The system we build is yours — deployed in your environment, maintained on your terms. When you outgrow a feature, you extend it. When your team changes, you retrain it. No tickets to a vendor roadmap.',
    detail: 'One-time build. Full source code handover. Your infrastructure.',
    icon: 'ownership',
  },
  {
    title: 'Your Stack, Not Ours',
    description: 'Your TMS. Your CargoWise instance. Your carrier portals. We integrate natively with the systems you already run — not the ones we decided to support. Every API call, every data mapping, every validation rule is built for your specific setup.',
    detail: 'CargoWise · SAP TM · Oracle TMS · Dynamics 365 · Descartes',
    icon: 'stack',
  },
  {
    title: 'Your Edge Cases, Built In',
    description: 'Every freight forwarder has lanes, suppliers, and document formats that don\'t fit a template. A 300-page PDF batch from a German supplier looks nothing like a single-page invoice from a carrier in Singapore. We build those edge cases in from day one — not as an afterthought.',
    detail: 'Self-learning supplier onboarding. Zero engineering per new format.',
    icon: 'edge',
  },
];

const vsRows = [
  { feature: 'Deployment', saas: 'Their cloud, their terms', cargoiq: 'Your environment, your control' },
  { feature: 'Pricing', saas: 'Per-seat subscription, forever', cargoiq: 'One-time build, you own it' },
  { feature: 'TMS Integration', saas: 'Generic connectors', cargoiq: 'Native API built for your instance' },
  { feature: 'Edge Cases', saas: 'Submit a feature request', cargoiq: 'Built in from day one' },
  { feature: 'New Suppliers', saas: 'Manual template mapping', cargoiq: 'Self-learning, zero engineering' },
];
---

<section class="relative overflow-hidden">
  <!-- Top: Light hero block -->
  <div class="bg-white py-24 md:py-32">
    <div class="container">
      <!-- Header -->
      <div class="text-center max-w-3xl mx-auto mb-6" data-reveal>
        <p class="eyebrow justify-center mb-4 text-ink-4">
          <span class="eyebrow-dot bg-brand-mid"></span>
          Why FreightMynd
        </p>
        <h2 class="text-display-lg font-bold text-ink" style="padding-left:0; border-left:none;">
          AI for Freight Forwarding,<br class="hidden md:inline" />
          <span class="text-brand">Custom-Built Around Your Workflow.</span>
        </h2>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed max-w-2xl mx-auto">
          Generic freight forwarding software gives you a login. We give you a complete freight management system — engineered for your TMS software, your suppliers, and your freight operations.
        </p>
      </div>

      <!-- Three pillars -->
      <div class="grid md:grid-cols-3 gap-5 mt-14">
        {differentiators.map((diff, i) => (
          <div class="bg-white rounded-2xl border border-line/70 p-8 hover:shadow-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300"
               data-reveal data-reveal-delay={String(i + 1)}>
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-brand-light flex items-center justify-center mb-5">
              {diff.icon === 'ownership' && (
                <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              )}
              {diff.icon === 'stack' && (
                <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3" />
                </svg>
              )}
              {diff.icon === 'edge' && (
                <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1m0 0L12 4.37l5.68 5.7m-11.38 0h11.38M4.22 19.78h15.56" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-ink mb-3">{diff.title}</h3>
            <p class="text-ink-3 leading-relaxed mb-4">{diff.description}</p>
            <p class="text-xs font-mono text-brand tracking-wide">{diff.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom: Comparison table -->
  <div class="bg-white py-16 md:py-20 border-t border-line">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <!-- Table header -->
        <div class="text-center mb-10" data-reveal>
          <h3 class="text-display-sm font-bold text-ink" style="padding-left:0; border-left:none;">
            Generic SaaS vs Custom-Built AI
          </h3>
          <p class="mt-3 text-ink-3 text-sm">See why freight forwarders choose custom AI freight management over off-the-shelf freight forwarding software.</p>
        </div>

        <!-- Desktop table -->
        <div class="hidden md:block rounded-2xl border border-line/70 overflow-hidden" data-reveal data-reveal-delay="1">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-line bg-surface">
                <th class="py-4 px-6 text-xs font-mono uppercase tracking-widest text-ink-4 w-1/4"></th>
                <th class="py-4 px-6 text-xs font-mono uppercase tracking-widest text-ink-4 w-[37.5%]">Generic SaaS</th>
                <th class="py-4 px-6 text-xs font-mono uppercase tracking-widest text-brand w-[37.5%] bg-brand-light/40">FreightMynd</th>
              </tr>
            </thead>
            <tbody>
              {vsRows.map((row, i) => (
                <tr class={`border-b border-line/50 ${i % 2 === 1 ? 'bg-surface/50' : ''}`}>
                  <td class="py-4 px-6 text-sm font-semibold text-ink">{row.feature}</td>
                  <td class="py-4 px-6 text-sm text-ink-4">{row.saas}</td>
                  <td class="py-4 px-6 text-sm text-ink font-medium bg-brand-light/40">{row.cargoiq}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile cards -->
        <div class="md:hidden grid gap-3">
          {vsRows.map((row, i) => (
            <div class="p-4 rounded-xl border border-line/70 bg-surface/50" data-reveal data-reveal-delay={String(Math.min(i + 1, 4))}>
              <p class="text-xs font-mono uppercase tracking-widest text-ink-4 mb-2">{row.feature}</p>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <p class="text-[10px] font-mono text-ink-4 uppercase mb-1">SaaS</p>
                  <p class="text-sm text-ink-4">{row.saas}</p>
                </div>
                <div class="pl-3 border-l border-brand/30">
                  <p class="text-[10px] font-mono text-brand uppercase mb-1">FreightMynd</p>
                  <p class="text-sm text-ink font-medium">{row.cargoiq}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- In-house comparison callout -->
        <div class="mt-10 p-8 rounded-2xl border border-brand-mid bg-brand-light text-center max-w-3xl mx-auto" data-reveal data-reveal-delay="2">
          <div class="w-12 h-12 rounded-xl bg-brand-light flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-ink mb-3">Faster Than Building In-House</h3>
          <p class="text-ink-3 leading-relaxed max-w-xl mx-auto">
            Building AI for freight operations in-house means hiring ML engineers, training them on TMS APIs, and discovering document edge cases the hard way. We've already solved those problems across multiple production deployments.
          </p>
          <p class="mt-4 text-sm font-semibold text-brand">
            Your team gets a production-grade system in 8–14 weeks, not 12–18 months.
          </p>
        </div>

        <!-- CTA -->
        <div class="mt-10 text-center" data-reveal data-reveal-delay="3">
          <a href="/contact" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <p class="mt-3 text-xs text-ink-4">No commitment. We'll assess your ops and show you what's possible.</p>
        </div>
      </div>
    </div>
  </div>
</section>
