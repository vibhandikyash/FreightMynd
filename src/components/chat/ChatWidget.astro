---
/**
 * ChatWidget.astro — Lazy-loaded chat bubble + panel with context-aware nudging.
 * SSG renders only the bubble button + nudge containers. All JS initializes on first click.
 * Signal collector and nudge timer use requestIdleCallback/setTimeout — zero Lighthouse impact.
 */
---

<!-- Chat Bubble -->
<button
  id="chat-bubble"
  class="fixed bottom-5 right-5 z-[45] flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-brand)] text-white shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-[var(--color-brand)] cursor-pointer"
  aria-label="Chat with FreightMynd"
>
  <svg id="chat-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
  </svg>
  <svg id="chat-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
  </svg>
</button>

<!-- Nudge Tooltip (Desktop) -->
<div
  id="chat-nudge"
  class="fixed bottom-20 right-5 z-[44] hidden max-w-[250px] rounded-xl bg-white px-4 py-3 shadow-lg border border-[var(--color-line)] opacity-0 translate-y-2 transition-all duration-300 max-sm:hidden"
  role="status"
  aria-live="polite"
>
  <p id="chat-nudge-text" class="text-sm text-[var(--color-ink)] leading-relaxed pr-5"></p>
  <button
    id="chat-nudge-close"
    class="absolute top-2 right-2 flex h-5 w-5 items-center justify-center rounded-full text-[var(--color-ink-4)] hover:text-[var(--color-ink)] hover:bg-[var(--color-surface)] transition-colors cursor-pointer"
    aria-label="Dismiss nudge"
  >
    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
    </svg>
  </button>
  <!-- Speech bubble tail -->
  <div class="absolute -bottom-1.5 right-8 h-3 w-3 rotate-45 bg-white border-r border-b border-[var(--color-line)]"></div>
</div>

<!-- Nudge Bar (Mobile) -->
<div
  id="chat-nudge-mobile"
  class="fixed bottom-20 left-3 right-3 z-[44] hidden sm:hidden rounded-xl bg-white px-4 py-2.5 shadow-lg border border-[var(--color-line)] opacity-0 translate-y-2 transition-all duration-300"
  role="status"
  aria-live="polite"
>
  <p id="chat-nudge-mobile-text" class="text-sm text-[var(--color-ink)] leading-snug"></p>
</div>

<!-- Chat Panel (hidden until first click) -->
<div
  id="chat-panel"
  class="fixed bottom-24 right-5 z-[45] hidden w-[380px] max-sm:bottom-0 max-sm:right-0 max-sm:left-0 max-sm:top-[68px] max-sm:w-full flex-col overflow-hidden rounded-2xl max-sm:rounded-none bg-white shadow-xl border border-[var(--color-line)]"
  role="dialog"
  aria-label="Chat with FreightMynd"
  style="height: 560px; max-sm:height: auto;"
>
  <!-- Header -->
  <div class="flex items-center justify-between bg-[var(--color-ink)] px-4 py-3 shrink-0">
    <div class="flex items-center gap-2.5">
      <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-brand)]">
        <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-white">Cargo</p>
        <p class="text-[11px] text-[var(--color-ink-4)]">FreightMynd AI Assistant</p>
      </div>
    </div>
    <button
      id="chat-close"
      class="rounded-md p-1.5 text-[var(--color-ink-4)] hover:bg-white/10 hover:text-white transition-colors cursor-pointer"
      aria-label="Close chat"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3" aria-live="polite">
    <!-- Greeting injected by JS on first open -->
  </div>

  <!-- Input -->
  <div class="shrink-0 border-t border-[var(--color-line)] bg-white p-3">
    <form id="chat-form" class="flex items-center gap-2">
      <label for="chat-input" class="sr-only">Type your message</label>
      <input
        id="chat-input"
        type="text"
        placeholder="Ask about freight automation..."
        autocomplete="off"
        maxlength="2000"
        class="flex-1 rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] px-3 py-2.5 text-sm text-[var(--color-ink)] placeholder-[var(--color-ink-4)] outline-none focus:border-[var(--color-brand)] focus:ring-1 focus:ring-[var(--color-brand)] transition-colors"
      />
      <button
        id="chat-send"
        type="submit"
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-dark)] transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer"
        aria-label="Send message"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
  (function () {
    const bubble = document.getElementById('chat-bubble')!;
    const panel = document.getElementById('chat-panel')!;
    const closeBtn = document.getElementById('chat-close')!;
    const iconOpen = document.getElementById('chat-icon-open')!;
    const iconClose = document.getElementById('chat-icon-close')!;
    const messagesEl = document.getElementById('chat-messages')!;
    const form = document.getElementById('chat-form') as HTMLFormElement;
    const input = document.getElementById('chat-input') as HTMLInputElement;
    const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
    const nudgeDesktop = document.getElementById('chat-nudge')!;
    const nudgeDesktopText = document.getElementById('chat-nudge-text')!;
    const nudgeDesktopClose = document.getElementById('chat-nudge-close')!;
    const nudgeMobile = document.getElementById('chat-nudge-mobile')!;
    const nudgeMobileText = document.getElementById('chat-nudge-mobile-text')!;

    let isOpen = false;
    let initialized = false;
    let sessionId: string | null = sessionStorage.getItem('ciq_sid');
    let isStreaming = false;
    let nudgeVisible = false;
    let nudgeAutoHideTimer: ReturnType<typeof setTimeout> | null = null;

    // =========================================================================
    // 1. SIGNAL COLLECTOR
    // =========================================================================

    // Lightweight context — just enough to personalise, nothing creepy
    interface UserContext {
      pages: string[];          // paths only, no timestamps or scroll tracking
      device: 'mobile' | 'desktop';
      sessionStart: number;
      nudgeDismissed: boolean;
      chatOpened: boolean;
      lastChatPage?: string;    // page where chat was last opened
    }

    function loadContext(): UserContext {
      try {
        const raw = sessionStorage.getItem('fmnd_ctx');
        if (raw) return JSON.parse(raw);
      } catch { /* ignore */ }
      return {
        pages: [],
        device: window.innerWidth < 768 ? 'mobile' : 'desktop',
        sessionStart: Date.now(),
        nudgeDismissed: false,
        chatOpened: false,
      };
    }

    function saveContext(ctx: UserContext) {
      try { sessionStorage.setItem('fmnd_ctx', JSON.stringify(ctx)); } catch { /* ignore */ }
    }

    const ctx = loadContext();
    const currentPath = window.location.pathname;

    // Track which pages the user has visited (just paths, nothing more)
    if (!ctx.pages.includes(currentPath)) {
      ctx.pages.push(currentPath);
    }
    saveContext(ctx);

    // =========================================================================
    // 2. PERSONA INFERENCER
    // =========================================================================

    interface InferredPersona {
      interest: string;
      stage: 'exploring' | 'researching' | 'evaluating' | 'ready';
      role: 'ops' | 'tech' | 'exec' | 'unknown';
      pain: string;
      nudgeMessage: string;
      greeting: string;
      quickReplies: string[];
    }

    // Solution slug to short title map
    const solutionTitles: Record<string, string> = {
      '4pl-control-tower-automation': '4PL Control Tower Automation',
      'autonomous-quote-management': 'Autonomous Quote Management',
      'document-intelligence': 'Document Intelligence',
      'freight-pricing-ai': 'AI-Powered Freight Pricing',
      'sea-freight-automation': 'Sea Freight Automation',
      'air-freight-automation': 'Air Freight Automation',
      '3pl-4pl-operations': '3PL/4PL Operations',
      'smart-invoice-processing': 'Smart Invoice Processing',
      'customs-automation': 'Customs Automation',
      'email-intelligence': 'Email Intelligence',
      'booking-automation': 'Booking Automation',
      'carrier-performance-analytics': 'Carrier Performance Analytics',
      'shipment-visibility-portal': 'Shipment Visibility Portal',
      'eta-prediction-exception-management': 'ETA Prediction & Exception Management',
      'sop-compliance-monitoring': 'SOP Compliance Monitoring',
      'order-to-cash-automation': 'Order-to-Cash Automation',
      'rate-sheet-intelligence': 'Rate Sheet Intelligence',
      'freight-document-automation': 'Freight Document Automation',
      'freight-spend-analytics': 'Freight Spend Analytics',
      'freight-revenue-recovery': 'Freight Revenue Recovery',
      'tms-automation': 'TMS Automation',
    };

    // Integration slug to display name
    const integrationTitles: Record<string, string> = {
      'cargowise': 'CargoWise',
      'sap-tm': 'SAP TM',
      'oracle-tms': 'Oracle TMS',
      'microsoft-dynamics': 'Microsoft Dynamics',
      'descartes': 'Descartes',
    };

    // Pain point map by interest slug
    const painMap: Record<string, string> = {
      '4pl-control-tower-automation': 'manual document processing bottleneck',
      'autonomous-quote-management': 'slow quote turnaround time',
      'document-intelligence': 'manual data extraction from freight documents',
      'freight-pricing-ai': 'inconsistent freight pricing and margin leakage',
      'sea-freight-automation': 'manual sea freight booking and tracking',
      'air-freight-automation': 'manual air freight operations',
      '3pl-4pl-operations': 'disconnected 3PL/4PL workflows',
      'smart-invoice-processing': 'manual invoice matching and processing',
      'customs-automation': 'customs filing bottleneck',
      'email-intelligence': 'inbox overload and missed communications',
      'booking-automation': 'manual booking workflows',
      'carrier-performance-analytics': 'lack of carrier performance visibility',
      'shipment-visibility-portal': 'fragmented shipment tracking',
      'eta-prediction-exception-management': 'reactive exception management',
      'sop-compliance-monitoring': 'SOP compliance gaps',
      'order-to-cash-automation': 'slow order-to-cash cycle',
      'rate-sheet-intelligence': 'manual rate sheet ingestion',
      'freight-document-automation': 'manual freight document handling',
      'freight-spend-analytics': 'lack of freight spend visibility',
      'freight-revenue-recovery': 'revenue leakage in freight operations',
      'tms-automation': 'underutilized TMS capabilities',
      'cargowise-integration': 'CargoWise integration complexity',
      'tms-integration': 'TMS integration challenges',
      'general': 'manual freight operations',
    };

    // Nudge messages by path
    const nudgeMessages: Record<string, string> = {
      '/solutions/customs-automation': 'Ask me about customs filing time reduction',
      '/solutions/4pl-control-tower-automation': 'Curious how we process 300-page batches?',
      '/solutions/autonomous-quote-management': 'Want to cut quoting time from 45 min to 5?',
      '/solutions/email-intelligence': 'Ask me about inbox automation',
      '/solutions/booking-automation': 'Ask about automated booking workflows',
      '/solutions/carrier-performance-analytics': 'Want to know which carriers actually perform?',
      '/solutions/shipment-visibility-portal': 'Ask about white-label tracking portals',
      '/solutions/eta-prediction-exception-management': 'Ask how we predict delays 24-72 hours early',
      '/solutions/sop-compliance-monitoring': 'Ask about automated SOP auditing',
      '/solutions/order-to-cash-automation': 'Ask about closing your books in 3 days',
      '/solutions/rate-sheet-intelligence': 'Ask about automated rate sheet ingestion',
      '/solutions/freight-pricing-ai': 'Ask about AI-powered freight pricing',
      '/solutions/smart-invoice-processing': 'Ask about automated invoice matching',
    };

    function inferPersona(ctx: UserContext): InferredPersona {
      const path = currentPath;
      const allPaths = ctx.pages;

      // --- Interest ---
      let interest = 'general';
      if (path.startsWith('/solutions/') && path !== '/solutions/') {
        interest = path.replace('/solutions/', '').replace(/\/$/, '');
      } else if (path.startsWith('/integrations/') && path !== '/integrations/') {
        interest = path.replace('/integrations/', '').replace(/\/$/, '') + '-integration';
      } else if (path.startsWith('/blog/') && path !== '/blog/') {
        interest = path.replace('/blog/', '').replace(/\/$/, '');
      } else if (path.startsWith('/compare/')) {
        interest = 'comparison';
      } else if (path.startsWith('/case-studies/')) {
        interest = 'case-study';
      }

      // --- Stage ---
      let stage: InferredPersona['stage'] = 'exploring';
      const uniquePages = new Set(allPaths).size;
      if (allPaths.some(p => p === '/contact')) {
        stage = 'ready';
      } else if (allPaths.some(p => p.startsWith('/compare/'))) {
        stage = 'evaluating';
      } else if (uniquePages >= 2) {
        stage = 'researching';
      }

      // --- Role ---
      let role: InferredPersona['role'] = 'unknown';
      if (allPaths.some(p => p.startsWith('/solutions/'))) {
        role = 'ops';
      }
      if (allPaths.some(p => p.startsWith('/integrations/'))) {
        role = 'tech';
      }
      if (allPaths.some(p => p.startsWith('/about') || p.startsWith('/compare/'))) {
        role = 'exec';
      }

      // --- Pain ---
      const painKey = interest.replace(/-integration$/, '-integration');
      const pain = painMap[painKey] || painMap[interest] || painMap['general'];

      // --- Nudge message ---
      let nudgeMessage: string;
      if (nudgeMessages[path]) {
        nudgeMessage = nudgeMessages[path];
      } else if (path.startsWith('/solutions/')) {
        nudgeMessage = 'Not sure which solution fits? Ask me';
      } else if (path.startsWith('/compare/')) {
        nudgeMessage = 'Comparing options? I can help you decide';
      } else if (path.startsWith('/integrations/cargowise')) {
        nudgeMessage = 'Ask about CargoWise AI integration';
      } else if (path.startsWith('/integrations/')) {
        nudgeMessage = 'Ask about TMS integration';
      } else if (path.startsWith('/blog/')) {
        nudgeMessage = 'Have a question about this topic?';
      } else if (path.startsWith('/case-studies/')) {
        nudgeMessage = 'Want to see how this applies to your ops?';
      } else if (path === '/' || path === '') {
        nudgeMessage = 'What freight process takes the most time?';
      } else {
        nudgeMessage = 'Questions about freight AI automation?';
      }

      // --- Greeting ---
      let greeting: string;
      if (path === '/' || path === '') {
        greeting = "Hey! I'm **Cargo**, FreightMynd's AI assistant. I help freight forwarding teams understand how AI can automate their operations.\n\nWhat's taking the most time in your ops right now?";
      } else if (path.startsWith('/solutions/') && path !== '/solutions/') {
        const slug = path.replace('/solutions/', '').replace(/\/$/, '');
        const title = solutionTitles[slug] || slug.replace(/-/g, ' ');
        greeting = `Hey! I see you're looking at **${title}**. I can answer questions about how it works, implementation timelines, or expected results.\n\nWhat would you like to know?`;
      } else if (path.startsWith('/compare/')) {
        greeting = "Hey! Evaluating your options for freight AI? I can help you understand the differences and figure out what fits your operation.\n\nWhat's most important to you \u2014 customization, speed, or cost?";
      } else if (path.startsWith('/blog/') && path !== '/blog/') {
        const slug = path.replace('/blog/', '').replace(/\/$/, '');
        const topic = slug.replace(/-/g, ' ');
        greeting = `Hey! I see you're reading about **${topic}**. I can answer questions or point you to related solutions.\n\nAnything specific you're looking into?`;
      } else if (path.startsWith('/integrations/') && path !== '/integrations/') {
        const slug = path.replace('/integrations/', '').replace(/\/$/, '');
        const title = integrationTitles[slug] || slug.replace(/-/g, ' ');
        greeting = `Hey! Looking at **${title}** integration? I can explain how our AI layer connects with your TMS.\n\nWhat system are you running?`;
      } else {
        greeting = "Hey! I'm **Cargo**, FreightMynd's AI assistant. I help freight forwarding teams understand how AI can automate their operations.\n\nWhat are you looking into?";
      }

      // --- Quick replies ---
      let quickReplies: string[];
      if (path.startsWith('/solutions/') && path !== '/solutions/') {
        quickReplies = ['How does it work?', 'Implementation timeline', 'Expected ROI', 'See a case study'];
      } else if (path.startsWith('/compare/')) {
        quickReplies = ['What makes you different?', 'Pricing model', 'See case studies'];
      } else if (path.startsWith('/blog/')) {
        quickReplies = ['Related solutions', 'Book an audit', 'Just exploring'];
      } else if (path.startsWith('/integrations/')) {
        quickReplies = ['How does it integrate?', 'What can be automated?', 'Implementation time'];
      } else {
        quickReplies = ['Document processing', 'Quote automation', 'TMS integration', 'Just exploring'];
      }

      return { interest, stage, role, pain, nudgeMessage, greeting, quickReplies };
    }

    const persona = inferPersona(ctx);

    // =========================================================================
    // 3. NUDGE SYSTEM
    // =========================================================================

    function showNudge() {
      if (ctx.nudgeDismissed || ctx.chatOpened || isOpen) return;
      if (currentPath === '/contact' || currentPath === '/contact/') return;

      const isMobile = window.innerWidth < 640;

      if (isMobile) {
        nudgeMobileText.textContent = persona.nudgeMessage;
        nudgeMobile.classList.remove('hidden');
        // Trigger entrance animation on next frame
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            nudgeMobile.classList.remove('opacity-0', 'translate-y-2');
            nudgeMobile.classList.add('opacity-100', 'translate-y-0');
          });
        });
      } else {
        nudgeDesktopText.textContent = persona.nudgeMessage;
        nudgeDesktop.classList.remove('hidden');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            nudgeDesktop.classList.remove('opacity-0', 'translate-y-2');
            nudgeDesktop.classList.add('opacity-100', 'translate-y-0');
          });
        });
      }

      nudgeVisible = true;

      // Auto-hide after 8 seconds
      nudgeAutoHideTimer = setTimeout(hideNudge, 8000);
    }

    function hideNudge(markDismissed = false) {
      if (nudgeAutoHideTimer) {
        clearTimeout(nudgeAutoHideTimer);
        nudgeAutoHideTimer = null;
      }

      // Fade out
      nudgeDesktop.classList.add('opacity-0', 'translate-y-2');
      nudgeDesktop.classList.remove('opacity-100', 'translate-y-0');
      nudgeMobile.classList.add('opacity-0', 'translate-y-2');
      nudgeMobile.classList.remove('opacity-100', 'translate-y-0');

      setTimeout(() => {
        nudgeDesktop.classList.add('hidden');
        nudgeMobile.classList.add('hidden');
      }, 300);

      nudgeVisible = false;

      if (markDismissed) {
        ctx.nudgeDismissed = true;
        saveContext(ctx);
      }
    }

    // Desktop nudge close button
    nudgeDesktopClose.addEventListener('click', (e) => {
      e.stopPropagation();
      hideNudge(true);
    });

    // Clicking the desktop nudge opens chat
    nudgeDesktop.addEventListener('click', () => {
      hideNudge(false);
      if (!isOpen) toggleChat();
    });

    // Clicking/tapping the mobile nudge opens chat
    nudgeMobile.addEventListener('click', () => {
      hideNudge(false);
      if (!isOpen) toggleChat();
    });

    // Mobile: swipe down to dismiss
    let touchStartY = 0;
    nudgeMobile.addEventListener('touchstart', (e) => {
      touchStartY = e.touches[0].clientY;
    }, { passive: true });
    nudgeMobile.addEventListener('touchend', (e) => {
      const deltaY = e.changedTouches[0].clientY - touchStartY;
      if (deltaY > 30) {
        hideNudge(true);
      }
    }, { passive: true });

    // Schedule nudge — non-blocking via requestIdleCallback or setTimeout
    function scheduleNudge() {
      if (ctx.nudgeDismissed || ctx.chatOpened) return;
      if (currentPath === '/contact' || currentPath === '/contact/') return;

      const isMobile = window.innerWidth < 640;
      const delayMs = isMobile ? 30000 : 20000;

      // Account for time already spent on site this session
      const elapsed = Date.now() - ctx.sessionStart;
      const remaining = Math.max(0, delayMs - elapsed);

      const schedule = typeof requestIdleCallback !== 'undefined'
        ? (cb: () => void) => requestIdleCallback(() => setTimeout(cb, remaining))
        : (cb: () => void) => setTimeout(cb, remaining);

      schedule(showNudge);
    }

    scheduleNudge();

    // =========================================================================
    // SESSION PERSISTENCE
    // =========================================================================

    interface StoredMessage { role: 'user' | 'assistant'; content: string }

    function saveMessages(msgs: StoredMessage[]) {
      sessionStorage.setItem('ciq_msgs', JSON.stringify(msgs));
    }

    function loadMessages(): StoredMessage[] {
      try {
        const raw = sessionStorage.getItem('ciq_msgs');
        return raw ? JSON.parse(raw) : [];
      } catch { return []; }
    }

    function persistSessionId(id: string) {
      sessionId = id;
      sessionStorage.setItem('ciq_sid', id);
    }

    // =========================================================================
    // MINIMAL MARKDOWN PARSER
    // =========================================================================

    function md(text: string): string {
      // Strip any LEAD markers that slipped through
      text = text.replace(/<!--LEAD:\{.*?\}-->/g, '');
      // Bold
      text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Links
      text = text.replace(
        /\[([^\]]+)\]\(([^)]+)\)/g,
        '<a href="$2" target="_blank" rel="noopener" class="underline text-[var(--color-brand)] hover:text-[var(--color-brand-dark)]">$1</a>'
      );
      // List items
      text = text.replace(/^- (.+)$/gm, '<li class="ml-4 list-disc">$1</li>');
      text = text.replace(/(<li.*?<\/li>\n?)+/g, '<ul class="my-1">$&</ul>');
      // Line breaks
      text = text.replace(/\n/g, '<br>');
      return text;
    }

    // =========================================================================
    // MESSAGE RENDERING
    // =========================================================================

    function addMessage(role: 'user' | 'assistant', content: string) {
      const wrapper = document.createElement('div');
      wrapper.className =
        role === 'user'
          ? 'flex justify-end'
          : 'flex justify-start';

      const msgBubble = document.createElement('div');
      msgBubble.className =
        role === 'user'
          ? 'max-w-[85%] rounded-2xl rounded-br-sm bg-[var(--color-brand)] px-3.5 py-2.5 text-sm text-white leading-relaxed'
          : 'max-w-[85%] rounded-2xl rounded-bl-sm bg-[var(--color-surface)] px-3.5 py-2.5 text-sm text-[var(--color-ink)] leading-relaxed';

      if (role === 'assistant') {
        msgBubble.innerHTML = md(content);
      } else {
        msgBubble.textContent = content;
      }

      wrapper.appendChild(msgBubble);
      messagesEl.appendChild(wrapper);
      scrollToBottom();

      // Persist to sessionStorage (skip if restoring)
      if (!isRestoring) {
        const msgs = loadMessages();
        msgs.push({ role, content });
        saveMessages(msgs);
      }
    }

    let isRestoring = false;

    function addStreamingBubble(): HTMLDivElement {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex justify-start';
      wrapper.id = 'streaming-msg';

      const msgBubble = document.createElement('div');
      msgBubble.className =
        'max-w-[85%] rounded-2xl rounded-bl-sm bg-[var(--color-surface)] px-3.5 py-2.5 text-sm text-[var(--color-ink)] leading-relaxed';
      msgBubble.innerHTML = '<span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-ink-4)] animate-pulse"></span>';

      wrapper.appendChild(msgBubble);
      messagesEl.appendChild(wrapper);
      scrollToBottom();
      return msgBubble;
    }

    function addQuickReplies(chips: string[]) {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex flex-wrap gap-2 mt-1';
      wrapper.id = 'quick-replies';

      chips.forEach((label) => {
        const btn = document.createElement('button');
        btn.className =
          'rounded-full border border-[var(--color-brand-mid)] bg-[var(--color-brand-light)] px-3 py-1.5 text-xs font-medium text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-mid)] transition-colors cursor-pointer';
        btn.textContent = label;
        btn.addEventListener('click', () => {
          const qr = document.getElementById('quick-replies');
          if (qr) qr.remove();
          sendMessage(label);
        });
        wrapper.appendChild(btn);
      });

      messagesEl.appendChild(wrapper);
      scrollToBottom();
    }

    function scrollToBottom() {
      requestAnimationFrame(() => {
        messagesEl.scrollTop = messagesEl.scrollHeight;
      });
    }

    // =========================================================================
    // GREETING OR RESTORE
    // =========================================================================

    function showGreeting() {
      const saved = loadMessages();
      if (saved.length > 0) {
        // Restore previous conversation
        isRestoring = true;
        saved.forEach((msg) => addMessage(msg.role, msg.content));
        isRestoring = false;

        // If user navigated to a different page since last chat, add a contextual bridge
        if (ctx.lastChatPage && ctx.lastChatPage !== currentPath && currentPath !== '/') {
          const slug = currentPath.replace(/^\/(solutions|integrations|blog|compare|case-studies)\//, '').replace(/\/$/, '');
          const title = solutionTitles[slug] || integrationTitles[slug] || null;
          if (title) {
            addMessage('assistant', `I see you're now looking at **${title}** — want me to answer questions about that?`);
            addQuickReplies(persona.quickReplies);
          }
        }
        return;
      }

      // First-ever chat open — contextual greeting based on current page
      addMessage('assistant', persona.greeting);
      addQuickReplies(persona.quickReplies);
    }

    // =========================================================================
    // SEND MESSAGE (with context)
    // =========================================================================

    async function sendMessage(text: string) {
      if (!text.trim() || isStreaming) return;

      addMessage('user', text.trim());
      input.value = '';
      isStreaming = true;
      sendBtn.disabled = true;

      const streamBubble = addStreamingBubble();
      let fullText = '';

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            sessionId,
            message: text.trim(),
            context: {
              currentPath: currentPath,
              pagesVisited: ctx.pages,
              device: ctx.device,
              interest: persona.interest,
              stage: persona.stage,
            },
          }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Something went wrong' }));
          streamBubble.innerHTML = md(
            err.error === 'Rate limit exceeded. Please try again later.'
              ? "You've sent a lot of messages! Feel free to [book a call with our team](/contact) to continue the conversation."
              : 'Sorry, I hit a snag. Try again in a moment.'
          );
          return;
        }

        const reader = res.body!.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';

          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            const data = line.slice(6).trim();
            if (!data) continue;

            try {
              const event = JSON.parse(data);

              if (event.type === 'session' && event.sessionId) {
                persistSessionId(event.sessionId);
              }

              if (event.type === 'delta' && event.text) {
                fullText += event.text;
                // Strip complete LEAD markers and any partial marker at the end
                let displayText = fullText.replace(/<!--LEAD:\{[\s\S]*?\}-->/g, '');
                // Also strip any partial/incomplete marker from end of stream
                const partialIdx = displayText.indexOf('<!--LEAD:');
                if (partialIdx !== -1) displayText = displayText.slice(0, partialIdx);
                streamBubble.innerHTML = md(displayText);
                scrollToBottom();
              }

              if (event.type === 'done') {
                // Final render — clean everything
                let displayText = fullText.replace(/<!--LEAD:\{[\s\S]*?\}-->/g, '');
                const partialIdx = displayText.indexOf('<!--LEAD:');
                if (partialIdx !== -1) displayText = displayText.slice(0, partialIdx);
                streamBubble.innerHTML = md(displayText.trimEnd());
              }
            } catch {
              // Skip malformed chunks
            }
          }
        }
      } catch (err) {
        console.error('Chat error:', err);
        streamBubble.innerHTML = md(
          'Sorry, I had trouble connecting. Please try again.'
        );
      } finally {
        // Remove streaming wrapper ID and persist assistant message
        const sw = document.getElementById('streaming-msg');
        if (sw) sw.removeAttribute('id');
        if (fullText) {
          const displayText = fullText.replace(/<!--LEAD:\{.*?\}-->/g, '');
          const msgs = loadMessages();
          msgs.push({ role: 'assistant', content: displayText });
          saveMessages(msgs);
        }
        isStreaming = false;
        sendBtn.disabled = false;
        input.focus();
      }
    }

    // =========================================================================
    // TOGGLE PANEL
    // =========================================================================

    function toggleChat() {
      isOpen = !isOpen;
      panel.classList.toggle('hidden', !isOpen);
      panel.classList.toggle('flex', isOpen);
      iconOpen.classList.toggle('hidden', isOpen);
      iconClose.classList.toggle('hidden', !isOpen);

      if (isOpen && !initialized) {
        initialized = true;
        showGreeting();
      }

      if (isOpen) {
        // Mark chat as opened and remember which page
        ctx.chatOpened = true;
        ctx.lastChatPage = currentPath;
        saveContext(ctx);

        // Hide nudge if visible
        if (nudgeVisible) hideNudge(false);

        input.focus();
      }
    }

    function closeChat() {
      isOpen = false;
      panel.classList.add('hidden');
      panel.classList.remove('flex');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      bubble.focus();
    }

    // =========================================================================
    // EVENT LISTENERS
    // =========================================================================

    bubble.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', closeChat);

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      sendMessage(input.value);
    });

    // Escape key closes chat
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeChat();
      }
    });

    // Mobile: fix panel height
    function setMobileHeight() {
      if (window.innerWidth < 640 && isOpen) {
        panel.style.height = `${window.innerHeight - 68}px`;
      } else if (window.innerWidth >= 640) {
        panel.style.height = '560px';
      }
    }

    window.addEventListener('resize', setMobileHeight);
  })();
</script>
