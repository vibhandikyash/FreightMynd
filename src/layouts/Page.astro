---
import Base from './Base.astro';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: object | object[];
}
---

<Base {...Astro.props}>
  <Nav />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  <Footer />
</Base>
