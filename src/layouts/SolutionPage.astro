---
import Page from './Page.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import SolutionIcon from '../components/ui/SolutionIcon.astro';
import { Image } from 'astro:assets';
import { site } from '../data/site';
import type { Solution } from '../data/solutions';
import type { ImageMetadata } from 'astro';

// Import all solution/integration hero images from src/assets/images
import img4pl from '../assets/images/4pl-control-tower.webp';
import imgQuote from '../assets/images/quote-management.webp';
import imgDoc from '../assets/images/document-intelligence.webp';
import imgPricing from '../assets/images/freight-pricing-ai.webp';
import imgSea from '../assets/images/sea-freight.webp';
import imgAir from '../assets/images/air-freight.webp';
import img3pl from '../assets/images/3pl-4pl-operations.webp';
import imgInvoice from '../assets/images/smart-invoice-processing.webp';

const heroImageMap: Record<string, ImageMetadata> = {
  '/images/4pl-control-tower.webp': img4pl,
  '/images/quote-management.webp': imgQuote,
  '/images/document-intelligence.webp': imgDoc,
  '/images/freight-pricing-ai.webp': imgPricing,
  '/images/sea-freight.webp': imgSea,
  '/images/air-freight.webp': imgAir,
  '/images/3pl-4pl-operations.webp': img3pl,
  '/images/smart-invoice-processing.webp': imgInvoice,
};

interface Props {
  solution: Solution;
  heroImage?: string;
  heroImageAlt?: string;
}

const { solution, heroImage, heroImageAlt } = Astro.props;
const resolvedHeroImage = heroImage ? heroImageMap[heroImage] : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Solutions", "item": `${site.url}/solutions` },
    { "@type": "ListItem", "position": 3, "name": solution.title },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": solution.faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": solution.title,
  "description": solution.description,
  "provider": {
    "@type": "Organization",
    "name": "FreightMynd",
    "url": site.url
  },
  "serviceType": "AI Automation for Freight Operations",
  "areaServed": "Global",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": solution.title,
    "itemListElement": solution.capabilities.map(c => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": c.title,
        "description": c.description
      }
    }))
  }
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": solution.title,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Cloud",
  "description": solution.description,
  "featureList": solution.capabilities.map(c => c.title).join(', '),
  "provider": {
    "@type": "Organization",
    "name": "FreightMynd",
    "url": site.url
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Custom project-based pricing — no per-seat subscription"
  }
};

// Get related solutions using the relatedSolutions field
import { solutions } from '../data/solutions';
import { integrations } from '../data/integrations';

import { caseStudies } from '../data/case-studies';
import type { CaseStudy } from '../data/case-studies';

const relatedSolutionData = solution.relatedSolutions
  .map(slug => solutions.find(s => s.slug === slug))
  .filter((s): s is Solution => !!s);

const relatedIntegrationData = solution.relatedIntegrations
  .map(slug => integrations.find(i => i.slug === slug))
  .filter((i): i is import('../data/integrations').Integration => !!i);

const relatedCaseStudyData = (solution.relatedCaseStudies ?? [])
  .map(slug => caseStudies.find(cs => cs.slug === slug))
  .filter((cs): cs is CaseStudy => !!cs);

const primaryCaseStudy = relatedCaseStudyData[0];
---

<Page
  title={solution.metaTitle}
  description={solution.metaDescription}
  schema={[breadcrumbSchema, faqSchema, serviceSchema, softwareSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Solutions', href: '/solutions' }, { label: solution.shortTitle }]} />

  <!-- Hero -->
  <section class="pt-12 pb-20 md:pt-16 md:pb-28" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          {solution.keyword}
        </p>
        <h1 class="text-display-lg font-bold text-ink">{solution.headline}</h1>
        {solution.keywordSubheadline && (
          <p class="mt-3 text-base font-medium text-ink-3">{solution.keywordSubheadline}</p>
        )}
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{solution.sub}</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          {primaryCaseStudy ? (
            <a href={`/case-studies/${primaryCaseStudy.slug}`} class="btn btn-ghost">See It in Action</a>
          ) : (
            <a href="/case-studies/" class="btn btn-ghost">View Case Studies</a>
          )}
        </div>
      </div>
      {(resolvedHeroImage || heroImage) && (
        <div class="mt-12 max-w-4xl" data-reveal data-reveal-delay="1">
          {resolvedHeroImage ? (
            <Image
              src={resolvedHeroImage}
              alt={heroImageAlt || `${solution.shortTitle} AI automation system`}
              widths={[640, 768, 960]}
              sizes="(max-width: 960px) calc(100vw - 40px), 768px"
              quality={80}
              class="w-full rounded-2xl border border-line/70 shadow-lg"
            />
          ) : heroImage ? (
            <img
              src={heroImage}
              alt={heroImageAlt || `${solution.shortTitle} AI automation system`}
              width="960"
              height="540"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl border border-line/70 shadow-lg"
            />
          ) : null}
        </div>
      )}
    </div>
  </section>

  <!-- Ideal For -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-mint"></span>
          Built For
        </p>
        <h2 class="section-heading">Who Needs {solution.shortTitle} Automation</h2>
        <ul class="mt-6 grid gap-3">
          {solution.idealFor.map((item, i) => (
            <li class="flex gap-3 items-start" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <svg class="w-5 h-5 mt-0.5 text-mint flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-ink-3 leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Problem: Before FreightMynd -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-accent"></span>
          Before FreightMynd
        </p>
        <h2 class="section-heading">{solution.problem.headline}</h2>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{solution.problem.description}</p>
      </div>
      <div class="max-w-3xl mt-8 grid gap-3">
        {solution.problem.painPoints.map((point, i) => (
          <div class="flex gap-3 items-start p-4 rounded-xl bg-white border border-line/70"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            <p class="text-sm text-ink-3 leading-relaxed">{point}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          What We Build
        </p>
        <h2 class="section-heading">{solution.shortTitle} AI Capabilities</h2>
      </div>
      <div class="max-w-4xl grid gap-5">
        {solution.capabilities.map((cap, i) => (
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/50 hover:bg-white hover:shadow-md transition-all duration-200"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <div class="flex gap-4 items-start">
              <div class="w-8 h-8 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                {i + 1}
              </div>
              <div>
                <h3 class="text-base font-bold text-ink mb-2">{cap.title}</h3>
                <p class="text-sm text-ink-3 leading-relaxed">{cap.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          In Practice
        </p>
        <h2 class="section-heading">{solution.shortTitle} Use Cases in Production</h2>
      </div>
      <div class="max-w-4xl grid gap-5">
        {solution.useCases.map((uc, i) => (
          <div class="p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-200"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <h3 class="text-base font-bold text-ink mb-2">{uc.scenario}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Implementation -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Implementation
        </p>
        <h2 class="section-heading">How We Deploy {solution.shortTitle} AI</h2>
        <p class="mt-4 text-lg text-ink-3">
          Timeline: <span class="font-semibold text-ink">{solution.implementation.timeline}</span>
        </p>
      </div>
      <div class="max-w-3xl mt-8 grid gap-4">
        {solution.implementation.phases.map((phase, i) => (
          <div class="flex gap-4 p-5 rounded-2xl border border-line/70 bg-surface/50"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <div class="w-8 h-8 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
              {i + 1}
            </div>
            <p class="text-sm text-ink-3 leading-relaxed">{phase}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-20 md:py-28" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4 text-white/50">
          <span class="eyebrow-dot bg-brand"></span>
          Results
        </p>
        <h2 class="text-display-md font-bold text-white" style="padding-left:0; border-left:none;">Measurable Impact</h2>
      </div>

      <!-- Headline metrics row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        {solution.results.map((r, i) => (
          <div class="text-center" data-reveal data-reveal-delay={String(i + 1)}>
            <p class="text-display-md font-bold text-brand-mid">{r.value}</p>
            <p class="mt-1 text-sm font-medium text-white/70">{r.label}</p>
          </div>
        ))}
      </div>

      <!-- Detailed results table -->
      <div class="max-w-4xl mx-auto" data-reveal data-reveal-delay="2">
        <!-- Desktop table -->
        <div class="hidden md:block overflow-x-auto rounded-2xl border border-white/10">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-white/10 bg-white/[0.04]">
                <th scope="col" class="py-4 px-6 text-xs font-mono uppercase tracking-wider text-white/40 w-[15%]">Metric</th>
                <th scope="col" class="py-4 px-6 text-xs font-mono uppercase tracking-wider text-white/40 w-[20%]">Result</th>
                <th scope="col" class="py-4 px-6 text-xs font-mono uppercase tracking-wider text-white/40 w-[35%]">Context</th>
                <th scope="col" class="py-4 px-6 text-xs font-mono uppercase tracking-wider text-white/40 w-[30%]">Business Outcome</th>
              </tr>
            </thead>
            <tbody>
              {solution.results.map((r, i) => (
                <tr class={`border-b border-white/[0.06] ${i % 2 === 1 ? 'bg-white/[0.02]' : ''}`}>
                  <td class="py-4 px-6 text-sm text-white/60">{r.label}</td>
                  <td class="py-4 px-6 text-lg font-bold text-brand-mid">{r.value}</td>
                  <td class="py-4 px-6 text-sm text-white/50 leading-relaxed">{r.context || '—'}</td>
                  <td class="py-4 px-6 text-sm text-white/70 leading-relaxed">{r.businessOutcome || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile cards (stacked) -->
        <div class="md:hidden grid gap-4">
          {solution.results.map((r, i) => (
            <div class="p-5 rounded-xl border border-white/10 bg-white/[0.04]">
              <div class="flex items-baseline justify-between mb-3">
                <span class="text-sm text-white/60">{r.label}</span>
                <span class="text-xl font-bold text-brand-mid">{r.value}</span>
              </div>
              {r.context && (
                <p class="text-xs text-white/40 leading-relaxed">{r.context}</p>
              )}
              {r.businessOutcome && (
                <p class="mt-2 text-xs text-white/60 leading-relaxed">{r.businessOutcome}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Related Case Studies -->
  {relatedCaseStudyData.length > 0 && (
    <section class="section-sm bg-white border-b border-line">
      <div class="container">
        <div class="max-w-2xl mb-8" data-reveal>
          <h3 class="text-lg font-bold text-ink">Proof in Production</h3>
        </div>
        <div class={`grid gap-5 ${relatedCaseStudyData.length > 1 ? 'sm:grid-cols-2' : ''}`}>
          {relatedCaseStudyData.map((cs, i) => (
            <a href={`/case-studies/${cs.slug}`}
               class="group p-6 rounded-2xl border border-line/70 bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
               data-reveal data-reveal-delay={String(i + 1)}>
              <div class="flex items-center gap-3 mb-3">
                <span class="tag tag-brand">
                  <span class="w-1.5 h-1.5 rounded-full bg-mint animate-pulse-dot"></span>
                  Case Study
                </span>
                <span class="text-xs text-ink-4 font-mono">{cs.client}</span>
              </div>
              <h4 class="text-base font-bold text-ink mb-2 group-hover:text-brand transition-colors">{cs.title}</h4>
              <p class="text-sm text-ink-3 leading-relaxed flex-grow">{cs.description}</p>
              <div class="mt-4 inline-flex items-baseline gap-2">
                <span class="text-lg font-bold text-brand">{cs.heroMetric.value}</span>
                <span class="text-xs text-ink-4">{cs.heroMetric.label}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Tech Stack & Integrations -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="flex flex-wrap items-center gap-3 mb-6" data-reveal>
        <span class="text-sm font-semibold text-ink mr-2">Tech Stack:</span>
        {solution.stack.map(tech => (
          <span class="tag tag-brand">{tech}</span>
        ))}
      </div>
      <div class="flex flex-wrap items-center gap-3" data-reveal>
        <span class="text-sm font-semibold text-ink mr-2">Integrations:</span>
        {solution.integrations.map(intg => (
          <span class="tag tag-brand">{intg}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Integration Callout -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="p-8 rounded-2xl border border-brand-mid/30 bg-brand-light/50 flex flex-col md:flex-row items-start md:items-center gap-6" data-reveal>
        <div class="flex-grow">
          <h3 class="text-lg font-bold text-ink mb-1">Works with your existing TMS</h3>
          <p class="text-sm text-ink-3">Direct integration with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes.</p>
        </div>
        <a href="/integrations" class="btn btn-brand btn-sm flex-shrink-0">View Integrations</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">{solution.shortTitle} — Frequently Asked Questions</h2>
      </div>
      <div class="max-w-3xl grid gap-4">
        {solution.faq.map((item, i) => (
          <details class="group rounded-2xl border border-line/70 bg-surface/50 hover:bg-white transition-colors" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
              {item.q}
              <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div>
              <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Solutions -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">Related Freight AI Solutions</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {relatedSolutionData.map((sol, i) => (
          <a href={`/solutions/${sol.slug}`}
             class="group p-6 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(i + 1)}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
              <SolutionIcon slug={sol.slug} fallbackEmoji={sol.icon} class="w-5 h-5 text-brand" />
            </div>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{sol.shortTitle}</h3>
            <p class="text-sm text-ink-3 leading-relaxed flex-grow">{sol.description}</p>
          </a>
        ))}
      </div>

      {relatedIntegrationData.length > 0 && (
        <div class="mt-12" data-reveal>
          <h3 class="text-sm font-semibold text-ink mb-4">Works With</h3>
          <div class="flex flex-wrap gap-3">
            {relatedIntegrationData.map(intg => (
              <a href={`/integrations/${intg.slug}`}
                 class="inline-flex items-center gap-2 px-4 py-2.5 rounded-card border border-line bg-white text-sm font-medium text-ink-3 hover:text-brand hover:border-brand-mid hover:bg-brand-light transition-all duration-200">
                {intg.shortTitle}
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Automate Your {solution.shortTitle}?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll show you exactly what we'd build for your operations.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href={`/contact?interest=${solution.slug}`} class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
