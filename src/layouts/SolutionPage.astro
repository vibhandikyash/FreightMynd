---
import Page from './Page.astro';
import type { Solution } from '../data/solutions';

interface Props {
  solution: Solution;
}

const { solution } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cargoiq.pages.dev" },
    { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://cargoiq.pages.dev/solutions" },
    { "@type": "ListItem", "position": 3, "name": solution.title },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": solution.faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": `CargoIQ ${solution.title}`,
  "applicationCategory": "BusinessApplication",
  "description": solution.description,
  "featureList": solution.capabilities.map(c => c.title),
};

// Get related solutions (exclude current)
import { solutions } from '../data/solutions';
const related = solutions.filter(s => s.slug !== solution.slug).slice(0, 3);
---

<Page
  title={solution.metaTitle}
  description={solution.metaDescription}
  schema={[breadcrumbSchema, faqSchema, softwareSchema]}
>
  <!-- Breadcrumb -->
  <nav class="pt-20 pb-0 bg-surface" aria-label="Breadcrumb">
    <div class="container">
      <ol class="flex items-center gap-2 text-sm text-ink-4" role="list">
        <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/solutions" class="hover:text-ink transition-colors">Solutions</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-ink font-medium">{solution.shortTitle}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-12 pb-20 md:pt-16 md:pb-28" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          {solution.keyword}
        </p>
        <h1 class="text-display-lg font-bold text-ink">{solution.headline}</h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{solution.sub}</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn btn-brand">
            Book a Free Audit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/case-studies/hellmann-4pl-control-tower" class="btn btn-ghost">See It in Action</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ideal For -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-mint"></span>
          Built For
        </p>
        <h2 class="section-heading">Who This Is For</h2>
        <ul class="mt-6 grid gap-3">
          {solution.idealFor.map((item, i) => (
            <li class="flex gap-3 items-start" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <svg class="w-5 h-5 mt-0.5 text-mint flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-ink-3 leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Problem: Before CargoIQ -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-accent"></span>
          Before CargoIQ
        </p>
        <h2 class="section-heading">{solution.problem.headline}</h2>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{solution.problem.description}</p>
      </div>
      <div class="max-w-3xl mt-8 grid gap-3">
        {solution.problem.painPoints.map((point, i) => (
          <div class="flex gap-3 items-start p-4 rounded-xl bg-white border border-line/70"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            <p class="text-sm text-ink-3 leading-relaxed">{point}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          What We Build
        </p>
        <h2 class="section-heading">Capabilities</h2>
      </div>
      <div class="max-w-4xl grid gap-5">
        {solution.capabilities.map((cap, i) => (
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/50 hover:bg-white hover:shadow-md transition-all duration-200"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <div class="flex gap-4 items-start">
              <div class="w-8 h-8 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                {i + 1}
              </div>
              <div>
                <h3 class="text-base font-bold text-ink mb-2">{cap.title}</h3>
                <p class="text-sm text-ink-3 leading-relaxed">{cap.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          In Practice
        </p>
        <h2 class="section-heading">Real-World Use Cases</h2>
      </div>
      <div class="max-w-4xl grid gap-5">
        {solution.useCases.map((uc, i) => (
          <div class="p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-200"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <h3 class="text-base font-bold text-ink mb-2">{uc.scenario}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Implementation -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          Implementation
        </p>
        <h2 class="section-heading">How We Deploy It</h2>
        <p class="mt-4 text-lg text-ink-3">
          Timeline: <span class="font-semibold text-ink">{solution.implementation.timeline}</span>
        </p>
      </div>
      <div class="max-w-3xl mt-8 grid gap-4">
        {solution.implementation.phases.map((phase, i) => (
          <div class="flex gap-4 p-5 rounded-2xl border border-line/70 bg-surface/50"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <div class="w-8 h-8 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
              {i + 1}
            </div>
            <p class="text-sm text-ink-3 leading-relaxed">{phase}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-20 md:py-28" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4 text-white/50">
          <span class="eyebrow-dot bg-brand"></span>
          Results
        </p>
        <h2 class="text-display-md font-bold text-white" style="padding-left:0; border-left:none;">Real Numbers from Production Systems</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {solution.results.map((r, i) => (
          <div class="p-6 rounded-2xl border border-white/10 bg-white/[0.04]" data-reveal data-reveal-delay={String(i + 1)}>
            <p class="text-display-sm font-bold text-brand-mid">{r.value}</p>
            <p class="mt-2 text-sm text-white/60">{r.label}</p>
            {r.context && (
              <p class="mt-2 text-xs text-white/40 leading-relaxed">{r.context}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack & Integrations -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="flex flex-wrap items-center gap-3 mb-6" data-reveal>
        <span class="text-sm font-semibold text-ink mr-2">Tech Stack:</span>
        {solution.stack.map(tech => (
          <span class="tag tag-brand">{tech}</span>
        ))}
      </div>
      <div class="flex flex-wrap items-center gap-3" data-reveal>
        <span class="text-sm font-semibold text-ink mr-2">Integrations:</span>
        {solution.integrations.map(intg => (
          <span class="tag tag-brand">{intg}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Integration Callout -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="p-8 rounded-2xl border border-brand-mid/30 bg-brand-light/50 flex flex-col md:flex-row items-start md:items-center gap-6" data-reveal>
        <div class="flex-grow">
          <h3 class="text-lg font-bold text-ink mb-1">Works with your existing TMS</h3>
          <p class="text-sm text-ink-3">Direct integration with CargoWise, SAP TM, Oracle TMS, Microsoft Dynamics, and Descartes.</p>
        </div>
        <a href="/integrations" class="btn btn-brand btn-sm flex-shrink-0">View Integrations</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">Frequently Asked Questions</h2>
      </div>
      <div class="max-w-3xl grid gap-4">
        {solution.faq.map((item, i) => (
          <details class="group rounded-2xl border border-line/70 bg-surface/50 hover:bg-white transition-colors" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
              {item.q}
              <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Solutions -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">Related Solutions</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        {related.map((sol, i) => (
          <a href={`/solutions/${sol.slug}`}
             class="group p-6 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(i + 1)}>
            <span class="text-2xl mb-3" aria-hidden="true">{sol.icon}</span>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{sol.shortTitle}</h3>
            <p class="text-sm text-ink-3 leading-relaxed flex-grow">{sol.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Automate Your {solution.shortTitle}?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll show you exactly what we'd build for your operations.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
