---
import Page from './Page.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import SolutionIcon from '../components/ui/SolutionIcon.astro';
import { Image } from 'astro:assets';
import { site } from '../data/site';
import type { Integration } from '../data/integrations';
import type { ImageMetadata } from 'astro';

import imgCargowise from '../assets/images/cargowise-integration.webp';
import imgSap from '../assets/images/sap-tm-integration.webp';
import imgOracle from '../assets/images/oracle-tms-integration.webp';

const heroImageMap: Record<string, ImageMetadata> = {
  '/images/cargowise-integration.webp': imgCargowise,
  '/images/sap-tm-integration.webp': imgSap,
  '/images/oracle-tms-integration.webp': imgOracle,
};

interface Props {
  integration: Integration;
  heroImage?: string;
  heroImageAlt?: string;
}

const { integration, heroImage, heroImageAlt } = Astro.props;
const resolvedHeroImage = heroImage ? heroImageMap[heroImage] : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Integrations", "item": `${site.url}/integrations` },
    { "@type": "ListItem", "position": 3, "name": integration.shortTitle },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": integration.faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

import { integrations } from '../data/integrations';
import { solutions } from '../data/solutions';
import type { Solution } from '../data/solutions';
const related = integrations.filter(i => i.slug !== integration.slug).slice(0, 3);

const relevantSolutions = (integration.relatedSolutions ?? [])
  .map(slug => solutions.find(s => s.slug === slug))
  .filter((s): s is Solution => !!s);
const topSolutions = relevantSolutions.length > 0 ? relevantSolutions : solutions.slice(0, 3);
---

<Page
  title={integration.metaTitle}
  description={integration.metaDescription}
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Integrations', href: '/integrations' }, { label: integration.shortTitle }]} />

  <!-- Hero -->
  <section class="pt-12 pb-16 md:pt-16 md:pb-24" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          {integration.shortTitle} Integration
        </p>
        <h1 class="text-display-lg font-bold text-ink">{integration.title}</h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{integration.description}</p>
        <div class="mt-8">
          <a href="/contact" class="btn btn-brand">
            Discuss Your Integration
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
      {(resolvedHeroImage || heroImage) && (
        <div class="mt-12 max-w-4xl" data-reveal data-reveal-delay="1">
          {resolvedHeroImage ? (
            <Image
              src={resolvedHeroImage}
              alt={heroImageAlt || `${integration.shortTitle} AI integration architecture`}
              widths={[640, 960, 1280]}
              sizes="(max-width: 768px) 100vw, 960px"
              quality={80}
              class="w-full rounded-2xl border border-line/70 shadow-lg"
            />
          ) : heroImage ? (
            <img
              src={heroImage}
              alt={heroImageAlt || `${integration.shortTitle} AI integration architecture`}
              width="960"
              height="540"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl border border-line/70 shadow-lg"
            />
          ) : null}
        </div>
      )}
    </div>
  </section>

  <!-- Intro -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="text-lg text-ink-3 leading-relaxed">{integration.intro}</p>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">{integration.shortTitle} AI Integration Architecture</h2>
      </div>
      <div class="max-w-3xl grid gap-6" data-reveal data-reveal-delay="1">
        <div class="p-6 rounded-2xl bg-white border border-line/70">
          <div class="grid gap-5">
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-ink-4 mb-1.5">Connection Method</p>
              <p class="text-ink font-medium leading-relaxed">{integration.architecture.connectionMethod}</p>
            </div>
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-ink-4 mb-1.5">Supported Versions</p>
              <p class="text-ink font-medium leading-relaxed">{integration.architecture.supportedVersions}</p>
            </div>
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-ink-4 mb-2">Data Objects</p>
              <div class="flex flex-wrap gap-2">
                {integration.architecture.dataObjects.map(obj => (
                  <span class="tag tag-brand">{obj}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">{integration.shortTitle} AI Automation Capabilities</h2>
      </div>
      <div class="max-w-3xl grid gap-5">
        {integration.capabilities.map((cap, i) => (
          <div class="p-6 rounded-2xl border border-line/70 bg-surface/50 hover:bg-white hover:shadow-md transition-all duration-200"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-lg bg-brand/10 text-brand font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                {i + 1}
              </div>
              <div>
                <h3 class="text-ink font-semibold mb-2">{cap.title}</h3>
                <p class="text-ink-3 leading-relaxed text-[15px]">{cap.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Proof Block (conditional) -->
  {integration.proofBlock && (
    <section class="section-sm bg-surface">
      <div class="container">
        <div class="max-w-3xl" data-reveal>
          <div class="relative p-6 md:p-8 rounded-2xl bg-brand/5 border border-brand-mid">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-brand/10 text-brand flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="eyebrow mb-3">
                  <span class="eyebrow-dot bg-health"></span>
                  Live Deployment
                </p>
                <p class="text-ink leading-relaxed">{integration.proofBlock}</p>
                <a href="/case-studies/hellmann-4pl-control-tower"
                   class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold text-brand hover:text-brand-dark transition-colors">
                  Read the Hellmann case study
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- How it works -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <h2 class="section-heading mb-6">How FreightMynd Connects to {integration.shortTitle}</h2>
        <div class="flex items-center justify-between gap-2 md:gap-4 p-6 rounded-2xl bg-white border border-line/70 overflow-x-auto">
          {['Your Documents', 'FreightMynd AI', 'Validation', integration.shortTitle].map((step, i) => (
            <>
              <div class="flex flex-col items-center text-center min-w-[90px]">
                <div class="w-10 h-10 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center mb-2">
                  {i + 1}
                </div>
                <p class="text-sm font-semibold text-ink">{step}</p>
              </div>
              {i < 3 && (
                <svg class="w-5 h-5 text-brand/30 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">{integration.shortTitle} AI Integration — FAQ</h2>
      </div>
      <div class="max-w-3xl grid gap-4">
        {integration.faq.map((item, i) => (
          <details class="group rounded-2xl border border-line/70 bg-surface/50 hover:bg-white transition-colors" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
              {item.q}
              <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions that work with this integration -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">Solutions That Work with {integration.shortTitle}</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        {topSolutions.map((sol, i) => (
          <a href={`/solutions/${sol.slug}`}
             class="group p-6 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(i + 1)}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
              <SolutionIcon slug={sol.slug} fallbackEmoji={sol.icon} class="w-5 h-5 text-brand" />
            </div>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{sol.shortTitle}</h3>
            <p class="text-sm text-ink-3 leading-relaxed flex-grow">{sol.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Other integrations -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="max-w-2xl mb-8" data-reveal>
        <h3 class="text-lg font-bold text-ink">Other Integrations</h3>
      </div>
      <div class="flex flex-wrap gap-3" data-reveal>
        {related.map(intg => (
          <a href={`/integrations/${intg.slug}`} class="tag tag-brand hover:shadow-md transition-all">
            {intg.shortTitle}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Connect AI to {integration.shortTitle}?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll assess your {integration.shortTitle} setup and show you what's possible.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
