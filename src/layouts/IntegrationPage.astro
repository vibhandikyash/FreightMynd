---
import Page from './Page.astro';
import type { Integration } from '../data/integrations';

interface Props {
  integration: Integration;
}

const { integration } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cargoiq.pages.dev" },
    { "@type": "ListItem", "position": 2, "name": "Integrations", "item": "https://cargoiq.pages.dev/integrations" },
    { "@type": "ListItem", "position": 3, "name": integration.shortTitle },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": integration.faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

import { integrations } from '../data/integrations';
import { solutions } from '../data/solutions';
const related = integrations.filter(i => i.slug !== integration.slug).slice(0, 3);
const topSolutions = solutions.slice(0, 3);
---

<Page
  title={`${integration.keyword} | CargoIQ.ai`}
  description={integration.description}
  schema={[breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumb -->
  <nav class="pt-20 pb-0 bg-surface" aria-label="Breadcrumb">
    <div class="container">
      <ol class="flex items-center gap-2 text-sm text-ink-4" role="list">
        <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/integrations" class="hover:text-ink transition-colors">Integrations</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-ink font-medium">{integration.shortTitle}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-12 pb-16 md:pt-16 md:pb-24" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-brand"></span>
          {integration.shortTitle} Integration
        </p>
        <h1 class="text-display-lg font-bold text-ink">{integration.title}</h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{integration.description}</p>
        <div class="mt-8">
          <a href="/contact" class="btn btn-brand">
            Discuss Your Integration
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">Integration Capabilities</h2>
      </div>
      <div class="max-w-3xl grid gap-4">
        {integration.capabilities.map((cap, i) => (
          <div class="flex gap-3 p-5 rounded-2xl border border-line/70 bg-surface/50 hover:bg-white hover:shadow-md transition-all duration-200"
               data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <svg class="w-5 h-5 mt-0.5 text-mint flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <p class="text-ink-3 leading-relaxed">{cap}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <h2 class="section-heading mb-6">How CargoIQ Connects to {integration.shortTitle}</h2>
        <div class="flex items-center justify-between gap-2 md:gap-4 p-6 rounded-2xl bg-white border border-line/70 overflow-x-auto">
          {['Your Documents', 'CargoIQ AI', 'Validation', integration.shortTitle].map((step, i) => (
            <>
              <div class="flex flex-col items-center text-center min-w-[90px]">
                <div class="w-10 h-10 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center mb-2">
                  {i + 1}
                </div>
                <p class="text-sm font-semibold text-ink">{step}</p>
              </div>
              {i < 3 && (
                <svg class="w-5 h-5 text-brand/30 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">Frequently Asked Questions</h2>
      </div>
      <div class="max-w-3xl grid gap-4">
        {integration.faq.map((item, i) => (
          <details class="group rounded-2xl border border-line/70 bg-surface/50 hover:bg-white transition-colors" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
            <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
              {item.q}
              <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions that work with this integration -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <h2 class="section-heading">Solutions That Work with {integration.shortTitle}</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        {topSolutions.map((sol, i) => (
          <a href={`/solutions/${sol.slug}`}
             class="group p-6 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
             data-reveal data-reveal-delay={String(i + 1)}>
            <span class="text-2xl mb-3" aria-hidden="true">{sol.icon}</span>
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{sol.shortTitle}</h3>
            <p class="text-sm text-ink-3 leading-relaxed flex-grow">{sol.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Other integrations -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="max-w-2xl mb-8" data-reveal>
        <h3 class="text-lg font-bold text-ink">Other Integrations</h3>
      </div>
      <div class="flex flex-wrap gap-3" data-reveal>
        {related.map(intg => (
          <a href={`/integrations/${intg.slug}`} class="tag tag-brand hover:shadow-md transition-all">
            {intg.shortTitle}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Ready to Connect AI to {integration.shortTitle}?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll assess your {integration.shortTitle} setup and show you what's possible.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
