---
import Page from './Page.astro';
import type { CaseStudy } from '../data/case-studies';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cargoiq.pages.dev" },
    { "@type": "ListItem", "position": 2, "name": "Case Studies", "item": "https://cargoiq.pages.dev/case-studies" },
    { "@type": "ListItem", "position": 3, "name": study.title },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "articleSection": "Case Study",
  "headline": study.headline,
  "description": study.description,
  "author": { "@type": "Organization", "name": "CargoIQ.ai" },
  "publisher": { "@type": "Organization", "name": "CargoIQ.ai" },
  "about": { "@type": "Organization", "name": study.client },
  "keywords": study.keyword,
};

import { caseStudies } from '../data/case-studies';
const related = caseStudies.filter(s => s.slug !== study.slug).slice(0, 2);
---

<Page
  title={`${study.title} | CargoIQ.ai`}
  description={study.description}
  schema={[breadcrumbSchema, articleSchema]}
>
  <!-- Breadcrumb -->
  <nav class="pt-20 pb-0 bg-surface" aria-label="Breadcrumb">
    <div class="container">
      <ol class="flex items-center gap-2 text-sm text-ink-4" role="list">
        <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/case-studies" class="hover:text-ink transition-colors">Case Studies</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-ink font-medium truncate">{study.client}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-12 pb-16 md:pt-16 md:pb-24" style="background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-5">
          <span class="tag tag-brand">
            <span class="w-1.5 h-1.5 rounded-full bg-mint animate-pulse-dot"></span>
            Case Study
          </span>
          <span class="text-xs text-ink-4 font-mono">{study.client}</span>
        </div>
        <h1 class="text-display-lg font-bold text-ink">{study.headline}</h1>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{study.description}</p>

        <!-- Hero metric -->
        <div class="mt-8 inline-flex items-baseline gap-3 p-5 rounded-2xl bg-brand-light/50 border border-brand-mid/30">
          <span class="text-display-sm font-bold text-brand">{study.heroMetric.value}</span>
          <span class="text-sm text-ink-3">{study.heroMetric.label}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- The Challenge -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-accent"></span>
          The Challenge
        </p>
        <h2 class="section-heading">What They Were Dealing With</h2>
        <p class="mt-5 text-lg text-ink-3 leading-relaxed">{study.challenge}</p>
      </div>
    </div>
  </section>

  <!-- What We Built -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-3xl">
        <div class="mb-10" data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-brand"></span>
            What We Built
          </p>
          <h2 class="section-heading">The System</h2>
        </div>
        <div class="grid gap-4">
          {study.whatWeBuilt.map((item, i) => (
            <div class="flex gap-4 p-5 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-200"
                 data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <div class="w-8 h-8 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                {i + 1}
              </div>
              <p class="text-ink-3 leading-relaxed">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-20 md:py-28" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4 text-white/50">
          <span class="eyebrow-dot bg-mint"></span>
          Results
        </p>
        <h2 class="text-display-md font-bold text-white" style="padding-left:0; border-left:none;">Measurable Impact</h2>
      </div>
      <div class={`grid gap-6 ${study.results.length >= 4 ? 'grid-cols-2 md:grid-cols-4' : 'grid-cols-1 sm:grid-cols-3'}`}>
        {study.results.map((r, i) => (
          <div class="p-6 rounded-2xl border border-white/10 bg-white/[0.04]" data-reveal data-reveal-delay={String(i + 1)}>
            <p class="text-display-sm font-bold text-brand-mid">{r.value}</p>
            <p class="mt-2 text-sm text-white/60">{r.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="flex flex-wrap items-center gap-3" data-reveal>
        <span class="text-sm font-semibold text-ink mr-2">Tech Stack:</span>
        {study.stack.map(tech => (
          <span class="tag tag-brand">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Case Studies -->
  {related.length > 0 && (
    <section class="section bg-surface">
      <div class="container">
        <div class="max-w-2xl mb-12" data-reveal>
          <h2 class="section-heading">More Case Studies</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          {related.map((s, i) => (
            <a href={`/case-studies/${s.slug}`}
               class="group p-7 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
               data-reveal data-reveal-delay={String(i + 1)}>
              <span class="text-2xl mb-3" aria-hidden="true">{s.icon}</span>
              <span class="text-xs text-ink-4 font-mono mb-2">{s.client}</span>
              <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{s.title}</h3>
              <p class="text-sm text-ink-3 leading-relaxed flex-grow">{s.description}</p>
              <div class="mt-4 inline-flex items-baseline gap-2">
                <span class="text-lg font-bold text-brand">{s.heroMetric.value}</span>
                <span class="text-xs text-ink-4">{s.heroMetric.label}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #5B5EF0 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white max-w-2xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Want Results Like These?
      </h2>
      <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your operations and show you what's possible.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact" class="btn btn-white">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
