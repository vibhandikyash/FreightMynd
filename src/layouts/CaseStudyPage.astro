---
import Page from './Page.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import SolutionIcon from '../components/ui/SolutionIcon.astro';
import { site } from '../data/site';
import type { CaseStudy } from '../data/case-studies';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Case Studies", "item": `${site.url}/case-studies/` },
    { "@type": "ListItem", "position": 3, "name": study.title },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "articleSection": "Case Study",
  "headline": study.headline,
  "description": study.description,
  "author": { "@type": "Organization", "name": "FreightMynd" },
  "publisher": { "@type": "Organization", "name": "FreightMynd", "url": site.url },
  "about": { "@type": "Organization", "name": study.client },
  "keywords": study.keyword,
  "datePublished": "2025-09-15",
  "dateModified": "2026-03-17",
  "mentions": study.stack.map(tech => ({ "@type": "Thing", "name": tech })),
};

const faqSchema = study.faq && study.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": study.faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
} : null;

import { caseStudies } from '../data/case-studies';
import { solutions } from '../data/solutions';
import type { Solution } from '../data/solutions';
import { integrations } from '../data/integrations';
import type { Integration } from '../data/integrations';
const related = caseStudies.filter(s => s.slug !== study.slug).slice(0, 2);

const relatedSolutionData = (study.relatedSolutions ?? [])
  .map(slug => solutions.find(s => s.slug === slug))
  .filter((s): s is Solution => !!s);

const relatedIntegrationData = (study.relatedIntegrations ?? [])
  .map(slug => integrations.find(i => i.slug === slug))
  .filter((i): i is Integration => !!i);

const pageTitle = study.metaTitle ?? `${study.title} | FreightMynd`;
const pageDescription = study.metaDescription ?? study.description;
---

<Page
  title={pageTitle}
  description={pageDescription}
  schema={[breadcrumbSchema, articleSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Case Studies', href: '/case-studies/' }, { label: study.title }]} />

  <!-- Hero -->
  <section class="py-12 md:py-[60px] bg-surface">
    <div class="container">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-5">
          <span class="tag tag-brand">
            <span class="w-1.5 h-1.5 rounded-full bg-mint animate-pulse-dot"></span>
            Case Study
          </span>
          <span class="text-xs text-ink-4 font-mono">{study.client}</span>
        </div>
        <h1 class="text-display-lg font-bold text-ink">{study.headline}</h1>
        <p class="mt-5 hero-description text-ink-3">{study.description}</p>

        <!-- Hero metric -->
        <div class="mt-8 inline-flex items-baseline gap-3 p-5 rounded-2xl bg-brand-light/50 border border-brand-mid/30">
          <span class="text-display-sm font-bold text-brand">{study.heroMetric.value}</span>
          <span class="text-sm text-ink-3">{study.heroMetric.label}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Client Overview (if present) -->
  {study.clientOverview && (
    <section class="section-sm bg-surface border-b border-line">
      <div class="container">
        <div class="max-w-none" data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-brand"></span>
            Client Overview
          </p>
          <h2 class="section-heading">About {study.client}</h2>
          <p class="mt-5 text-lg text-ink-3 leading-relaxed">{study.clientOverview}</p>
        </div>
      </div>
    </section>
  )}

  <!-- The Challenge -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-none" data-reveal>
        <p class="eyebrow mb-4">
          <span class="eyebrow-dot bg-accent"></span>
          The Challenge
        </p>
        <h2 class="section-heading">What They Were Dealing With</h2>
        <p class="mt-5 text-base text-ink-3 leading-relaxed">{study.challenge}</p>
        {study.challengePoints && study.challengePoints.length > 0 && (
          <ul class="mt-8 grid gap-5 md:grid-cols-2">
            {study.challengePoints.map((point, i) => (
              <li class="flex gap-4 items-start p-6 rounded-2xl border border-line/70 bg-surface/50"
                  data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
                <svg class="w-6 h-6 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <span class="text-[17px] text-ink-3 leading-relaxed">{point}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </section>

  <!-- What We Built -->
  <section class="section bg-surface">
    <div class="container">
      <div class="max-w-none">
        <div class="mb-10" data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-brand"></span>
            What We Built
          </p>
          <h2 class="section-heading">The System</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          {study.whatWeBuilt.map((item, i) => (
            <div class="flex gap-4 p-6 rounded-2xl border border-line/70 bg-white hover:shadow-md transition-all duration-200"
                 data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <div class="w-8 h-8 rounded-xl bg-brand/10 text-brand font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                {i + 1}
              </div>
              <p class="text-base text-ink-3 leading-relaxed">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture (if present) -->
  {study.architecture && (
    <section class="section bg-white">
      <div class="container">
        <div class="max-w-none">
          <div class="mb-10" data-reveal>
            <p class="eyebrow mb-4">
              <span class="eyebrow-dot bg-brand"></span>
              System Architecture
            </p>
            <h2 class="section-heading">How It All Connects</h2>
          </div>
          <div class="grid gap-4">
            {study.architecture.map((step, i) => (
              <div class="flex gap-4 p-6 rounded-2xl border border-line/70 bg-surface hover:shadow-md transition-all duration-200"
                   data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
                <div class="w-8 h-8 rounded-full bg-brand text-white font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                  {i + 1}
                </div>
                <p class="text-base text-ink-3 leading-relaxed">{step}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Results -->
  <section class="py-12 md:py-[60px]" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="eyebrow mb-4 text-white/50">
          <span class="eyebrow-dot bg-mint"></span>
          Results
        </p>
        <h2 class="text-display-md font-bold text-white" style="padding-left:0; border-left:none;">Measurable Impact</h2>
      </div>
      <div class={`grid gap-6 ${study.results.length >= 4 ? 'grid-cols-2 md:grid-cols-4' : 'grid-cols-1 sm:grid-cols-3'}`}>
        {study.results.map((r, i) => (
          <div class="p-6 rounded-2xl border border-white/10 bg-white/[0.04]" data-reveal data-reveal-delay={String(i + 1)}>
            <p class="text-display-sm font-bold text-brand-mid">{r.value}</p>
            <p class="mt-2 text-sm text-white/60">{r.label}</p>
            {r.context && (
              <p class="mt-2 text-xs text-white/40 leading-relaxed">{r.context}</p>
            )}
          </div>
        ))}
      </div>
      {study.timeline && (
        <div class="mt-8 p-5 rounded-2xl border border-white/10 bg-white/[0.04] inline-flex items-center gap-3" data-reveal data-reveal-delay="5">
          <svg class="w-5 h-5 text-brand-mid flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-sm text-white/70"><span class="font-semibold text-white">Implementation Timeline:</span> {study.timeline}</p>
        </div>
      )}
    </div>
  </section>

  <!-- Mid-page CTA -->
  <section class="section-sm bg-brand-light/50 border-y border-brand-mid/20">
    <div class="container">
      <div class="flex flex-col md:flex-row items-start md:items-center gap-6" data-reveal>
        <div class="flex-grow">
          <h3 class="text-2xl font-bold text-ink mb-2">Want Results Like These?</h3>
          <p class="text-base md:text-lg leading-relaxed text-ink-3">Book a free audit — we'll map your operations and show you what's possible.</p>
        </div>
        <a href="/contact/" class="btn btn-brand btn-sm flex-shrink-0">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Key Learnings (if present) -->
  {study.keyLearnings && (
    <section class="section bg-surface">
      <div class="container">
        <div class="max-w-none">
          <div class="mb-10" data-reveal>
            <p class="eyebrow mb-4">
              <span class="eyebrow-dot bg-health"></span>
              Key Learnings
            </p>
            <h2 class="section-heading">What We Learned</h2>
          </div>
          <ul class="grid gap-5 md:grid-cols-2">
            {study.keyLearnings.map((learning, i) => (
              <li class="flex gap-4 p-6 rounded-2xl border border-line/70 bg-white"
                  data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
                <span class="w-6 h-6 rounded-full bg-health/10 text-health flex items-center justify-center flex-shrink-0 mt-0.5" aria-hidden="true">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <p class="text-base text-ink-3 leading-relaxed">{learning}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <!-- Tech Stack -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="flex flex-wrap items-center gap-3" data-reveal>
        <span class="text-sm font-semibold text-ink mr-2">Tech Stack:</span>
        {study.stack.map(tech => (
          <span class="tag tag-brand">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {study.faq && study.faq.length > 0 && (
    <section class="section bg-white">
      <div class="container">
        <div class="max-w-2xl mb-12" data-reveal>
          <p class="eyebrow mb-4">
            <span class="eyebrow-dot bg-brand"></span>
            FAQ
          </p>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <div class="max-w-3xl grid gap-4">
          {study.faq.map((item, i) => (
            <details class="group rounded-2xl border border-line/70 bg-surface/50 hover:bg-white transition-colors" data-reveal data-reveal-delay={String(Math.min(i + 1, 5))}>
              <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-semibold list-none">
                {item.q}
                <svg class="w-5 h-5 text-ink-4 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div>
                <div class="px-5 pb-5 text-ink-3 leading-relaxed">{item.a}</div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Solutions -->
  {relatedSolutionData.length > 0 && (
    <section class="section bg-white">
      <div class="container">
        <div class="max-w-2xl mb-12" data-reveal>
          <h2 class="section-heading">Related Solutions</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedSolutionData.map((sol, i) => (
            <a href={`/solutions/${sol.slug}/`}
               class="group p-6 rounded-2xl border border-line/70 bg-surface/50 hover:bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
               data-reveal data-reveal-delay={String(i + 1)}>
              <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
                <SolutionIcon slug={sol.slug} fallbackEmoji={sol.icon} class="w-5 h-5 text-brand" />
              </div>
              <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{sol.shortTitle}</h3>
              <p class="text-sm text-ink-3 leading-relaxed flex-grow">{sol.description}</p>
            </a>
          ))}
        </div>
        {relatedIntegrationData.length > 0 && (
          <div class="mt-10" data-reveal>
            <h3 class="text-sm font-semibold text-ink mb-4">Integrations Used</h3>
            <div class="flex flex-wrap gap-3">
              {relatedIntegrationData.map(intg => (
                <a href={`/integrations/${intg.slug}/`}
                   class="inline-flex items-center gap-2 px-4 py-2.5 rounded-card border border-line bg-white text-sm font-medium text-ink-3 hover:text-brand hover:border-brand-mid hover:bg-brand-light transition-all duration-200">
                  {intg.shortTitle}
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Related Case Studies -->
  {related.length > 0 && (
    <section class="section bg-surface">
      <div class="container">
        <div class="max-w-2xl mb-12" data-reveal>
          <h2 class="section-heading">More Case Studies</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          {related.map((s, i) => (
            <a href={`/case-studies/${s.slug}/`}
               class="group p-7 rounded-2xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300 flex flex-col"
               data-reveal data-reveal-delay={String(i + 1)}>
              <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center mb-3">
                <SolutionIcon slug={s.slug} fallbackEmoji={s.icon} class="w-5 h-5 text-brand" />
              </div>
              <span class="text-xs text-ink-4 font-mono mb-2">{s.client}</span>
              <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand transition-colors">{s.title}</h3>
              <p class="text-sm text-ink-3 leading-relaxed flex-grow">{s.description}</p>
              <div class="mt-4 inline-flex items-baseline gap-2">
                <span class="text-lg font-bold text-brand">{s.heroMetric.value}</span>
                <span class="text-xs text-ink-4">{s.heroMetric.label}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative py-12 md:py-[60px] overflow-hidden" style="background: linear-gradient(135deg, #24170E 0%, #382315 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-[40px] leading-[50px] md:text-[52px] md:leading-[64px] font-bold text-white max-w-3xl mx-auto" data-reveal style="padding-left:0; border-left:none;">
        Want Results Like These?
      </h2>
      <p class="mt-5 text-xl leading-8 text-white/80 max-w-2xl mx-auto" data-reveal data-reveal-delay="1">
        Book a free audit. We'll map your operations and show you what's possible.
      </p>
      <div class="mt-8" data-reveal data-reveal-delay="2">
        <a href="/contact/" class="btn btn-cta-single">Book a Free Audit</a>
      </div>
    </div>
  </section>
</Page>
