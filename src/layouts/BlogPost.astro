---
import Page from './Page.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  modifiedDate?: Date;
  author: string;
  category: string;
  tags: string[];
  readingTime: string;
  ogImage?: string;
  slug: string;
  wordCount?: number;
  faq?: Array<{ q: string; a: string }>;
  howToSteps?: string[];
  relatedSolutions?: string[];
  relatedCaseStudies?: string[];
  relatedIntegrations?: string[];
}

import { solutions } from '../data/solutions';
import { caseStudies } from '../data/case-studies';
import { integrations } from '../data/integrations';

const {
  title,
  description,
  publishDate,
  modifiedDate,
  author,
  category,
  tags,
  readingTime,
  ogImage,
  slug,
  wordCount,
  faq,
  howToSteps,
  relatedSolutions: relatedSolutionSlugs,
  relatedCaseStudies: relatedCaseStudySlugs,
  relatedIntegrations: relatedIntegrationSlugs,
} = Astro.props;

// Resolve related content from slugs
const relatedSolutionItems = (relatedSolutionSlugs ?? [])
  .map(s => solutions.find(sol => sol.slug === s))
  .filter(Boolean)
  .slice(0, 2);

const relatedCaseStudyItems = (relatedCaseStudySlugs ?? [])
  .map(s => caseStudies.find(cs => cs.slug === s))
  .filter(Boolean)
  .slice(0, 1);

const relatedIntegrationItems = (relatedIntegrationSlugs ?? [])
  .map(s => integrations.find(i => i.slug === s))
  .filter(Boolean)
  .slice(0, 1);

// Build dynamic continue reading cards
const continueReadingCards: Array<{ href: string; type: string; label: string }> = [];
for (const sol of relatedSolutionItems) {
  if (sol) continueReadingCards.push({ href: `/solutions/${sol.slug}`, type: 'Solution', label: sol.shortTitle });
}
for (const cs of relatedCaseStudyItems) {
  if (cs) continueReadingCards.push({ href: `/case-studies/${cs.slug}`, type: 'Case Study', label: cs.client });
}
for (const intg of relatedIntegrationItems) {
  if (intg) continueReadingCards.push({ href: `/integrations/${intg.slug}`, type: 'Integration', label: `${intg.shortTitle} AI Integration` });
}

// Fallback to default links if no related content specified
if (continueReadingCards.length === 0) {
  continueReadingCards.push(
    { href: '/solutions/4pl-control-tower-automation', type: 'Solution', label: '4PL Control Tower Automation' },
    { href: '/case-studies/hellmann-4pl-control-tower', type: 'Case Study', label: 'Hellmann Worldwide Logistics' },
    { href: '/integrations/cargowise', type: 'Integration', label: 'CargoWise AI Integration' },
  );
}

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = publishDate.toISOString();
const isoModified = modifiedDate ? modifiedDate.toISOString() : undefined;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${site.url}/blog` },
    { "@type": "ListItem", "position": 3, "name": title },
  ],
};

const ogImageUrl = ogImage ? (ogImage.startsWith('http') ? ogImage : `${site.url}${ogImage}`) : `${site.url}/og-default.webp`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImageUrl,
  "author": {
    "@type": "Organization",
    "name": "FreightMynd Team",
  },
  "publisher": {
    "@type": "Organization",
    "name": "FreightMynd",
    "url": site.url,
    "logo": {
      "@type": "ImageObject",
      "url": "https://freightmynd.com/FM-logo.svg",
    },
  },
  "datePublished": isoDate,
  ...(isoModified && { "dateModified": isoModified }),
  "mainEntityOfPage": `${site.url}/blog/${slug}`,
  "keywords": tags.join(', '),
  "inLanguage": "en-US",
  ...(wordCount && { "wordCount": wordCount }),
};

const howToSchema = howToSteps && howToSteps.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": title,
  "description": description,
  "step": howToSteps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "text": step,
  })),
} : null;

const faqSchema = faq && faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
} : null;

const allSchemas = [breadcrumbSchema, articleSchema, ...(faqSchema ? [faqSchema] : []), ...(howToSchema ? [howToSchema] : [])];
---

<Page
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
  schema={allSchemas}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[{ label: 'Blog', href: '/blog' }, { label: title }]} bg="bg-white" />

  <!-- Article Hero -->
  <header class="bg-white border-b border-line">
    <div class="container max-w-3xl mx-auto py-12 md:py-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="tag tag-brand">{category}</span>
        <span class="text-xs text-ink-4 font-mono">{readingTime}</span>
      </div>
      <h1 class="text-display-md font-bold text-ink leading-tight">
        {title}
      </h1>
      <p class="mt-4 text-lg text-ink-3 leading-relaxed">
        {description}
      </p>
      <div class="mt-6 flex items-center gap-4 text-sm text-ink-4">
        <span class="font-medium text-ink-3">{author}</span>
        <span aria-hidden="true" class="w-1 h-1 rounded-full bg-ink-4"></span>
        <time datetime={isoDate}>{formattedDate}</time>
      </div>
    </div>
  </header>

  <!-- Article Body -->
  <article class="section">
    <div class="container max-w-3xl mx-auto">
      <div class="article-body">
        <slot />
      </div>

      <!-- Tags -->
      <div class="mt-12 pt-8 border-t border-line flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="tag tag-brand">{tag}</span>
        ))}
      </div>
    </div>
  </article>

  <!-- Related Reading -->
  <section class="section bg-surface">
    <div class="container max-w-3xl mx-auto">
      <h2 class="text-display-sm font-bold text-ink mb-8" style="padding-left:0; border-left:none;">Continue Reading</h2>
      <div class={`grid gap-4 ${continueReadingCards.length >= 3 ? 'sm:grid-cols-3' : continueReadingCards.length === 2 ? 'sm:grid-cols-2' : ''}`}>
        {continueReadingCards.slice(0, 3).map(card => (
          <a href={card.href} class="p-5 rounded-xl border border-line/70 bg-white hover:shadow-hover hover:-translate-y-1 transition-all duration-300">
            <span class="text-xs font-mono text-brand uppercase tracking-wider">{card.type}</span>
            <p class="mt-2 text-sm font-semibold text-ink">{card.label}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);">
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-[-20%] left-[-10%] w-[300px] h-[300px] rounded-full bg-white/5 blur-3xl" aria-hidden="true"></div>
    <div class="container relative z-10 text-center">
      <h2 class="text-display-lg font-bold text-white max-w-3xl mx-auto" style="padding-left:0; border-left:none;">
        Want to See What This Looks Like for Your Operations?
      </h2>
      <p class="mt-5 text-lg text-white/80 max-w-xl mx-auto leading-relaxed">
        Book a free audit. We'll map your workflows, identify the highest-impact automation opportunities, and show you exactly what we'd build.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact" class="btn btn-white">
          Book a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/solutions" class="btn border border-white/30 text-white hover:bg-white/10">
          Explore Solutions
        </a>
      </div>
      <p class="mt-6 text-sm text-white/50">
        Takes 30 minutes. No commitment. Custom proposal within 48 hours.
      </p>
    </div>
  </section>
</Page>
