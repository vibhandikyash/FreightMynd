---
import Seo from '../components/global/Seo.astro';
import { site } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: object | object[];
}

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "FreightMynd",
  "url": site.url,
  "description": "AI-driven cargo data intelligence platform for sea, air & freight forwarders",
  "publisher": {
    "@type": "Organization",
    "name": "FreightMynd"
  }
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <Seo {...Astro.props} />
  <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
  <link rel="preload" href="/fonts/dm-sans-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/dm-mono-regular.woff2" as="font" type="font/woff2" crossorigin />
  <meta name="theme-color" content="#1A5FA8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
</head>
<body class="bg-surface text-ink antialiased">
  <slot />
  <script>
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          io.unobserve(e.target);
        }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  </script>
  <!-- Google Analytics + Clarity — loaded after page render -->
  <script is:inline>
    window.addEventListener('load', function() {
      var h = window.location.hostname;
      if (h === 'localhost' || h === '127.0.0.1' || h.endsWith('.local')) return;
      // GA4
      var s = document.createElement('script');
      s.src = 'https://www.googletagmanager.com/gtag/js?id=G-5QNK34P8J5';
      s.async = true;
      document.head.appendChild(s);
      s.onload = function() {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-5QNK34P8J5');
      };
      // Microsoft Clarity
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i+"?ref=bwt";
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "vwq8h1q4z6");
    });
  </script>
</body>
</html>
