---
import Seo from '../components/global/Seo.astro';
import { site } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: object | object[];
}

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CargoIQ.ai",
  "url": site.url,
  "description": "AI-driven cargo data intelligence platform for sea, air & freight forwarders",
  "publisher": {
    "@type": "Organization",
    "name": "CargoIQ.ai"
  }
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <Seo {...Astro.props} />
  <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
  <link rel="preload" href="/fonts/dm-sans-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/dm-mono-regular.woff2" as="font" type="font/woff2" crossorigin />
  <meta name="theme-color" content="#1A5FA8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-surface text-ink antialiased">
  <slot />
  <script>
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          io.unobserve(e.target);
        }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  </script>
</body>
</html>
